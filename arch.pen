ns-serif\" text-anchor=\"start\" letter-spacing=\"2\" opacity=\"1\">SITE AREA</text>\n    <text x=\"22\" y=\"458\" font-size=\"14\" fill=\"#1E1A16\" font-weight=\"500\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">3,200 m² · Sloping terrain</text>\n    <line x1=\"22\" y1=\"470\" x2=\"368\" y2=\"470\" stroke=\"rgba(30,26,22,0.10)\" stroke-width=\"1\" opacity=\"0.5\"/>\n    <text x=\"22\" y=\"506\" font-size=\"9\" fill=\"#9E9087\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"2\" opacity=\"1\">BUDGET</text>\n    <text x=\"22\" y=\"530\" font-size=\"14\" fill=\"#1E1A16\" font-weight=\"500\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">€ 2.8M indicative</text>\n    <line x1=\"22\" y1=\"542\" x2=\"368\" y2=\"542\" stroke=\"rgba(30,26,22,0.10)\" stroke-width=\"1\" opacity=\"0.5\"/>\n    <text x=\"22\" y=\"578\" font-size=\"9\" fill=\"#9E9087\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"2\" opacity=\"1\">DEADLINE</text>\n    <text x=\"22\" y=\"602\" font-size=\"14\" fill=\"#1E1A16\" font-weight=\"500\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Schematic by Sep 2026</text>\n    <line x1=\"22\" y1=\"614\" x2=\"368\" y2=\"614\" stroke=\"rgba(30,26,22,0.10)\" stroke-width=\"1\" opacity=\"0.5\"/>\n    <rect x=\"22\" y=\"744\" width=\"169\" height=\"44\" fill=\"#C4614A\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"106.5\" y=\"770\" font-size=\"13\" fill=\"#fff\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Accept Brief</text>\n    <rect x=\"199\" y=\"744\" width=\"169\" height=\"44\" fill=\"#F3EEE6\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"199\" y=\"744\" width=\"169\" height=\"44\" fill=\"n