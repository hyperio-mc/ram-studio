        {
          "id": "f119",
          "type": "TEXT",
          "x": 20,
          "y": 124,
          "width": 350,
          "height": 52,
          "content": "The Paradox of Choice argues that more options lead to worse decisions. But this applies equally to information consumption: more reading does not equal more clarity.",
          "fontSize": 11,
          "fill": "#EBE8F5",
          "fontWeight": 400,
          "fontFamily": "Inter",
          "textAlign": "left"
        },
        {
          "id": "f120",
          "type": "TEXT",
          "x": 20,
          "y": 182,
          "width": 350,
          "height": 14,
          "content": "More reading ≠ more clarity",
          "fontSize": 12,
          "fill": "#D4A853",
          "fontWeight": 600,
          "fontFamily": "Inter",
          "textAlign": "left"
        },
        {
          "id": "f121",
          "type": "TEXT",
          "x": 20,
          "y": 202,
          "width": 350,
          "height": 52,
          "content": "The brain doesn't distinguish relevant from irrelevant input until AFTER processing. Every notification consumes working memory before being classified as noise.",
          "fontSize": 11,
          "fill": "#EBE8F5",
          "fontWeight": 400,
          "fontFamily": "Inter",
          "textAlign": "left"
        },
        {
          "id": "f122",
          "type": "TEXT",
