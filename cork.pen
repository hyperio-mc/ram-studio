e","x":1309,"y":103,"width":74,"height":74,"fill":"#F9F7F7","cornerRadius":37},{"type":"text","content":"100","x":1332,"y":130,"fontSize":20,"fill":"#7A1B3F","fontFamily":"Georgia","fontWeight":700},{"type":"text","content":"pts","x":1338,"y":152,"fontSize":10,"fill":"#9B8B96","fontFamily":"Inter","fontWeight":400},{"type":"rectangle","x":648,"y":172,"width":12,"height":12,"fill":"#C49A3A","cornerRadius":1},{"type":"rectangle","x":664,"y":172,"width":12,"height":12,"fill":"#C49A3A","cornerRadius":1},{"type":"rectangle","x":680,"y":172,"width":12,"height":12,"fill":"#C49A3A","cornerRadius":1},{"type":"rectangle","x":696,"y":172,"width":12,"height":12,"fill":"#C49A3A","cornerRadius":1},{"type":"rectangle","x":712,"y":172,"width":12,"height":12,"fill":"#C49A3A","cornerRadius":1},{"type":"text","content":"Perfect · 5.0 / 5.0","x":740,"y":172,"fontSize":12,"fill":"#9B8B96","fontFamily":"Inter","fontWeight":400},{"type":"rectangle","x":648,"y":196,"width":744,"height":1,"fill":"#E4DDD9","cornerRadius":0},{"type":"text","content":"Serving temp:","x":648,"y":212,"fontSize":11,"fill":"#9B8B96","fontFamily":"Inter","fontWeight":400},{"type":"text","content":"16°C","x":734,"y":212,"fontSize":11,"fill":"#20033C","fontFamily":"Inter","fontWeight":600},{"type":"text","content":"Glassware:","x":804,"y":212,"fontSize":11,"fill":"#9B8B96","fontFamily":"Inter","fontWeight":400},{"type":"text","content":"Zalto Burgundy","x":866,"y":212,"fontSize":11,"fill":"#20033C","fontFamily":"Inter","fontWeight":600},{"type":"text","content":"Decanted:","x":984,"y":212,"fontSize":11,"fill":"#9B8B96","fontFamily":"Inter","fontWeight":400},{"type":"text","content":"90 min","x":1042,"y":212,"fontSize":11,"fill":"#20033C","fontFamily":"Inter","fontWeight":600},{"type":"rectangle","x":648,"y":226,"width":744,"height":1,"fill":"#E4DDD9","cornerRadius":0},{"type":"text","content":"Tasting Notes","x":648,"y":242,"fontSize":13,"fill":"#20033C","fontFamily":"Inter","fontWeight":700},{"type":"text","content":"\"The 2018 La Tâche possesses a transcendent quality that separates it from","x":648,"y":264,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"all other wines I have tasted this year. The color is a luminous ruby, almost","x":648,"y":282,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"garnet at the edges — a living painting.","x":648,"y":300,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"","x":648,"y":318,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"The nose is otherworldly: rose petal, black cherry, and woodland floor layer","x":648,"y":336,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"over a silky backbone. There is a florality here that reminds one of spring","x":648,"y":354,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"morning in the vineyards themselves.","x":648,"y":372,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"","x":648,"y":390,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"On the palate, the tannins are so fine they seem almost ethereal — present","x":648,"y":408,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"but yielding. The acidity is perfectly calibrated, lifting the fruit without","x":648,"y":426,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"sharpness. The finish lasts beyond three minutes and evolves continuously.\"","x":648,"y":444,"fontSize":13,"fill":"#5C4A5A","fontFamily":"Georgia","fontWeight":400},{"type":"text","content":"Flavor Profile","x":648,"y":474,"fontSize":13,"fill":"#20033C","fontFamily":"Inter","fontWeight":700},{"type":"rectangle","x":648,"y":494,"width":86,"height":26,"fill":"#7A1B3F15","cornerRadius":13},{"type":"text","content":"Rose Petal","x":656,"y":498,"fontSize":11,"fill":"#7A1B3F","fontFamily":"Inter","fontWeight":600},{"type":"rectangle","x":740,"y":494,"width":100,"height":26,"fill":"#7A1B3F15","cornerRadius":13},{"type":"text","content":"Black Cherry","x":748,"y":498,"fontSize":11,"fill":"#7A1B3F","fontFamily":"Inter","fontWeight":600},{"type":"rectangle","x":846,"y":494,"width":114,"height":26,"fill":"#7A1B3F15","cornerRadius":13},{"type":"text","content":"Woodland Floor","x":854,"y":498,"fontSize":11,"fill":"#7A1B3F","fontFamily":"Inter","fontWeight":600},{"type":"rectangle","x":966,"y":494,"width":44,"height":26,"fill":"#7A1B3F15","cornerRadius":13},{"type":"text","content":"Silk","x":974,"y":498,"fontSize":11,"fill":"#7A1B3F","fontFamily":"Inter","fontWeight":600},{"type":"rectangle","x":1016,"y":494,"width":79,"height":26,"fill":"#7A1B3F15","cornerRadius":13},{"type":"text","content":"Black Tea","x":1024,"y":498,"fontSize":11,"fill":"#7A1B3F","fontFamily":"Inter","fontWeight":600},{"type":"rectangle","x":1101,"y":494,"width":65,"height":26,"fill":"#7A1B3F15","cornerRadius":13},{"type":"text","content":"Truffle","x":1109,"y":498,"fontSize":11,"fill":"#7A1B3F","fontFamily":"Inter","fontWeight":600},{"type":"rectangle","x":1172,"y":494,"width":58,"height":26,"fill":"#7A1B3F15","cornerRadius":13},{"type":"text","content":"Violet","x":1180,"y":498,"fontSize":11,"fill":"#7A1B3F","fontFamily":"Inter","fontWeight":600},{"type":"text","content":"Profile","x":648,"y":540,"fontSize":13,"fill":"#20033C","fontFamily":"Inter","fontWeight":700},{"type":"text","content":"Tannins","x":648,"y":562,"fontSize":11,"fill":"#5C4A5A","fontFamily":"Inter","fontWeight":400},{"type":"rectangle","x":728,"y":563,"width":664,"height":8,"fill":"#D8CEC9","cornerRadius":4},{"type":"rectangle","x":728,"y":563,"width":298.8,"height":8,"fill":"#7A1B3F","cornerRadius":4},{"type":"text","content":"45%","x":1