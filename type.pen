fill=\"#4A5560\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Departure Mono</text>\n    <text x=\"358\" y=\"208\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">Body</text>\n    <rect x=\"32\" y=\"222\" width=\"326\" height=\"82\" fill=\"#F0EBE3\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"44\" y=\"242\" font-size=\"14\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">The Future</text>\n    <text x=\"44\" y=\"260\" font-size=\"14\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">of Type</text>\n    <text x=\"44\" y=\"282\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">A specimen for the new age of variable fonts</text>\n    <text x=\"44\" y=\"294\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">and digital typography.</text>\n    <rect x=\"20\" y=\"328\" width=\"350\" height=\"178\" fill=\"#FFFFFF\" rx=\"12\" opacity=\"1\" stroke=\"#DDD7CE\" stroke-width=\"0.8\"/>\n    <rect x=\"32\" y=\"338\" width=\"58\" height=\"18\" fill=\"#F0EBE3\" rx=\"9\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"61\" y=\"351\" font-size=\"8\" fill=\"#4A5560\" font-weight=\"700\" font-family=\"monospace\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">BRAND</text>\n    <text x=\"358\" y=\"351\" font-size=\"10\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">♡ 891</text>\n    <line x1=\"32\" y1=\"364\" x2=\"358\" y2=\"364\" stroke=\"#DDD7CE\" stroke-width=\"0.5\" opacity=\"1\"/>\n    <text x=\"32\" y=\"380\" font-size=\"11\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">GT Pantheon</text>\n    <text x=\"358\" y=\"380\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">H1</text>\n    <text x=\"32\" y=\"394\" font-size=\"11\" fill=\"#4A5560\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Inter</text>\n    <text x=\"358\" y=\"394\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">Body</text>\n    <rect x=\"32\" y=\"408\" width=\"326\" height=\"82\" fill=\"#F0EBE3\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"44\" y=\"428\" font-size=\"14\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Clarity</text>\n    <text x=\"44\" y=\"446\" font-size=\"14\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">in Motion</text>\n    <text x=\"44\" y=\"468\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Every character chosen with intention. Every</text>\n    <text x=\"44\" y=\"480\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">weight a deliberate choice.</text>\n    <rect x=\"20\" y=\"514\" width=\"350\" height=\"178\" fill=\"#FFFFFF\" rx=\"12\" opacity=\"1\" stroke=\"#DDD7CE\" stroke-width=\"0.8\"/>\n    <rect x=\"32\" y=\"524\" width=\"58\" height=\"18\" fill=\"#F0EBE3\" rx=\"9\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"61\" y=\"537\" font-size=\"8\" fill=\"#4A5560\" font-weight=\"700\" font-family=\"monospace\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">DISPLAY</text>\n    <text x=\"358\" y=\"537\" font-size=\"10\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">♡ 654</text>\n    <line x1=\"32\" y1=\"550\" x2=\"358\" y2=\"550\" stroke=\"#DDD7CE\" stroke-width=\"0.5\" opacity=\"1\"/>\n    <text x=\"32\" y=\"566\" font-size=\"11\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Swizzy</text>\n    <text x=\"358\" y=\"566\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">H1</text>\n    <text x=\"32\" y=\"580\" font-size=\"11\" fill=\"#4A5560\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Stabil Grotesk</text>\n    <text x=\"358\" y=\"580\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">Body</text>\n    <rect x=\"32\" y=\"594\" width=\"326\" height=\"82\" fill=\"#F0EBE3\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"44\" y=\"614\" font-size=\"14\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Bold</text>\n    <text x=\"44\" y=\"632\" font-size=\"14\" fill=\"#1C1814\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Statement</text>\n    <text x=\"44\" y=\"654\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Contrasting styles create visual hierarchy</text>\n    <text x=\"44\" y=\"666\" font-size=\"9\" fill=\"#9A9086\" font-weight=\"400\" font-family=\"monospace\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">th