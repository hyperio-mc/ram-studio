      "strokeWidth": 3
    },
    {
      "id": "el-133",
      "type": "line",
      "x1": 18,
      "y1": 1366,
      "x2": 21,
      "y2": 1366,
      "stroke": "#C8440C",
      "strokeWidth": 3
    },
    {
      "id": "el-134",
      "type": "text",
      "x": 28,
      "y": 1384,
      "content": "\"The model begins to believe its own",
      "fontSize": 13,
      "fontWeight": "700",
      "fontFamily": "Inter",
      "fill": "#1A1510",
      "textAlign": "left",
      "lineHeight": 1.5,
      "width": 330
    },
    {
      "id": "el-135",
      "type": "text",
      "x": 28,
      "y": 1402,
      "content": "mistakes — we found a 23% drift in",
      "fontSize": 13,
      "fontWeight": "700",
      "fontFamily": "Inter",
      "fill": "#1A1510",
      "textAlign": "left",
      "lineHeight": 1.5,
      "width": 330
    },
    {
      "id": "el-136",
      "type": "text",
      "x": 28,
      "y": 1420,
      "content": "factual accuracy after two cycles.\"",
      "fontSize": 13,
      "fontWeight": "700",
      "fontFamily": "Inter",
      "fill": "#1A1510",
      "textAlign": "left",
      "width": 330
    },
    {
      "id": "el-137",
      "type": "text",
      "x": 28,
      "y": 1438,
      "content": "— Dr. Marcus Webb, Stanford HAI",
      "fontSize": 10,
      "fontWeight": "600",
      "fontFamily": "Inter",
      "fill": "#8C7B6A",
      "textAlign": "left",
      "letterSpacing": 0.3
    },
    {
      "id": "el-138",
      "type": "text",
      "x": 18,
      "y": 1466,
      "content": "The findings, published Tuesday in Nature Machine",
      "fontSize": 14,
      "fontWeight": "400",
      "fontFamily": "Inter",
      "fill": "#4A4038",
      "textAlign": "left",
      "lineHeight": 1.65,
      "width": 354
    },
