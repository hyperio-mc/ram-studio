    },
    {
      "id": "el-127",
      "type": "text",
      "x": 8,
      "y": 1253,
      "content": "Conceptual illustration of recursive AI training loops — PRESS/Reuters",
      "fontSize": 7.5,
      "fontWeight": "400",
      "fontFamily": "Inter",
      "fill": "#F5F0E6",
      "textAlign": "left",
      "letterSpacing": 0.3
    },
    {
      "id": "el-128",
      "type": "text",
      "x": 18,
      "y": 1268,
      "content": "When a language model trains on its own outputs,",
      "fontSize": 14,
      "fontWeight": "400",
      "fontFamily": "Inter",
      "fill": "#4A4038",
      "textAlign": "left",
      "lineHeight": 1.65,
      "width": 354
    },
    {
      "id": "el-129",
      "type": "text",
      "x": 18,
      "y": 1290,
      "content": "something subtle begins to shift. Researchers at Stanford's",
      "fontSize": 14,
      "fontWeight": "400",
      "fontFamily": "Inter",
      "fill": "#4A4038",
      "textAlign": "left",
      "lineHeight": 1.65,
      "width": 354
    },
    {
      "id": "el-130",
      "type": "text",
      "x": 18,
      "y": 1312,
      "content": "Human-Centered AI Institute are calling this the \"Mirror Problem\"",
      "fontSize": 14,
      "fontWeight": "400",
      "fontFamily": "Inter",
      "fill": "#4A4038",
      "textAlign": "left",
      "lineHeight": 1.65,
      "width": 354
    },
    {
      "id": "el-131",
      "type": "text",
      "x": 18,
      "y": 1334,
      "content": "—  a feedback loop where AI errors compound.",
      "fontSize": 14,
      "fontWeight": "400",
      "fontFamily": "Inter",
      "fill": "#4A4038",
      "textAlign": "left",
      "lineHeight": 1.65,
      "width": 354
    },
    {
      "id": "el-132",
      "type": "rect",
      "x": 18,
      "y": 1366,
      "width": 354,
      "height": 84,
