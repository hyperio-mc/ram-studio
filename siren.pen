      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 390 844\" width=\"390\" height=\"844\">\n  <rect width=\"390\" height=\"844\" fill=\"#0C0C0F\"/>\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" rx=\"0\" fill=\"#0C0C0F\"/>\n    <text x=\"20\" y=\"30\" font-size=\"14\" fill=\"#F0EFE8\" font-weight=\"600\" font-family=\"Inter, system-ui, sans-serif\" text-anchor=\"start\" dy=\"0\">9:41</text>\n    <text x=\"370\" y=\"30\" font-size=\"10\" fill=\"#F0EFE8\" font-weight=\"400\" font-family=\"Inter, system-ui, sans-serif\" text-anchor=\"end\" opacity=\"0.6\" dy=\"0\">●●●</text>\n    <rect x=\"0\" y=\"44\" width=\"390\" height=\"56\" rx=\"0\" fill=\"#0C0C0F\"/>\n    <text x=\"20\" y=\"82\" font-size=\"22\" fill=\"#F59E0B\" font-weight=\"700\" font-family=\"\"JetBrains Mono\", monospace\" text-anchor=\"start\" letter-spacing=\"0.08em\" dy=\"0\">SIREN</text>\n    <text x=\"100\" y=\"82\" font-size=\"13\" fill=\"rgba(240,239,232,0.42)\" font-weight=\"400\" font-family=\"\"JetBrains Mono\", monospace\" text-anchor=\"start\" dy=\"0\">/ config</text>\n    <rect x=\"306\" y=\"64\" width=\"56\" height=\"22\" rx=\"4\" fill=\"#06B6D4\" opacity=\"0.15\"/>\n    <rect x=\"306\" y=\"64\" width=\"56\" height=\"22\" rx=\"4\" fill=\"none\" stroke=\"#06B6D4\" stroke-width=\"1\" opacity=\"0.35\"/>\n    <text x=\"334\" y=\"79\" font-size=\"10\" fill=\"#06B6D4\" font-weight=\"600\" font-family=\"\"JetBrains Mono\", \"Fira Code\", monospace\" text-anchor=\"middle\" letter-spacing=\"0.03em\" dy=\"0\">v2.4.1</text>\n    <text x=\"20\" y=\"130\" font-size=\"13\" fill=\"#F0EFE8\" font-weight=\"600\" font-family=\"Inter, system-ui, sans-serif\" text-anchor=\"start\" dy=\"0\">Alerting Rules</text>\n    <rect x=\"16\" y=\"140\" width=\"358\" height=\"46\" rx=\"10\" fill=\"#1B1B21\"/>\n    <text x=\"28\" y=\"166\" font-size=\"12\" fill=\"#F0EFE8\" font-weight=\"400\" font-family=\"Inter, system-ui, sans-serif\" text-anchor=\"start\" dy=\"0\">Error rate threshold</text>\n    <