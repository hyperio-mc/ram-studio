ng=\"0\" opacity=\"1\">⏱</text>\n<text x=\"44\" y=\"679\" font-size=\"12\" fill=\"rgba(148,163,184,0.55)\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">P99 latency</text>\n<text x=\"370\" y=\"679\" font-size=\"12\" fill=\"#00D4FF\" font-weight=\"600\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">200ms</text>\n<rect x=\"16\" y=\"698\" width=\"358\" height=\"36\" fill=\"#131A2E\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"28\" y=\"721\" font-size=\"12\" fill=\"rgba(148,163,184,0.55)\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">◉</text>\n<text x=\"44\" y=\"721\" font-size=\"12\" fill=\"rgba(148,163,184,0.55)\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">CPU usage</text>\n<text x=\"370\" y=\"721\" font-size=\"12\" fill=\"#00D4FF\" font-weight=\"600\" font-family=\"monospace\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">80%</text>\n<rect x=\"0\" y=\"762\" width=\"390\" height=\"82\" fill=\"#0D1220\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<line x1=\"0\" y1=\"762\" x2=\"390\" y2=\"762\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\" opacity=\"1\"/>\n<text x=\"51.8\" y=\"801\" font-size=\"18\" fill=\"rgba(148,163,184,0.55)\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◈</text>\n<text x=\"51.8\" y=\"817\" font-size=\"10\" fill=\"rgba(148,163,184,0.55)\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Overview</text>\n<text x=\"123.39999999999999\" y=\"801\" font-size=\"18\" fill=\"rgba(148,163,184,0.55)\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">⊹</text>\n<text x=\"123.39999999999999\" y=\"817\" font-size=\"10\" fill=\"rgba(148,163,184,0.55)\" font