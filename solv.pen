      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 390 844\" width=\"390\" height=\"844\" style=\"background:#0D0B13\">\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"50\" fill=\"#0D0B13\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"34\" font-size=\"15\" fill=\"#EDE9FE\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">9:41</text>\n  <text x=\"370\" y=\"34\" font-size=\"13\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">●●● ▲ ▌▌</text>\n  <text x=\"20\" y=\"82\" font-size=\"11\" fill=\"#A78BFA\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"1.5\" opacity=\"1\">ALERTS</text>\n  <text x=\"20\" y=\"106\" font-size=\"26\" fill=\"#EDE9FE\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">3 need attention</text>\n  <rect x=\"20\" y=\"126\" width=\"85.5\" height=\"22\" fill=\"#F472B6\" rx=\"11\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"62.75\" y=\"140\" font-size=\"11\" fill=\"#F472B6\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0.3\" opacity=\"1\">2 overdue</text>\n  <rect x=\"100\" y=\"126\" width=\"85.5\" height=\"22\" fill=\"#FBBF24\" rx=\"11\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"142.75\" y=\"140\" font-size=\"11\" fill=\"#FBBF24\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0.3\" opacity=\"1\">1 at risk</text>\n  <rect x=\"160\" y=\"126\" width=\"63\" height=\"22\" fill=\"#34D399\" rx=\"11\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"191.5\" y=\"140\" font-size=\"11\" fill=\"#34D399\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0.3\" opacity=\"1\">3 safe</text>\n  <rect x=\"20\" y=\"156\" width=\"350\" height=\"100\" fill=\"#1C1829\" rx=\"14\" opacity=\"1\" stroke=\"rgba(167,139,250,0.12)\" stroke-width=\"1\"/>\n  <rect x=\"20\" y=\"164\" width=\"4\" height=\"84\" fill=\"#F472B6\" rx=\"2\" opacity=\"0.8\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"46\" cy=\"182\" r=\"14\" fill=\"#F472B6\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"46\" y=\"187\" font-size=\"13\" fill=\"#F472B6\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">!</text>\n  <text x=\"66\" y=\"178\" font-size=\"13\" fill=\"#EDE9FE\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Acme Co. — 5 days overdue</text>\n  <text x=\"66\" y=\"194\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Invoice #2035 for $850 was due Apr 8. Send a</text>\n  <text x=\"66\" y=\"208\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\"> reminder to avoid escalation.</text>\n  <rect x=\"230\" y=\"224\" width=\"124\" height=\"24\" fill=\"#F472B6\" rx=\"12\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"292\" y=\"239\" font-size=\"11\" fill=\"#F472B6\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Send Reminder</text>\n  <rect x=\"20\" y=\"268\" width=\"350\" height=\"100\" fill=\"#1C1829\" rx=\"14\" opacity=\"1\" stroke=\"rgba(167,139,250,0.12)\" stroke-width=\"1\"/>\n  <rect x=\"20\" y=\"276\" width=\"4\" height=\"84\" fill=\"#FBBF24\" rx=\"2\" opacity=\"0.8\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"46\" cy=\"294\" r=\"14\" fill=\"#FBBF24\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"46\" y=\"299\" font-size=\"13\" fill=\"#FBBF24\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">⚡</text>\n  <text x=\"66\" y=\"290\" font-size=\"13\" fill=\"#EDE9FE\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Stripe Inc. — due tomorrow</text>\n  <text x=\"66\" y=\"306\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Invoice #2038 for $1,200 due Apr 14. Payment</text>\n  <text x=\"66\" y=\"320\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\"> not yet initiated by client.</text>\n  <rect x=\"238\" y=\"336\" width=\"116\" height=\"24\" fill=\"#FBBF24\" rx=\"12\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"296\" y=\"351\" font-size=\"11\" fill=\"#FBBF24\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Check Status</text>\n  <rect x=\"20\" y=\"380\" width=\"350\" height=\"100\" fill=\"#1C1829\" rx=\"14\" opacity=\"1\" stroke=\"rgba(167,139,250,0.12)\" stroke-width=\"1\"/>\n  <rect x=\"20\" y=\"388\" width=\"4\" height=\"84\" fill=\"#FBBF24\" rx=\"2\" opacity=\"0.8\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"46\" cy=\"406\" r=\"14\" fill=\"#FBBF24\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"46\" y=\"411\" font-size=\"13\" fill=\"#FBBF24\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">↘</text>\n  <text x=\"66\" y=\"402\" font-size=\"13\" fill=\"#EDE9FE\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Runway dropping</text>\n  <text x=\"66\" y=\"418\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Current burn vs income suggests runway will </text>\n  <text x=\"66\" y=\"432\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">fall below 30 days in 3 weeks if Acme stays </text>\n  <rect x=\"230\" y=\"448\" width=\"124\" height=\"24\" fill=\"#FBBF24\" rx=\"12\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"292\" y=\"463\" font-size=\"11\" fill=\"#FBBF24\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">View Forecast</text>\n  <rect x=\"20\" y=\"492\" width=\"350\" height=\"100\" fill=\"#1C1829\" rx=\"14\" opacity=\"1\" stroke=\"rgba(167,139,250,0.12)\" stroke-width=\"1\"/>\n  <rect x=\"20\" y=\"500\" width=\"4\" height=\"84\" fill=\"#22D3EE\" rx=\"2\" opacity=\"0.8\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"46\" cy=\"518\" r=\"14\" fill=\"#22D3EE\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"46\" y=\"523\" font-size=\"13\" fill=\"#22D3EE\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">✓</text>\n  <text x=\"66\" y=\"514\" font-size=\"13\" fill=\"#EDE9FE\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Figma Inc. — payment expected</text>\n  <text x=\"66\" y=\"530\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Invoice #2041 for $2,400 due in 3 days. Figm</text>\n  <text x=\"66\" y=\"544\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">a has a 98% on-time rate.</text>\n  <rect x=\"238\" y=\"560\" width=\"116\" height=\"24\" fill=\"#22D3EE\" rx=\"12\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"296\" y=\"575\" font-size=\"11\" fill=\"#22D3EE\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">View Invoice</text>\n  <rect x=\"20\" y=\"604\" width=\"350\" height=\"100\" fill=\"#1C1829\" rx=\"14\" opacity=\"1\" stroke=\"rgba(167,139,250,0.12)\" stroke-width=\"1\"/>\n  <rect x=\"20\" y=\"612\" width=\"4\" height=\"84\" fill=\"#34D399\" rx=\"2\" opacity=\"0.8\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"46\" cy=\"630\" r=\"14\" fill=\"#34D399\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"46\" y=\"635\" font-size=\"13\" fill=\"#34D399\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">★</text>\n  <text x=\"66\" y=\"626\" font-size=\"13\" fill=\"#EDE9FE\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Q1 summary ready</text>\n  <text x=\"66\" y=\"642\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">You collected $31,200 in Q1. That's 24% more</text>\n  <text x=\"66\" y=\"656\" font-size=\"11\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\"> than Q4 2025. View full report.</text>\n  <rect x=\"246\" y=\"672\" width=\"108\" height=\"24\" fill=\"#34D399\" rx=\"12\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"300\" y=\"687\" font-size=\"11\" fill=\"#34D399\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">View Report</text>\n  <rect x=\"0\" y=\"762\" width=\"390\" height=\"82\" fill=\"#141121\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <line x1=\"0\" y1=\"762\" x2=\"390\" y2=\"762\" stroke=\"rgba(167,139,250,0.12)\" stroke-width=\"1\" opacity=\"1\" stroke-linecap=\"round\"/>\n  <circle cx=\"39\" cy=\"788\" r=\"9\" fill=\"#A89FC5\" opacity=\"0.12\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"39\" y=\"793\" font-size=\"13\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">⌂</text>\n  <text x=\"39\" y=\"814\" font-size=\"10\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Dash</text>\n  <circle cx=\"117\" cy=\"788\" r=\"9\" fill=\"#A89FC5\" opacity=\"0.12\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"117\" y=\"793\" font-size=\"13\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◈</text>\n  <text x=\"117\" y=\"814\" font-size=\"10\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Pipeline</text>\n  <circle cx=\"195\" cy=\"788\" r=\"9\" fill=\"#A89FC5\" opacity=\"0.12\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"195\" y=\"793\" font-size=\"13\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◎</text>\n  <text x=\"195\" y=\"814\" font-size=\"10\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Forecast</text>\n  <circle cx=\"273\" cy=\"788\" r=\"9\" fill=\"#A89FC5\" opacity=\"0.12\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"273\" y=\"793\" font-size=\"13\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">⊙</text>\n  <text x=\"273\" y=\"814\" font-size=\"10\" fill=\"#A89FC5\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Clients</text>\n  <rect x=\"327\" y=\"764\" width=\"48\" height=\"3\" fill=\"#A78BFA\" rx=\"2\" opacity=\"0.85\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"351\" cy=\"788\" r=\"10\" fill=\"#A78BFA\" opacity=\"0.25\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"351\" y=\"793\" font-size=\"13\" fill=\"#A78BFA\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◉</text>\n  <text x=\"351\" y=\"814\" font-size=\"10\" fill=\"#A78BFA\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Alerts</text>\n</svg>",
