          "opacity": 1
        },
        {
          "type": "text",
          "x": 20,
          "y": 305,
          "content": "I woke before my alarm. The apartment was",
          "fontSize": 12,
          "fill": "#2B2620",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "textAnchor": "start",
          "letterSpacing": "0",
          "opacity": 1
        },
        {
          "type": "text",
          "x": 20,
          "y": 323,
          "content": "still, and I made coffee slowly, on purpose.",
          "fontSize": 12,
          "fill": "#2B2620",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "textAnchor": "start",
          "letterSpacing": "0",
          "opacity": 1
        },
        {
          "type": "text",
          "x": 20,
          "y": 341,
