nt-weight=\"600\" font-family=\"Inter, sans-serif\">Hosted by James</text><text x=\"58\" y=\"420\" font-size=\"11\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Superhost · 4 years hosting</text><line x1=\"20\" y1=\"436\" x2=\"370\" y2=\"436\" stroke=\"#DDD8CE\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"63.75\" y=\"460\" font-size=\"18\" fill=\"#4A3728\" font-weight=\"700\" font-family=\"Playfair Display, sans-serif\" text-anchor=\"middle\">2</text><text x=\"63.75\" y=\"476\" font-size=\"9\" fill=\"#A89E94\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">Bedrooms</text><line x1=\"107.5\" y1=\"448\" x2=\"107.5\" y2=\"480\" stroke=\"#DDD8CE\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"151.25\" y=\"460\" font-size=\"18\" fill=\"#4A3728\" font-weight=\"700\" font-family=\"Playfair Display, sans-serif\" text-anchor=\"middle\">1</text><text x=\"151.25\" y=\"476\" font-size=\"9\" fill=\"#A89E94\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">Bathroom</text><line x1=\"195\" y1=\"448\" x2=\"195\" y2=\"480\" stroke=\"#DDD8CE\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"238.75\" y=\"460\" font-size=\"18\" fill=\"#4A3728\" font-weight=\"700\" font-family=\"Playfair Display, sans-serif\" text-anchor=\"middle\">4</text><text x=\"238.75\" y=\"476\" font-size=\"9\" fill=\"#A89E94\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">Guests</text><line x1=\"282.5\" y1=\"448\" x2=\"282.5\" y2=\"480\" stroke=\"#DDD8CE\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"326.25\" y=\"460\" font-size=\"18\" fill=\"#4A3728\" font-weight=\"700\" font-family=\"Playfair Display, sans-serif\" text-anchor=\"middle\">3ac</text><text x=\"326.25\" y=\"476\" font-size=\"9\" fill=\"#A89E94\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">Property</text><line x1=\"20\" y1=\"490\" x2=\"370\" y2=\"490\" stroke=\"#DDD8CE\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"20\" y=\"510\" font-size=\"14\" fill=\"#2A2018\" font-weight=\"700\" font-family=\"Inter, sans-serif\">About this space</text><text x=\"20\" y=\"530\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">A handcrafted cabin nestled among old-growth</text><text x=\"20\" y=\"548\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Douglas fir on 3 private acres. Floor-to-ceiling</text><text x=\"20\" y=\"566\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">windows frame forest views from every room.</text><text x=\"20\" y=\"584\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">The wood-fired hot tub is lit at dusk.</text><text x=\"20\" y=\"610\" font-size=\"14\" fill=\"#2A2018\" font-weight=\"700\" font-family=\"Inter, sans-serif\">Amenities</text><text x=\"20\" y=\"630\" font-size=\"13\" fill=\"[object Object]\" font-family=\"Inter, sans-serif\">🌲</text><text x=\"42\" y=\"630\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Forest trails</text><text x=\"195\" y=\"630\" font-size=\"13\" fill=\"[object Object]\" font-family=\"Inter, sans-serif\">🛁</text><text x=\"217\" y=\"630\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Hot tub</text><text x=\"20\" y=\"656\" font-size=\"13\" fill=\"[object Object]\" font-family=\"Inter, sans-serif\">🔥</text><text x=\"42\" y=\"656\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Fireplace</text><text x=\"195\" y=\"656\" font-size=\"13\" fill=\"[object Object]\" font-family=\"Inter, sans-serif\">☕</text><text x=\"217\" y=\"656\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Espresso bar</text><text x=\"20\" y=\"682\" font-size=\"13\" fill=\"[object Object]\" font-family=\"Inter, sans-serif\">🌐</text><text x=\"42\" y=\"682\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Wi-Fi</text><text x=\"195\" y=\"682\" font-size=\"13\" fill=\"[object Object]\" font-family=\"Inter, sans-serif\">🚗</text><text x=\"217\" y=\"682\" font-size=\"12\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">Free parking</text><rect x=\"0\" y=\"760\" width=\"390\" height=\"84\" fill=\"#FFFFFF\" opacity=\"1\"/><line x1=\"0\" y1=\"760\" x2=\"390\" y2=\"760\" stroke=\"#DDD8CE\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"20\" y=\"789\" font-size=\"20\" fill=\"#4A3728\" font-weight=\"700\" font-family=\"Playfair Display, sans-serif\">$280</text><text x=\"74\" y=\"789\" font-size=\"13\" fill=\"#7A6E62\" font-family=\"Inter, sans-serif\">/night</text><text x=\"20\" y=\"808\" font-size=\"11\" fill=\"#A89E94\" font-family=\"Inter, sans-serif\">5 nights · $1,400 total</text><rect x=\"246\" y=\"770\" width=\"128\" height=\"44\" fill=\"#4A3728\" rx=\"22\" opacity=\"1\"/><text x=\"310\" y=\"797\" font-size=\"14\" fill=\"#FFFFFF\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">Reserve →</text></svg>",
