          "textAlign": "left",
          "letterSpacing": 0.5
        },
        {
          "id": "v516",
          "type": "frame",
          "x": 20,
          "y": 174,
          "width": 30,
          "height": 2,
          "fill": "#C8A96E",
          "clip": false,
          "cornerRadius": 1,
          "children": []
        },
        {
          "id": "v517",
          "type": "text",
          "content": "The version of myself I was trying to become\ntwo years ago would be confused by who I am\nnow. Not disappointed — confused.",
          "x": 20,
          "y": 188,
          "width": 335,
          "height": 58,
          "textGrowth": "fixed-width-height",
          "fontSize": 15,
          "fontWeight": "400",
          "fill": "#E8E3D8",
          "textAlign": "left",
          "lineHeight": 26
        },
        {
          "id": "v518",
          "type": "text",
          "content": "He was running toward something he could\nname. A title. A number. A city. Now I can't\ntell you what I'm running toward, only that\nI'm still moving.",
          "x": 20,
          "y": 260,
          "width": 335,
          "height": 74,
          "textGrowth": "fixed-width-height",
          "fontSize": 15,
          "fontWeight": "400",
          "fill": "#E8E3D8",
          "textAlign": "left",
          "lineHeight": 26
        },
        {
          "id": "v519",
          "type": "frame",
          "x": 0,
          "y": 348,
          "width": 6,
          "height": 80,
          "fill": "#C8A96E",
          "clip": false,
          "children": []
        },
        {
          "id": "v520",
          "type": "text",
          "content": "\"Maybe that's the point. Maybe you\nhave to stop being able to see it\nbefore you can actually reach it.\"",
          "x": 26,
          "y": 354,
          "width": 330,
          "height": 68,
          "textGrowth": "fixed-width-height",
          "fontSize": 14,
          "fontWeight": "300",
          "fill": "#E8E3D8",
          "textAlign": "left",
          "lineHeight": 24
        },
        {
          "id": "v521",
          "type": "text",
          "content": "The coffee went cold. I kept writing.",
          "x": 20,
          "y": 442,
          "width": 335,
          "height": 20,
          "textGrowth": "fixed-width-height",
          "fontSize": 15,
          "fontWeight": "400",
          "fill": "#9A9487",
          "textAlign": "left",
          "lineHeight": 26
        },
