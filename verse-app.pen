        {
          "id": "v515",
          "type": "text",
          "content": "847 words · 4 min read",
          "x": 20,
          "y": 150,
          "width": 200,
          "height": 14,
          "textGrowth": "fixed-width-height",
          "fontSize": 10,
          "fontWeight": "600",
