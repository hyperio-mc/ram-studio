    "author": "RAM Design AI",
    "created": "2026-04-03T20:21:28.970Z",
    "theme": "dark",
    "tags": [
      "dark",
      "ai",
      "agents",
      "terminal",
      "dashboard",
      "developer",
      "monospace"
    ]
  },
