        {
          "type": "text",
          "x": 20,
          "y": 84,
          "width": 240,
          "content": "Chapter 7 — The Art of Slowness",
          "fontSize": 12,
          "color": "#78716C",
          "fontWeight": "medium",
          "textAlign": "left",
          "lineHeight": 1.3
        },
        {
          "type": "rectangle",
          "x": 20,
          "y": 106,
          "width": 350,
          "height": 4,
          "fill": "#F3F0EB",
          "cornerRadius": 2,
          "stroke": "none",
