        },
        {
          "type": "rectangle",
          "x": 20,
          "y": 106,
          "width": 224,
          "height": 4,
          "fill": "#C9853A",
          "cornerRadius": 2,
          "stroke": "none",
          "strokeWidth": 0
        },
        {
          "type": "text",
          "x": 340,
          "y": 100,
          "width": 40,
          "content": "64%",
          "fontSize": 10,
          "color": "#C9853A",
          "fontWeight": "semibold",
          "textAlign": "right",
          "lineHeight": 1.3
        },
        {
          "type": "rectangle",
          "x": 20,
          "y": 118,
          "width": 350,
          "height": 1,
          "fill": "#E5E0D8",
          "cornerRadius": 0,
          "stroke": "none",
          "strokeWidth": 0
        },
        {
          "type": "text",
          "x": 28,
          "y": 134,
          "width": 334,
          "content": "There is a profound pleasure in the deliberate act of reading — one that demands we resist the tyranny of the immediate.",
          "fontSize": 16,
          "color": "#1C1917",
          "fontWeight": "regular",
          "textAlign": "left",
          "lineHeight": 1.65
        },
        {
          "type": "rectangle",
          "x": 20,
          "y": 228,
          "width": 350,
          "height": 96,
          "fill": "#FFF5E6",
          "cornerRadius": 8,
          "stroke": "none",
          "strokeWidth": 0
        },
        {
          "type": "rectangle",
          "x": 20,
          "y": 228,
          "width": 4,
          "height": 96,
          "fill": "#C9853A",
          "cornerRadius": 0,
          "stroke": "none",
          "strokeWidth": 0
        },
        {
          "type": "text",
          "x": 32,
          "y": 238,
          "width": 330,
          "content": "\"The book is the only medium that requires the reader to construct the world in their own image.\"",
          "fontSize": 15,
          "color": "#1C1917",
          "fontWeight": "regular",
          "textAlign": "left",
          "lineHeight": 1.6
        },
        {
          "type": "text",
          "x": 346,
          "y": 298,
          "width": 20,
          "content": "▨",
          "fontSize": 16,
          "color": "#C9853A",
          "fontWeight": "regular",
          "textAlign": "center",
          "lineHeight": 1.3
        },
        {
          "type": "text",
          "x": 28,
          "y": 340,
          "width": 334,
          "content": "We return to the same passages not because we have forgotten, but because we have changed — and the text reveals something new in consequence.",
          "fontSize": 16,
          "color": "#1C1917",
          "fontWeight": "regular",
          "textAlign": "left",
          "lineHeight": 1.65
        },
        {
          "type": "text",
          "x": 28,
          "y": 436,
          "width": 334,
          "content": "Annotation is not defacement of the page but rather the opening of a dialogue across time with an author long gone.",
          "fontSize": 16,
          "color": "#1C1917",
          "fontWeight": "regular",
          "textAlign": "left",
          "lineHeight": 1.65
        },
        {
