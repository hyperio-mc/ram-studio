    {
      "name": "Review Deliverable",
      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n  <defs><style>text{font-family:'Inter',system-ui,sans-serif}</style></defs>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#0D0F14\" rx=\"0\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#12151D\" rx=\"0\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"20\" y=\"28\" font-size=\"13\" fill=\"#94A3B8\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">9:41</text>\n<rect x=\"0\" y=\"44\" width=\"390\" height=\"52\" fill=\"#12151D\" rx=\"0\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"0\" y=\"95\" width=\"390\" height=\"1\" fill=\"#252D40\" rx=\"0\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"20\" y=\"78\" font-size=\"13\" fill=\"#E2E8F0\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">← Review</text>\n<rect x=\"282\" y=\"56\" width=\"88\" height=\"22\" fill=\"#1E2333\" rx=\"11\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"294\" cy=\"67\" r=\"5\" fill=\"#10B981\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"302\" y=\"72\" font-size=\"10\" fill=\"#10B981\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">AI Score: 94</text>\n<rect x=\"20\" y=\"108\" width=\"350\" height=\"86\" fill=\"#1A1E2A\" rx=\"12\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"20\" y=\"108\" width=\"350\" height=\"3\" fill=\"#F59E0B\" rx=\"2\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"32\" y=\"130\" font-size=\"13\" fill=\"#E2E8F0\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Market Analysis Q2 2026</text>\n<text x=\"32\" y=\"148\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Assigned by Rakis · Alex-Research-01</text>\n<text x=\"32\" y=\"164\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Research competitor landscape and market sizing for Q2.</text>\n<text x=\"32\" y=\"180\" font-size=\"9\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Sources: 12 web searches · 4 docs analyzed · 1.8h runtime</text>\n<rect x=\"20\" y=\"204\" width=\"350\" height=\"52\" fill=\"#1E2333\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"34\" cy=\"230\" r=\"8\" fill=\"#06B6D4\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"34\" y=\"234\" font-size=\"8\" fill=\"#06B6D4\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">A</text>\n<text x=\"48\" y=\"216\" font-size=\"9\" fill=\"#06B6D4\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Alex-Research-01 note:</text>\n<text x=\"48\" y=\"230\" font-size=\"9\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">\"Found 3 major competitors not in prior list. EU market</text>\n<text x=\"48\" y=\"242\" font-size=\"9\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">sizing revised up 23%. High confidence all sources verified.\"</text>\n<rect x=\"20\" y=\"268\" width=\"350\" height=\"320\" fill=\"#1A1E2A\" rx=\"12\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"32\" y=\"288\" font-size=\"13\" fill=\"#E2E8F0\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Market Analysis Q2 2026</text>\n<text x=\"32\" y=\"304\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0.5\">Executive Summary</text>\n<line x1=\"32\" y1=\"312\" x2=\"358\" y2=\"312\" stroke=\"#252D40\" stroke-width=\"1\" opacity=\"1\"/>\n<text x=\"32\" y=\"320\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">The enterprise SaaS analytics market grew 34% YoY to reach</text>\n<text x=\"32\" y=\"334\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">$8.4B in Q1 2026. Three new entrants pose competitive risk:</text>\n<text x=\"32\" y=\"362\" font-size=\"8.5\" fill=\"#E2E8F0\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Competitors Identified:</text>\n<text x=\"32\" y=\"376\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">1. DataSphere — Series B, $180M ARR, EU-first approach</text>\n<text x=\"32\" y=\"390\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">2. MetricFlow — Open source, 12K GitHub stars, growing fast</text>\n<text x=\"32\" y=\"404\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">3. PulseIQ — AI-native, raised $40M, targeting SMB segment</text>\n<text x=\"32\" y=\"432\" font-size=\"8.5\" fill=\"#E2E8F0\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">EU Market Revision:</text>\n<text x=\"32\" y=\"446\" font-size=\"8.5\" fill=\"#06B6D4\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Previous estimate: €2.1B → Revised: €2.59B (+23%)</text>\n<text x=\"32\" y=\"460\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Primary driver: GDPR-compliant analytics demand surge.</text>\n<text x=\"32\" y=\"488\" font-size=\"8.5\" fill=\"#E2E8F0\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Recommendations:</text>\n<text x=\"32\" y=\"502\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">• Prioritize EU compliance certification for Q3 launch</text>\n<text x=\"32\" y=\"516\" font-size=\"8.5\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">• Monitor MetricFlow open source traction weekly</text>\n<rect x=\"0\" y=\"744\" width=\"390\" height=\"100\" fill=\"#12151D\" rx=\"0\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"0\" y=\"743\" width=\"390\" height=\"1\" fill=\"#252D40\" rx=\"0\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"20\" y=\"770\" font-size=\"12\" fill=\"#94A3B8\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Request revision</text>\n<text x=\"20\" y=\"786\" font-size=\"10\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Add a note before sending back...</text>\n<rect x=\"20\" y=\"804\" width=\"100\" height=\"28\" fill=\"#F43F5E\" rx=\"14\" ry=\"0\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"20\" y=\"804\" width=\"100\" height=\"28\" fill=\"none\" rx=\"14\" ry=\"0\" opacity=\"1\" stroke=\"#F43F5E\" stroke-width=\"1\"/>\n<text x=\"70\" y=\"821\" font-size=\"11\" fill=\"#F43F5E\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">✗ Reject</text>\n<rect x=\"130\" y=\"804\" width=\"80\" height=\"28\" fill=\"#F59E0B\" rx=\"14\" ry=\"0\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"130\" y=\"804\" width=\"80\" height=\"28\" fill=\"none\" rx=\"14\" ry=\"0\" opacity=\"1\" stroke=\"#F59E0B\" stroke-width=\"1\"/>\n<text x=\"170\" y=\"821\" font-size=\"11\" fill=\"#F59E0B\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Revise</text>\n<rect x=\"220\" y=\"804\" width=\"150\" height=\"28\" fill=\"#10B981\" rx=\"14\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"255\" y=\"821\" font-size=\"12\" fill=\"#0D0F14\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">✓ Approve</text>\n</svg>",
