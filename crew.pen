pacity=\"1\" letter-spacing=\"0.5\">Role</text>\n<rect x=\"20\" y=\"192\" width=\"112.66666666666667\" height=\"46\" fill=\"#06B6D4\" rx=\"10\" ry=\"0\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"20\" y=\"192\" width=\"112.66666666666667\" height=\"46\" fill=\"none\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"#06B6D4\" stroke-width=\"1.5\"/>\n<text x=\"76.33333333333334\" y=\"212\" font-size=\"14\" fill=\"#06B6D4\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">◎</text>\n<text x=\"76.33333333333334\" y=\"228\" font-size=\"9\" fill=\"#06B6D4\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Researcher</text>\n<rect x=\"138.66666666666669\" y=\"192\" width=\"112.66666666666667\" height=\"46\" fill=\"#1A1E2A\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"138.66666666666669\" y=\"192\" width=\"112.66666666666667\" height=\"46\" fill=\"none\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"#252D40\" stroke-width=\"1\"/>\n<text x=\"195.00000000000003\" y=\"212\" font-size=\"14\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">✏</text>\n<text x=\"195.00000000000003\" y=\"228\" font-size=\"9\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Writer</text>\n<rect x=\"257.33333333333337\" y=\"192\" width=\"112.66666666666667\" height=\"46\" fill=\"#1A1E2A\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"257.33333333333337\" y=\"192\" width=\"112.66666666666667\" height=\"46\" fill=\"none\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"#252D40\" stroke-width=\"1\"/>\n<text x=\"313.6666666666667\" y=\"212\" font-size=\"14\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">◈</text>\n<text x=\"313.6666666666667\" y=\"228\" font-size=\"9\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Analyst</text>\n<rect x=\"20\" y=\"246\" width=\"112.66666666666667\" height=\"46\" fill=\"#1A1E2A\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"20\" y=\"246\" width=\"112.66666666666667\" height=\"46\" fill=\"none\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"#252D40\" stroke-width=\"1\"/>\n<text x=\"76.33333333333334\" y=\"266\" font-size=\"14\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">⌥</text>\n<text x=\"76.33333333333334\" y=\"282\" font-size=\"9\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Developer</text>\n<rect x=\"138.66666666666669\" y=\"246\" width=\"112.66666666666667\" height=\"46\" fill=\"#1A1E2A\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"138.66666666666669\" y=\"246\" width=\"112.66666666666667\" height=\"46\" fill=\"none\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"#252D40\" stroke-width=\"1\"/>\n<text x=\"195.00000000000003\" y=\"266\" font-size=\"14\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">✉</text>\n<text x=\"195.00000000000003\" y=\"282\" font-size=\"9\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Email</text>\n<rect x=\"257.33333333333337\" y=\"246\" width=\"112.66666666666667\" height=\"46\" fill=\"#1A1E2A\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"257.33333333333337\" y=\"246\" width=\"112.66666666666667\" height=\"46\" fill=\"none\" rx=\"10\" ry=\"0\" opacity=\"1\" stroke=\"#252D40\" stroke-width=\"1\"/>\n<text x=\"313.6666666666667\" y=\"266\" font-size=\"14\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">+</text>\n<text x=\"313.6666666666667\" y=\"282\" font-size=\"9\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Custom</text>\n<text x=\"20\" y=\"308\" font-size=\"11\" fill=\"#94A3B8\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0.5\">Base Model</text>\n<rect x=\"20\" y=\"316\" width=\"350\" height=\"36\" fill=\"#1E2333\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"20\" y=\"316\" width=\"350\" height=\"36\" fill=\"none\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"#06B6D4\" stroke-width=\"1.5\"/>\n<circle cx=\"36\" cy=\"334\" r=\"7\" fill=\"#06B6D4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"36\" cy=\"334\" r=\"3\" fill=\"#0D0F14\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"50\" y=\"330\" font-size=\"11\" fill=\"#E2E8F0\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">claude-3.5-sonnet</text>\n<text x=\"50\" y=\"344\" font-size=\"9\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Best quality</text>\n<rect x=\"314\" y=\"326\" width=\"50\" height=\"16\" fill=\"#06B6D4\" rx=\"4\" ry=\"0\" opacity=\"0.12\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"339\" y=\"337\" font-size=\"7\" fill=\"#06B6D4\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">Recommended</text>\n<rect x=\"20\" y=\"360\" width=\"350\" height=\"36\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"36\" cy=\"378\" r=\"5\" fill=\"#475569\" opacity=\"0.5\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"50\" y=\"374\" font-size=\"11\" fill=\"#E2E8F0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">gpt-4o</text>\n<text x=\"50\" y=\"388\" font-size=\"9\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Balanced</text>\n<rect x=\"20\" y=\"404\" width=\"350\" height=\"36\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"36\" cy=\"422\" r=\"5\" fill=\"#475569\" opacity=\"0.5\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"50\" y=\"418\" font-size=\"11\" fill=\"#E2E8F0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">claude-3-haiku</text>\n<text x=\"50\" y=\"432\" font-size=\"9\" fill=\"#475569\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Fast &amp; cheap</text>\n<text x=\"20\" y=\"454\" font-size=\"11\" fill=\"#94A3B8\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0.5\">Permissions</text>\n<rect x=\"20\" y=\"462\" width=\"169\" height=\"30\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"32\" y=\"481\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Web Search</text>\n<rect x=\"151\" y=\"471\" width=\"28\" height=\"14\" fill=\"#06B6D4\" rx=\"7\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"167\" cy=\"478\" r=\"6\" fill=\"#0D0F14\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"201\" y=\"462\" width=\"169\" height=\"30\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"213\" y=\"481\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Send Email</text>\n<rect x=\"332\" y=\"471\" width=\"28\" height=\"14\" fill=\"#2E3850\" rx=\"7\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"336\" cy=\"478\" r=\"6\" fill=\"#475569\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"20\" y=\"500\" width=\"169\" height=\"30\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"32\" y=\"519\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Read Files</text>\n<rect x=\"151\" y=\"509\" width=\"28\" height=\"14\" fill=\"#06B6D4\" rx=\"7\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"167\" cy=\"516\" r=\"6\" fill=\"#0D0F14\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"201\" y=\"500\" width=\"169\" height=\"30\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"213\" y=\"519\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Execute Code</text>\n<rect x=\"332\" y=\"509\" width=\"28\" height=\"14\" fill=\"#2E3850\" rx=\"7\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"336\" cy=\"516\" r=\"6\" fill=\"#475569\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"20\" y=\"538\" width=\"169\" height=\"30\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"32\" y=\"557\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Publish</text>\n<rect x=\"151\" y=\"547\" width=\"28\" height=\"14\" fill=\"#2E3850\" rx=\"7\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"155\" cy=\"554\" r=\"6\" fill=\"#475569\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"201\" y=\"538\" width=\"169\" height=\"30\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"213\" y=\"557\" font-size=\"10\" fill=\"#94A3B8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0\">Call APIs</text>\n<rect x=\"332\" y=\"547\" width=\"28\" height=\"14\" fill=\"#06B6D4\" rx=\"7\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"348\" cy=\"554\" r=\"6\" fill=\"#0D0F14\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"20\" y=\"584\" font-size=\"11\" fill=\"#94A3B8\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" opacity=\"1\" letter-spacing=\"0.5\">Max Concurrent Tasks</text>\n<rect x=\"20\" y=\"592\" width=\"350\" height=\"32\" fill=\"#1A1E2A\" rx=\"8\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"32\" y=\"604\" width=\"310\" height=\"8\" fill=\"#252D40\" rx=\"4\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<rect x=\"32\" y=\"604\" width=\"124\" height=\"8\" fill=\"#06B6D4\" rx=\"4\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"156\" cy=\"608\" r=\"10\" fill=\"#0D0F14\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<circle cx=\"156\" cy=\"608\" r=\"10\" fill=\"none\" opacity=\"1\" stroke=\"#06B6D4\" stroke-width=\"2\"/>\n<circle cx=\"156\" cy=\"608\" r=\"4\" fill=\"#06B6D4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"360\" y=\"609\" font-size=\"10\" fill=\"#06B6D4\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"end\" opacity=\"1\" letter-spacing=\"0\">3</text>\n<rect x=\"20\" y=\"752\" width=\"350\" height=\"44\" fill=\"#06B6D4\" rx=\"22\" ry=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n<text x=\"195\" y=\"780\" font-size=\"16\" fill=\"#0D0F14\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spacing=\"0\">⚡  Deploy Agent</text>\n<text x=\"195\" y=\"796\" font-size=\"9\" fill=\"#1E2333\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" opacity=\"1\" letter-spaci