y=\"246\" font-size=\"9\" font-family=\"Inter\" font-weight=\"600\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"1.5\" opacity=\"1\">AI INSIGHTS</text>\n  <rect x=\"20\" y=\"260\" width=\"350\" height=\"74\" rx=\"12\" ry=\"12\" fill=\"#FFFFFF\"></rect>\n  <rect x=\"20\" y=\"260\" width=\"6\" height=\"74\" rx=\"3\" ry=\"3\" fill=\"#2D6A4F\"></rect>\n  <rect x=\"34\" y=\"272\" width=\"42\" height=\"42\" rx=\"8\" ry=\"8\" fill=\"#E8F5E9\"></rect>\n  <text x=\"55\" y=\"300\" font-size=\"22\" font-family=\"Inter\" font-weight=\"400\" fill=\"#1A1C18\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">🏆</text>\n  <text x=\"86\" y=\"288\" font-size=\"13\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Best protein week yet</text>\n  <text x=\"86\" y=\"306\" font-size=\"10\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Averaged 142g/day — 18% above your goal</text>\n  <text x=\"86\" y=\"318\" font-size=\"10\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Averaged 142g/day — 18% above your goal</text>\n  <rect x=\"20\" y=\"342\" width=\"350\" height=\"74\" rx=\"12\" ry=\"12\" fill=\"#FFFFFF\"></rect>\n  <rect x=\"20\" y=\"342\" width=\"6\" height=\"74\" rx=\"3\" ry=\"3\" fill=\"#B07D20\"></rect>\n  <rect x=\"34\" y=\"354\" width=\"42\" height=\"42\" rx=\"8\" ry=\"8\" fill=\"#FFF3DB\"></rect>\n  <text x=\"55\" y=\"382\" font-size=\"22\" font-family=\"Inter\" font-weight=\"400\" fill=\"#1A1C18\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">⚡</text>\n  <text x=\"86\" y=\"370\" font-size=\"13\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Pre-ride fueling optimized</text>\n  <text x=\"86\" y=\"388\" font-size=\"10\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Carb loading 90m before rides improved your HR response</text>\n  <text x=\"86\" y=\"400\" font-size=\"10\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Carb loading 90m before rides improved your …</text>\n  <rect x=\"20\" y=\"424\" width=\"350\" height=\"74\" rx=\"12\" ry=\"12\" fill=\"#FFFFFF\"></rect>\n  <rect x=\"20\" y=\"424\" width=\"6\" height=\"74\" rx=\"3\" ry=\"3\" fill=\"#2E7DBB\"></rect>\n  <rect x=\"34\" y=\"436\" width=\"42\" height=\"42\" rx=\"8\" ry=\"8\" fill=\"#EBF4FB\"></rect>\n  <text x=\"55\" y=\"464\" font-size=\"22\" font-family=\"Inter\" font-weight=\"400\" fill=\"#1A1C18\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">💧</text>\n  <text x=\"86\" y=\"452\" font-size=\"13\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Hydration needs work</text>\n  <text x=\"86\" y=\"470\" font-size=\"10\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Hit 3L target only 4 of 7 days — focus on morning hydration</text>\n  <text x=\"86\" y=\"482\" font-size=\"10\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Hit 3L target only 4 of 7 days — focus on mo…</text>\n  <rect x=\"20\" y=\"512\" width=\"350\" height=\"56\" rx=\"12\" ry=\"12\" fill=\"#2D6A4F\"></rect>\n  <text x=\"32\" y=\"534\" font-size=\"14\" font-family=\"Inter\" font-weight=\"700\" fill=\"#FFFFFF\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Next Week -  Taper Phase</text>\n  <text x=\"32\" y=\"554\" font-size=\"11\" font-family=\"Inter\" font-weight=\"400\" fill=\"rgba(255,255,255,0.75)\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Lower volume → higher carb ratio. Plan ready.</text>\n  <text x=\"360\" y=\"544\" font-size=\"12\" font-family=\"Inter\" font-weight=\"600\" fill=\"#FFFFFF\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">View Plan →</text>\n  <text x=\"20\" y=\"588\" font-size=\"9\" font-family=\"Inter\" font-weight=\"600\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"1.5\" opacity=\"1\">WEEKLY TOTALS</text>\n  <rect x=\"20\" y=\"600\" width=\"167\" height=\"52\" rx=\"10\" ry=\"10\" fill=\"#FFFFFF\"></rect>\n  <text x=\"30\" y=\"618\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Avg Calories</text>\n  <text x=\"30\" y=\"640\" font-size=\"18\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">2,284</text>\n  <text x=\"80\" y=\"640\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">kcal/day</text>\n  <rect x=\"203\" y=\"600\" width=\"167\" height=\"52\" rx=\"10\" ry=\"10\" fill=\"#FFFFFF\"></rect>\n  <text x=\"213\" y=\"618\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Total Protein</text>\n  <text x=\"213\" y=\"640\" font-size=\"18\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">994g</text>\n  <text x=\"253\" y=\"640\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">7-day total</text>\n  <rect x=\"20\" y=\"660\" width=\"167\" height=\"52\" rx=\"10\" ry=\"10\" fill=\"#FFFFFF\"></rect>\n  <text x=\"30\" y=\"678\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Ride Fueling</text>\n  <text x=\"30\" y=\"700\" font-size=\"18\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">6/7</text>\n  <text x=\"60\" y=\"700\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">rides logged</text>\n  <rect x=\"203\" y=\"660\" width=\"167\" height=\"52\" rx=\"10\" ry=\"10\" fill=\"#FFFFFF\"></rect>\n  <text x=\"213\" y=\"678\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Avg Water</text>\n  <text x=\"213\" y=\"700\" font-size=\"18\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">2.7L</text>\n  <text x=\"253\" y=\"700\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">per day</text>\n  <rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" rx=\"0\" ry=\"0\" fill=\"#FFFFFF\" opacity=\"1\"></rect>\n  <line x1=\"0\" y1=\"764\" x2=\"390\" y2=\"764\" stroke=\"#E2DED8\" stroke-width=\"1\" opacity=\"1\"></line>\n  <path d=\"M31,790 L39,780 L47,790 L47,794 L31,794 Z\" fill=\"#9A9B93\"></path>\n  <text x=\"39\" y=\"814\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Today</text>\n  <rect x=\"109\" y=\"788\" width=\"5\" height=\"6\" fill=\"#9A9B93\"></rect>\n  <rect x=\"115\" y=\"784\" width=\"5\" height=\"10\" fill=\"#9A9B93\"></rect>\n  <rect x=\"121\" y=\"780\" width=\"5\" height=\"14\" fill=\"#9A9B93\"></rect>\n  <text x=\"117\" y=\"814\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Macros</text>\n  <circle cx=\"193\" cy=\"786\" r=\"5\" fill=\"none\" stroke=\"#9A9B93\" stroke-width=\"2\"></circle>\n  <line x1=\"197\" y1=\"790\" x2=\"202\" y2=\"794\" stroke=\"#9A9B93\" stroke-width=\"2\"></line>\n  <text x=\"195\" y=\"814\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Recipes</text>\n  <polyline points=\"265,786 269,781 273,791 277,783 281,786\" fill=\"none\" stroke=\"#9A9B93\" stroke-width=\"2\"></polyline>\n  <text x=\"273\" y=\"814\" font-size=\"9\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Training</text>\n  <rect x=\"333\" y=\"774\" width=\"36\" height=\"24\" rx=\"12\" ry=\"12\" fill=\"#E8F5E9\"></rect>\n  <circle cx=\"351\" cy=\"784\" r=\"4\" fill=\"#2D6A4F\"></circle>\n  <path d=\"M344,794 C344,789 358,789 358,794\" fill=\"#2D6A4F\"></path>\n  <text x=\"351\" y=\"814\" font-size=\"9\" font-family=\"Inter\" font-weight=\"600\" fill=\"#2D6A4F\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Profile</text>\n</svg>"
