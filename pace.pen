      "label": "Weekly Review",
      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n  <defs><style>text{font-family:'Inter',system-ui,sans-serif;}</style></defs>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#F7F4EF\"></rect>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#F7F4EF\"></rect>\n  <text x=\"20\" y=\"28\" font-size=\"13\" font-family=\"Inter\" font-weight=\"600\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">9:41</text>\n  <text x=\"318\" y=\"28\" font-size=\"10\" font-family=\"Inter\" font-weight=\"600\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">●●●</text>\n  <text x=\"344\" y=\"28\" font-size=\"10\" font-family=\"Inter\" font-weight=\"400\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">WiFi</text>\n  <text x=\"370\" y=\"28\" font-size=\"11\" font-family=\"Inter\" font-weight=\"400\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">⬜</text>\n  <text x=\"20\" y=\"84\" font-size=\"24\" font-family=\"Inter\" font-weight=\"700\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Weekly Review</text>\n  <text x=\"20\" y=\"106\" font-size=\"13\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Mar 24 – Mar 30, 2026</text>\n  <rect x=\"20\" y=\"120\" width=\"350\" height=\"100\" rx=\"16\" ry=\"16\" fill=\"#F0E8D6\"></rect>\n  <text x=\"32\" y=\"144\" font-size=\"9\" font-family=\"Inter\" font-weight=\"600\" fill=\"#8A7040\" text-anchor=\"start\" letter-spacing=\"1.5\" opacity=\"1\">PERFORMANCE SCORE</text>\n  <text x=\"32\" y=\"196\" font-size=\"52\" font-family=\"Inter\" font-weight=\"800\" fill=\"#1A1C18\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">87</text>\n  <text x=\"94\" y=\"196\" font-size=\"20\" font-family=\"Inter\" font-weight=\"400\" fill=\"#9A9B93\" text-anchor=\"start\" letter-spa