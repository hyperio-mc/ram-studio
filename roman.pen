      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 390 844\" width=\"390\" height=\"844\">\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"0\" fill=\"#FAF7F2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" rx=\"0\" fill=\"#FAF7F2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"28\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:13px;font-weight:600;font-family:-apple-system, sans-serif\">9:41</text>\n  <rect x=\"334\" y=\"17\" width=\"25\" height=\"11\" rx=\"2\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <rect x=\"335\" y=\"18\" width=\"18\" height=\"9\" rx=\"1\" fill=\"#1C1814\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"360\" y=\"20\" width=\"3\" height=\"5\" rx=\"1\" fill=\"#4A4238\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"290\" cy=\"22\" r=\"4\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <circle cx=\"304\" cy=\"22\" r=\"4\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <circle cx=\"318\" cy=\"22\" r=\"4\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <rect x=\"0\" y=\"44\" width=\"390\" height=\"64\" rx=\"0\" fill=\"#FAF7F2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"82\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:26px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">Discover</text>\n  <text x=\"370\" y=\"82\" text-anchor=\"end\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">Apr 2026</text>\n  <line x1=\"20\" y1=\"110\" x2=\"370\" y2=\"110\" stroke=\"#E8E1D6\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <rect x=\"20\" y=\"120\" width=\"350\" height=\"180\" rx=\"8\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"20\" y=\"120\" width=\"350\" height=\"4\" rx=\"0\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"144\" text-anchor=\"start\" fill=\"#4A3728\" opacity=\"1\" style=\"font-size:9px;font-weight:700;font-family:-apple-system, sans-serif;letter-spacing:1.5px\">EDITOR'S PICK</text>\n  <text x=\"36\" y=\"172\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:22px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">The Dispossessed</text>\n  <text x=\"36\" y=\"192\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">Ursula K. Le Guin</text>\n  <text x=\"36\" y=\"212\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"54\" y=\"212\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"72\" y=\"212\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"90\" y=\"212\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"108\" y=\"212\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"126\" y=\"212\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">4.8 · 12.4k reads</text>\n  <text x=\"36\" y=\"244\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:Georgia, serif\">\"True journey is return.\" A masterwork of</text>\n  <text x=\"36\" y=\"260\" text-anchor=\"start\" fill=\"