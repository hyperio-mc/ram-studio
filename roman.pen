1\" stroke=\"#E8E1D6\" stroke-width=\"0.5\"/>\n  <rect x=\"40\" y=\"576\" width=\"3\" height=\"60\" rx=\"0\" fill=\"#C49A3C\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"52\" y=\"598\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:Georgia, serif\">\"The evening's ceremony had come and gone…\"</text>\n  <text x=\"52\" y=\"616\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">p. 180</text>\n  <rect x=\"40\" y=\"648\" width=\"310\" height=\"60\" rx=\"6\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"#E8E1D6\" stroke-width=\"0.5\"/>\n  <rect x=\"40\" y=\"648\" width=\"3\" height=\"60\" rx=\"0\" fill=\"#C49A3C\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"52\" y=\"670\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:Georgia, serif\">\"There is, after all, a dignity in that.\"</text>\n  <text x=\"52\" y=\"688\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">p. 184</text>\n  <rect x=\"0\" y=\"762\" width=\"390\" height=\"82\" rx=\"0\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"#E8E1D6\" stroke-width=\"0.5\"/>\n  <text x=\"49\" y=\"788\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:Georgia, serif\">❧</text>\n  <text x=\"49\" y=\"806\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif;letter-spacing:0.3px\">Library</text>\n  <text x=\"130\" y=\"788\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:Georgia, serif\">◈</text>\n  <text x=\"130\" y=\"806\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sa