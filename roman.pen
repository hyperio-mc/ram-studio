oke-width=\"0\"/>\n  <rect x=\"123\" y=\"108\" width=\"8\" height=\"192\" rx=\"0\" fill=\"rgba(255,255,255,0.08)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"195\" cy=\"204\" r=\"20\" fill=\"none\" opacity=\"1\" stroke=\"rgba(200,184,154,0.25)\" stroke-width=\"1\"/>\n  <circle cx=\"195\" cy=\"204\" r=\"36\" fill=\"none\" opacity=\"1\" stroke=\"rgba(200,184,154,0.25)\" stroke-width=\"1\"/>\n  <circle cx=\"195\" cy=\"204\" r=\"52\" fill=\"none\" opacity=\"1\" stroke=\"rgba(200,184,154,0.25)\" stroke-width=\"1\"/>\n  <circle cx=\"195\" cy=\"204\" r=\"68\" fill=\"none\" opacity=\"1\" stroke=\"rgba(200,184,154,0.25)\" stroke-width=\"1\"/>\n  <circle cx=\"195\" cy=\"204\" r=\"84\" fill=\"none\" opacity=\"1\" stroke=\"rgba(200,184,154,0.25)\" stroke-width=\"1\"/>\n  <text x=\"195\" y=\"188\" text-anchor=\"middle\" fill=\"#C8B89A\" opacity=\"1\" style=\"font-size:14px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.5px\">The Remains</text>\n  <text x=\"195\" y=\"208\" text-anchor=\"middle\" fill=\"#C8B89A\" opacity=\"1\" style=\"font-size:14px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.5px\">of the Day</text>\n  <text x=\"195\" y=\"236\" text-anchor=\"middle\" fill=\"rgba(200,184,154,0.6)\" opacity=\"1\" style=\"font-size:9px;font-weight:400;font-family:-apple-system, sans-serif;letter-spacing:2px\">KAZUO ISHIGURO</text>\n  <rect x=\"247\" y=\"118\" width=\"68\" height=\"26\" rx=\"13\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"281\" y=\"134\" text-anchor=\"middle\" fill=\"#fff\" opacity=\"1\" style=\"font-size:11px;font-weight:600;font-family:-apple-system, sans-serif\">Reading</text>\n  <rect x=\"0\" y=\"314\" width=\"390\" height=\"448\" rx=\"0\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"344\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:20px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">The Remains of the Day</text>\n  <text x=\"20\" y=\"366\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:12px;font-weight:400;font-family:-apple-system, sans-serif\">Kazuo Ishiguro  ·  1989  ·  258 pages</text>\n  <text x=\"20\" y=\"392\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"42\" y=\"392\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"64\" y=\"392\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"86\" y=\"392\" text-anchor=\"start\" fill=\"#C49A3C\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"108\" y=\"392\" text-anchor=\"start\" fill=\"#DDD5C8\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:-apple-system, sans-serif\">★</text>\n  <text x=\"130\" y=\"392\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:12px;font-weight:400;font-family:-apple-system, sans-serif\">4.2  ·  Booker Prize 1989</text>\n  <rect x=\"20\" y=\"406\" width=\"132\" height=\"22\" rx=\"11\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"#DDD5C8\" stroke-width=\"0.5\"/>\n  <text x=\"86\" y=\"420\" text-anchor=\"middle\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">Literary Fiction</text>\n  <rect x=\"160\" y=\"406\" width=\"69\" height=\"22\" rx=\"11\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"#DDD5C8\" stroke-width=\"0.5\"/>\n  <text x=\"194.5\" y=\"420\" text-anchor=\"middle\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">British</text>\n  <rect x=\"237\" y=\"406\" width=\"90\" height=\"22\" rx=\"11\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"#DDD5C8\" stroke-width=\"0.5\"/>\n  <text x=\"282\" y=\"420\" text-anchor=\"middle\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">Historical</text>\n  <rect x=\"335\" y=\"406\" width=\"62\" height=\"22\" rx=\"11\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"#DDD5C8\" stroke-width=\"0.5\"/>\n  <text x=\"366\" y=\"420\" text-anchor=\"middle\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">Booker</text>\n  <line x1=\"20\" y1=\"442\" x2=\"370\" y2=\"442\" stroke=\"#E8E1D6\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"20\" y=\"460\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:12px;font-weight:400;font-family:Georgia, serif\">An aging butler, Stevens, recalls his career</text>\n  <text x=\"20\" y=\"478\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:12px;font-weight:400;font-family:Georgia, serif\">serving a distinguished English household,</text>\n  <text x=\"20\" y=\"496\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:12px;font-weight:400;font-family:Georgia, serif\">questioning duty, dignity, and missed love.</text>\n  <line x1=\"20\" y1=\"518\" x2=\"370\" y2=\"518\" stroke=\"#E8E1D6\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"20\" y=\"534\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.8px\">Your Progress</text>\n  <text x=\"370\" y=\"534\" text-anchor=\"end\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">Page 187 / 258</text>\n  <rect x=\"20\" y=\"544\" width=\"350\" height=\"8\" rx=\"4\" fill=\"#EEE8DC\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"20\" y=\"544\" width=\"252\" height=\"8\" rx=\"4\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"564\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">Started Mar 28  ·  72% complete  ·  ~2 hrs left</text>\n  <rect x=\"20\" y=\"578\" width=\"350\" height=\"52\" rx=\"8\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"604\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:13px;font-weight:500;font-family:Georgia, \"Times New Roman\", serif\">7 highlights  ·  2 notes</text>\n  <text x=\"36\" y=\"620\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">Tap to view your annotations →</text>\n  <rect x=\"20\" y=\"644\" width=\"171\" height=\"44\" rx=\"22\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"105.5\" y=\"670\" text-anchor=\"middle\" fill=\"#fff\" opacity=\"1\" style=\"font-size:13px;font-weight:600;font-family:-apple-system, sans-serif\">Continue Reading</text>\n  <rect x=\"199\" y=\"644\" width=\"171\" height=\"44\" rx=\"22\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"#DDD5C8\" stroke-width=\"1\"/>\n  <text x=\"284.5\" y=\"670\" text-anchor=\"middle\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:-apple-system, sans-serif\">Mark Finished</text>\n  <rect x=\"0\" y=\"762\" width=\"390\" height=\"82\" rx=\"0\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"#E8E1D6\" stroke-width=\"0.5\"/>\n  <text x=\"49\" y=\"788\" text-anchor=\"middle\" fill=\"#4A3728\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:Georgia, serif\">❧</text>\n  <text x=\"49\" y=\"806\" text-anchor=\"middle\" fill=\"#4A3728\" opacity=\"1\" style=\"font-size:10px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.3px\">Library</text>\n  <rect x=\"31\" y=\"766\" width=\"36\" height=\"2\" rx=\"1\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"130\" y=\"788\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:Georgia, serif\">◈</text>\n  <text x=\"130\" y=\"806\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif;letter-spacing:0.3px\">Discover</text>\n  <text x=\"211\" y=\"788\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:Georgia, serif\">⊙</text>\n  <text x=\"211\" y=\"806\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif;letter-spacing:0.3px\">Reading</text>\n  <text x=\"292\" y=\"788\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:16px;font-weight:400;font-family:Georgia, serif\">◎</text>\n  <text x=\"292\" y=\"806\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif;letter-spacing:0.3px\">Stats</text>\n</svg>",
