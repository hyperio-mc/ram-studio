      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 390 844\" width=\"390\" height=\"844\">\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"0\" fill=\"#FAF7F2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" rx=\"0\" fill=\"#FAF7F2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"28\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:13px;font-weight:600;font-family:-apple-system, sans-serif\">9:41</text>\n  <rect x=\"334\" y=\"17\" width=\"25\" height=\"11\" rx=\"2\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <rect x=\"335\" y=\"18\" width=\"18\" height=\"9\" rx=\"1\" fill=\"#1C1814\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"360\" y=\"20\" width=\"3\" height=\"5\" rx=\"1\" fill=\"#4A4238\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"290\" cy=\"22\" r=\"4\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <circle cx=\"304\" cy=\"22\" r=\"4\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <circle cx=\"318\" cy=\"22\" r=\"4\" fill=\"none\" opacity=\"1\" stroke=\"#4A4238\" stroke-width=\"1.5\"/>\n  <rect x=\"0\" y=\"44\" width=\"390\" height=\"64\" rx=\"0\" fill=\"#FAF7F2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"82\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:22px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">My Reading Life</text>\n  <text x=\"370\" y=\"72\" text-anchor=\"end\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:20px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">⚙</text>\n  <line x1=\"20\" y1=\"112\" x2=\"370\" y2=\"112\" stroke=\"#E8E1D6\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <circle cx=\"195\" cy=\"162\" r=\"38\" fill=\"#EEE8DC\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"195\" y=\"170\" text-anchor=\"middle\" fill=\"#4A3728\" opacity=\"1\" style=\"font-size:22px;font-weight:600;font-family:-apple-system, sans-serif\">EM</text>\n  <text x=\"195\" y=\"218\" text-anchor=\"middle\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:18px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">Eleanor M.</text>\n  <text x=\"195\" y=\"238\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:13px;font-weight:400;font-family:Georgia, serif\">\"Reading slowly, thoughtfully.\"</text>\n  <text x=\"115\" y=\"270\" text-anchor=\"middle\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:22px;font-weight:600;font-family:Georgia, \"Times New Roman\", serif\">18</text>\n  <text x=\"115\" y=\"288\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">Read</text>\n  <line x1=\"155\" y1=\"260\" x2=\"155\" y2=\"290\" stroke=\"#DDD5C8\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"195\" y=\"270\" text-anchor=\"middle\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:22px;font-weight:600;font-family:Georgia, \"Times New Roman\", serif\">12</text>\n  <text x=\"195\" y=\"288\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">To Read</text>\n  <line x1=\"235\" y1=\"260\" x2=\"235\" y2=\"290\" stroke=\"#DDD5C8\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"275\" y=\"270\" text-anchor=\"middle\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:22px;font-weight:600;font-family:Georgia, \"Times New Roman\", serif\">7</text>\n  <text x=\"275\" y=\"288\" text-anchor=\"middle\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">Favourites</text>\n  <line x1=\"20\" y1=\"306\" x2=\"370\" y2=\"306\" stroke=\"#E8E1D6\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <rect x=\"20\" y=\"316\" width=\"350\" height=\"84\" rx=\"10\" fill=\"#F5F0E8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"20\" y=\"316\" width=\"4\" height=\"84\" rx=\"0\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"340\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.8px\">Reading Identity</text>\n  <text x=\"36\" y=\"362\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:16px;font-weight:500;font-family:Georgia, \"Times New Roman\", serif\">The Contemplative Reader</text>\n  <text x=\"36\" y=\"380\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:12px;font-weight:400;font-family:Georgia, serif\">You read deeply, slowly, and with care.</text>\n  <text x=\"36\" y=\"396\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">Avg. 12 days per book · Prefers literary fiction.</text>\n  <line x1=\"20\" y1=\"414\" x2=\"370\" y2=\"414\" stroke=\"#E8E1D6\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"20\" y=\"430\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.8px\">April 2026</text>\n  <text x=\"370\" y=\"430\" text-anchor=\"end\" fill=\"#4A3728\" opacity=\"1\" style=\"font-size:11px;font-weight:500;font-family:-apple-system, sans-serif\">23-day streak 🔥</text>\n  <rect x=\"20\" y=\"442\" width=\"38\" height=\"26\" rx=\"4\" fill=\"rgba(74,55,40,0.44)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"39\" y=\"458\" text-anchor=\"middle\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:9px;font-weight:400;font-family:-apple-system, sans-serif\">1</text>\n  <rect x=\"68\" y=\"442\" width=\"38\" height=\"26\" rx=\"4\" fill=\"rgba(74,55,40,0.6799999999999999)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"8