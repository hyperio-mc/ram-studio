\"font-size:11px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.8px\">Currently Reading</text>\n  <text x=\"370\" y=\"133\" text-anchor=\"end\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">3 books</text>\n  <rect x=\"20\" y=\"144\" width=\"350\" height=\"120\" rx=\"8\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"#E8E1D6\" stroke-width=\"0.5\"/>\n  <rect x=\"20\" y=\"144\" width=\"6\" height=\"120\" rx=\"0\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"24\" y=\"144\" width=\"2\" height=\"120\" rx=\"0\" fill=\"#6B8F5E\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"36\" y=\"154\" width=\"64\" height=\"100\" rx=\"4\" fill=\"#EEE8DC\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <line x1=\"43\" y1=\"168\" x2=\"93\" y2=\"168\" stroke=\"#DDD5C8\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <line x1=\"43\" y1=\"184\" x2=\"93\" y2=\"184\" stroke=\"#DDD5C8\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <line x1=\"43\" y1=\"200\" x2=\"93\" y2=\"200\" stroke=\"#DDD5C8\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <line x1=\"43\" y1=\"216\" x2=\"93\" y2=\"216\" stroke=\"#DDD5C8\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <line x1=\"43\" y1=\"232\" x2=\"93\" y2=\"232\" stroke=\"#DDD5C8\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"68\" y=\"207\" text-anchor=\"middle\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:18px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">📖</text>\n  <text x=\"116\" y=\"168\" text-anchor=\"start\" fill=\"#1C1814\" opacity=\"1\" style=\"font-size:13px;font-weight:600;font-family:Georgia, \"Times New Roman\", serif\">The Remains of the Day</text>\n  <text x=\"116\" y=\"184\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">Kazuo Ishiguro</text>\n  <text x=\"116\" y=\"210\" text-anchor=\"start\" fill=\"#4A4238\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">Page 187 of 258</text>\n  <rect x=\"116\" y=\"220\" width=\"218\" height=\"4\" rx=\"2\" fill=\"#EEE8DC\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"116\" y=\"220\" width=\"157\" height=\"4\" rx=\"2\" fill=\"#4A3728\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"116\" y=\"242\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:10px;font-weight:400;font-family:-apple-system, sans-serif\">72% complete</text>\n  <text x=\"354\" y=\"242\" text-anchor=\"end\" fill=\"#4A3728\" opacity=\"1\" style=\"font-size:14px;font-weight:400;font-family:Georgia, \"Times New Roman\", serif\">→</text>\n  <line x1=\"20\" y1=\"278\" x2=\"370\" y2=\"278\" stroke=\"#E8E1D6\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"20\" y=\"294\" text-anchor=\"start\" fill=\"#9C9086\" opacity=\"1\" style=\"font-size:11px;font-weight:600;font-family:-apple-system, sans-serif;letter-spacing:0.8px\">Your Shelf</text>\n  <text x=\"370\" y=\"294\" text-anchor=\"end\" fill=\"#4A3728\" opacity=\"1\" style=\"font-size:11px;font-weight:400;font-family:-apple-system, sans-serif\">View all</text>\n  <rect x=\"20\" y=\"304\" width=\"100\" height=\"140\" rx=\"4\" fill=\"#8B6F5E\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"20\" y=\"304\" width=\"5\" height=\"140\" rx=\"0\" fill=\"rgba(0,0,0,0.2)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"70\" y=\"366\" text-anchor=\"middle\" fill=\"#FFFFFF\" opacity=\"1\" style=\"font-size:10px;font-weight:600;font-family:-apple-system, sans-serif\">Middlemarch</text>\n  <text x=\"70\" y=\"382\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.75)\" opacity=\"1\" style=\"font-size:9px;font-weight:400;font-family:-apple-system, sans-serif\">G. Eliot</text>\n  <circle cx=\"108\" cy=\"316\" r=\"10\" fill=\"#6B8F5E\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"108\" y=\"321\" text-anchor=\"middle\" fill=\"#fff\" opacity=\"1\" style=\"font-size:10px;font-weight:700;font-family:-apple-system, sans-serif\">✓</text>\n  <rect x=\"135\" y=\"304\" width=\"100\" height=\"140\" rx=\"4\" fill=\"#5E7B6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"135\" y=\"304\" width=\"5\" height=\"140\" rx=\"0\" fill=\"rgba(0,0,0,0.2)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"185\" y=\"366\" text-anchor=\"middle\" fill=\"#FFFFFF\" opacity=\"1\" style=\"font-size:10px;font-weight:600;font-family:-apple-system, sans-serif\">Beloved</text>\n  <text x=\"185\" y=\"382\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.75)\" opacity=\"1\" style=\"font-size:9px;font-weight:400;font-family:-apple-system, sans-serif\">T. Morrison</text>\n  <circle cx=\"223\" cy=\"316\" r=\"10\" fill=\"#6B8F5E\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"223\" y=\"321\" text-anchor=\"middle\" fill=\"#fff\" opacity=\"1\" style=\"font-size:10px;font-weight:700;font-family:-apple-system, sans-serif\">✓</text>\n  <rect x=\"250\" y=\"304\" width=\"100\" height=\"140\" rx=\"4\" fill=\"#6B5E8B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"250\" y=\"304\" width=\"5\" height=\"140\" rx=\"0\" fill=\"rgba(0,0,0,0.2)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"300\" y=\"366\" text-anchor=\"middle\" fill=\"#FFFFFF\" opacity=\"1\" style=\"font-size:10px;font-weight:600;font-family:-apple-system, sans-serif\">On Earth…</text>\n  <text x=\"300\" y=\"382\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.75)\" opacity=\"1\" style=\"font-size:9px;font-weight:400;font-family:-apple-system, sans-serif\">J. Eugenides</text>\n  <circle cx=\"338\" cy=\"316\" r=\"10\" fill=\"#C49A3C\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"338\" y=\"321\" text-anchor=\"middle\" fill=\"#fff\" opacity=\"1\" style=\"font-size:10px;font-weight:700;font-family:-apple-system, sans-serif\">½</text>\n  <rect x=\"20\" y=\"484\" width=\"100\" height=\"140\" rx=\"4\" fill=\"#7B6B4A\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"20\" y=\"484\" width=\"5\" height=\"140\" rx=\"0\" fill=\"rgba(0,0,0,0.2)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"70\" y=\"546\" text-anchor=\"middle\" fill=\"#FFFFFF\" opacity=\"1\" style=\"font-size:10px;font-weight:600;font-family:-apple-system, sans-serif\">Never Let Me</text>\n  <text x=\"70\" y=\"562\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.75)\" opacity=\"1\" style=\"font-size:9px;font-weight:400;font-family:-apple-system, sans-serif\">K. Ishiguro</text>\n  <circle cx=\"108\" cy=\"496\" r=\"10\" fill=\"#6B8F5E\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"108\" y=\"501\" text-anchor=\"middle\" fill=\"#fff\" opacity=\"1\" style=\"font-size:10px;font-weight:700;font-family:-apple-system, sans-serif\">✓</text>\n  <rect x=\"135\" y=\"484\" width=\"100\" height=\"140\" rx=\"4\" fill=\"#5E7B7B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"135\" y=\"484\" width=\"5\" height=\"140\" rx=\"0\" fill=\"rgba(0,0,0,0.2)\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"185\" y=\"546\" text-anchor=\"middle\" fill=\"#FFFFFF\" opacity=\"1\" style=\"font-size:10px;font-weight:600;font-family:-apple-system, sans-serif\">The Hours</text>\n  <text x=\"185\" y=\"562\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.75)\" opacity=\"1\" style=\"font-size:9px;font-weight:400;font-family:-apple-system, sans-serif\">M. Cunningham</text>\n  <circle cx=\"223\" cy=\"496\" r=\"10\" fill=\"#9C9086\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"223\" y=\"501\" text-anchor=\"middle\" fill=\"#fff\" opacity=\"1\" style=\"font-size:10px;font-weight:700;font-family:-apple-system, sans-serif\">↓</text>\n  <rect x=\"250\" y=\"484\" width=\"100\" height=\"140\" rx=\"4\" fill=\"#8B5E5E\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n