r=\"start\" style=\"font-size:26px;font-weight:300;font-family:Georgia, serif;letter-spacing:-0.01em;opacity:1;\">of spring</text><line x1=\"24\" y1=\"240\" x2=\"366\" y2=\"240\" stroke=\"rgba(74,55,40,0.18)\" stroke-width=\"1\" opacity=\"1\"/><text x=\"24\" y=\"262\" fill=\"rgba(74,55,40,0.38)\" text-anchor=\"start\" style=\"font-size:11px;font-weight:700;font-family:system-ui;letter-spacing:0.09em;opacity:1;\">TAGS</text><rect x=\"24\" y=\"270\" width=\"62\" height=\"26\" rx=\"13\" fill=\"#4A3728\" stroke=\"none\" stroke-width=\"1\" opacity=\"1\"/><text x=\"55\" y=\"287\" fill=\"#FAF7F2\" text-anchor=\"middle\" style=\"font-size:11px;font-weight:600;font-family:system-ui;letter-spacing:0;opacity:1;\">Botany</text><rect x=\"94\" y=\"270\" width=\"62\" height=\"26\" rx=\"13\" fill=\"#E8F3E5\" stroke=\"none\" stroke-width=\"1\" opacity=\"1\"/><text x=\"125\" y=\"287\" fill=\"#5A8A4E\" text-anchor=\"middle\" style=\"font-size:11px;font-weight:600;font-family:system-ui;letter-spacing:0;opacity:1;\">Lichen</text><rect x=\"164\" y=\"270\" width=\"55\" height=\"26\" rx=\"13\" fill=\"#FFFFFF\" stroke=\"rgba(74,55,40,0.18)\" stroke-width=\"1\" opacity=\"1\"/><text x=\"191.5\" y=\"287\" fill=\"rgba(74,55,40,0.38)\" text-anchor=\"middle\" style=\"font-size:11px;font-weight:600;font-family:system-ui;letter-spacing:0;opacity:1;\">+ Add</text><line x1=\"24\" y1=\"310\" x2=\"366\" y2=\"310\" stroke=\"rgba(74,55,40,0.10)\" stroke-width=\"1\" opacity=\"1\"/><text x=\"24\" y=\"330\" fill=\"rgba(74,55,40,0.38)\" text-anchor=\"start\" style=\"font-size:11px;font-weight:700;font-family:system-ui;letter-spacing:0.09em;opacity:1;\">BODY</text><text x=\"24\" y=\"350\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">Arrived at grid B4 around 14:20. Light overcast,</text><text x=\"24\" y=\"370\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">temp 11C, 82% humidity. Ideal conditions.</text><text x=\"24\" y=\"390\" fill=\"rgba(74,55,40,0.38)\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\"></text><text x=\"24\" y=\"410\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">Identified Xanthoria parietina (foliose, orange)</text><text x=\"24\" y=\"430\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">on southwest-facing limestone at ~1.2m above</text><text x=\"24\" y=\"450\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">tide line. Coverage approx. 35% of exposed face.</text><text x=\"24\" y=\"470\" fill=\"rgba(74,55,40,0.38)\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\"></text><text x=\"24\" y=\"490\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">Also: Verrucaria maura (black, crustose) on wet</text><text x=\"24\" y=\"510\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">lower faces. Sample ref: CM-2026-04-10-B4.</text><text x=\"24\" y=\"530\" fill=\"rgba(74,55,40,0.38)\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\"></text><text x=\"24\" y=\"550\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">Note: significant increase vs April 2025 survey.</text><text x=\"24\" y=\"570\" fill=\"#1A1209\" text-anchor=\"start\" style=\"font-size:13px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">|</text><rect x=\"0\" y=\"712\" width=\"390\" height=\"52\" rx=\"0\" fill=\"#FFFFFF\" stroke=\"none\" stroke-width=\"1\" opacity=\"1\"/><line x1=\"0\" y1=\"712\" x2=\"390\" y2=\"712\" stroke=\"rgba(74,55,40,0.10)\" stroke-width=\"1\" opacity=\"1\"/><text x=\"38\" y=\"742\" fill=\"#6B4F3A\" text-anchor=\"middle\" style=\"font-size:12px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">Img</text><text x=\"90\" y=\"742\" fill=\"#6B4F3A\" text-anchor=\"middle\" style=\"font-size:12px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">Map</text><text x=\"142\" y=\"742\" fill=\"#6B4F3A\" text-anchor=\"middle\" style=\"font-size:12px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">Mic</text><text x=\"194\" y=\"742\" fill=\"#6B4F3A\" text-anchor=\"middle\" style=\"font-size:12px;font-weight:700;font-family:system-ui;letter-spacing:0;opacity:1;\">Bold</text><text x=\"246\" y=\"742\" fill=\"#6B4F3A\" text-anchor=\"middle\" style=\"font-size:12px;font-weight:700;font-family:system-ui;letter-spacing:0;opacity:1;\">Italic</text><text x=\"298\" y=\"742\" fill=\"#6B4F3A\" text-anchor=\"middle\" style=\"font-size:12px;font-weight:700;font-family:system-ui;letter-spacing:0;opacity:1;\">P</text><rect x=\"24\" y=\"570\" width=\"150\" height=\"24\" rx=\"12\" fill=\"#F5F0E8\" stroke=\"rgba(74,55,40,0.10)\" stroke-width=\"1\" opacity=\"1\"/><text x=\"38\" y=\"586\" fill=\"#6B4F3A\" text-anchor=\"start\" style=\"font-size:11px;font-weight:400;font-family:system-ui;letter-spacing:0;opacity:1;\">142 words  |  ~1 min</text><rect x=\"24\" y=\"600\" width=\"241.8\" height=\"3\" rx=\"2\" fill=\"#7B9B6B\" stroke=\"none\" stroke-width=\"1\" opacity=\"1\"/><rect x=\"265.8\" y=\"600\" width=\"100.19999999999999\" height=\"3\" rx=\"2\" fill=\"#F5F0E8\" stroke=\"none\" stroke-width=\"1\" opacity=\"1\"/><rect x=\"24\" y=\"614\" width=\"120\" height=\"24\" rx=\"12\" fill=\"#FBF0DC\" stroke=\"rgba(74,55,40,0.10)\" stroke-width=\"1\" opacity=\"1\"/><text x=\"84\