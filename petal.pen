spacing=\"0\" opacity=\"1\">💡</text>\n  <text x=\"66\" y=\"632\" font-size=\"13\" fill=\"#1C1917\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Try this: Add a 5-min walk after</text>\n  <text x=\"66\" y=\"650\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">lunch to boost your step count.</text>\n  <text x=\"66\" y=\"666\" font-size=\"11\" fill=\"#5B8A6B\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Tap to add ritual →</text>\n  <rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" rx=\"0\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <line x1=\"0\" y1=\"764\" x2=\"390\" y2=\"764\" stroke=\"#E5DDD8\" stroke-width=\"1\" opacity=\"1\"/>\n  <rect x=\"11\" y=\"774\" width=\"56\" height=\"28\" rx=\"14\" fill=\"#5B8A6B20\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"39\" y=\"793\" font-size=\"11\" fill=\"#5B8A6B\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">❀ Garden</text>\n  <text x=\"117\" y=\"794\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◎</text>\n  <text x=\"117\" y=\"812\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Today</text>\n  <text x=\"195\" y=\"794\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">▲</text>\n  <text x=\"195\" y=\"812\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Streaks</text>\n  <text x=\"273\" y=\"794\" f