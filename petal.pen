      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"0\" fill=\"#FAF7F4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" rx=\"0\" fill=\"#FAF7F4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"29\" font-size=\"15\" fill=\"#1C1917\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">9:41</text>\n  <text x=\"370\" y=\"29\" font-size=\"12\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">●●●</text>\n  <text x=\"20\" y=\"80\" font-size=\"14\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Patterns & reflections</text>\n  <text x=\"20\" y=\"108\" font-size=\"34\" fill=\"#1C1917\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Insights</text>\n  <rect x=\"20\" y=\"128\" width=\"108\" height=\"28\" rx=\"14\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"74\" y=\"147\" font-size=\"11\" fill=\"#57534E\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Mar 24</text>\n  <rect x=\"138\" y=\"128\" width=\"108\" height=\"28\" rx=\"14\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"192\" y=\"147\" font-size=\"11\" fill=\"#57534E\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Mar 31</text>\n  <rect x=\"256\" y=\"128\" width=\"108\" height=\"28\" rx=\"14\" fill=\"#5B8A6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"310\" y=\"147\" font-size=\"11\" fill=\"#fff\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Apr 7</text>\n  <rect x=\"20\" y=\"174\" width=\"350\" height=\"130\" rx=\"20\" fill=\"#5B8A6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"210\" font-size=\"28\" fill=\"#fff\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">✨</text>\n  <text x=\"36\" y=\"242\" font-size=\"20\" fill=\"#fff\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Best week yet!</text>\n  <text x=\"36\" y=\"264\" font-size=\"12\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">You completed 89% of your rituals —</text>\n  <text x=\"36\" y=\"282\" font-size=\"12\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">highest since you started.</text>\n  <text x=\"358\" y=\"252\" font-size=\"46\" fill=\"#fff\" font-weight=\"900\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">89</text>\n  <text x=\"358\" y=\"278\" font-size=\"13\" fill=\"rgba(255,255,255,0.65)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">/ 100</text>\n  <text x=\"20\" y=\"330\" font-size=\"11\" fill=\"#A8A29E\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1.2\" opacity=\"1\">DAILY COMPLETION</text>\n  <rect x=\"24\" y=\"342\" width=\"36\" height=\"100\" rx=\"8\" fill=\"#E5DDD8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"24\" y=\"360\" width=\"36\" height=\"82\" rx=\"8\" fill=\"#5B8A6B99\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"42\" y=\"456\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, s