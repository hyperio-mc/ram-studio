e-width=\"0\"/>\n  <text x=\"166\" y=\"193\" font-size=\"20\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">🙂</text>\n  <circle cx=\"236\" cy=\"186\" r=\"26\" fill=\"#5B8A6B20\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"236\" y=\"193\" font-size=\"24\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">😊</text>\n  <circle cx=\"236\" cy=\"215\" r=\"4\" fill=\"#5B8A6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <circle cx=\"306\" cy=\"186\" r=\"22\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"306\" y=\"193\" font-size=\"20\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">🤩</text>\n  <rect x=\"20\" y=\"232\" width=\"350\" height=\"130\" rx=\"20\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"258\" font-size=\"15\" fill=\"#1C1917\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Gratitude</text>\n  <text x=\"36\" y=\"278\" font-size=\"11\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">3 things I'm grateful for today</text>\n  <circle cx=\"42\" cy=\"299\" r=\"5\" fill=\"#5B8A6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"56\" y=\"303\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Morning sunlight through the window</text>\n  <circle cx=\"42\" cy=\"323\" r=\"5\" fill=\"#5B8A6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"56\" y=\"327\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">A long walk with my dog</text>\n  <circle cx=\"42\" cy=\"347\" r=\"5\" fill=\"#5B8A6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"56\" y=\"351\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">This feels like a good week</text>\n  <rect x=\"20\" y=\"380\" width=\"350\" height=\"110\" rx=\"20\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"406\" font-size=\"15\" fill=\"#1C1917\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Today's reflection</text>\n  <text x=\"36\" y=\"426\" font-size=\"11\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">What made today meaningful?</text>\n  <text x=\"36\" y=\"452\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">I focused on the small wins. The morning</text>\n  <text x=\"36\" y=\"470\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">meditation helped me stay calm during</text>\n  <text x=\"36\" y=\"488\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">a stressful meeting.</text>\n  <text x=\"20\" y=\"514\" font-size=\"11\" fill=\"#A8A29E\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1.2\" opacity=\"1\">RECENT ENTRIES</text>\n  <rect x=\"20\" y=\"530\" width=\"350\" height=\"46\" rx=\"14\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"560\" font-size=\"20\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">😊</text>\n  <text x=\"66\" y=\"553\" font-size=\"11\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Apr 8 · Tue</text>\n  <text x=\"66\" y=\"568\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Great run this morning, 5K!</text>\n  <text x=\"358\" y=\"560\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">›</text>\n  <rect x=\"20\" y=\"584\" width=\"350\" height=\"46\" rx=\"14\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"614\" font-size=\"20\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">🙂</text>\n  <text x=\"66\" y=\"607\" font-size=\"11\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Apr 7 · Mon</text>\n  <text x=\"66\" y=\"622\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Slow start but evening was good.</text>\n  <text x=\"358\" y=\"614\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">›</text>\n  <rect x=\"20\" y=\"638\" width=\"350\" height=\"46\" rx=\"14\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"668\" font-size=\"20\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">🤩</text>\n  <text x=\"66\" y=\"661\" font-size=\"11\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Apr 6 · Sun</text>\n  <text x=\"66\" y=\"676\" font-size=\"12\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Best day this week, full score!</text>\n  <text x=\"358\" y=\"668\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">›</text>\n  <rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" rx=\"0\" fill=\"#FFFFFF\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <line x1=\"0\" y1=\"764\" x2=\"390\" y2=\"764\" stroke=\"#E5DDD8\" stroke-width=\"1\" opacity=\"1\"/>\n  <text x=\"39\" y=\"794\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">❀</text>\n  <text x=\"39\" y=\"812\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Garden</text>\n  <text x=\"117\" y=\"794\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◎</text>\n  <text x=\"117\" y=\"812\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Today</text>\n  <text x=\"195\" y=\"794\" font-size=\"18\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">▲</text>\n  <text x=\"195\" y=\"812\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Streaks</text>\n  <rect x=\"245\" y=\"774\" width=\"56\" height=\"28\" rx=\"14\" fill=\"#5B8A6B20\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"273\" y=\"793\" font-size=\"11