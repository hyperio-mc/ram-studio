        },
        {
          "type": "text",
          "x": 28,
          "y": 162,
          "content": "That afternoon, Don Aurelio takes",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 184,
          "content": "me into the room where he fires",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 206,
          "content": "his pieces. The kiln is three feet",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 228,
          "content": "wide, built from adobe brick his",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 250,
          "content": "grandfather laid. He opens the",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 272,
          "content": "wooden door and the smell of earth",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 294,
          "content": "and heat fills the narrow space.",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 338,
          "content": "\"My son wants to study in the city,\"",
          "fontSize": 15,
          "fill": "#3A5A3E",
          "fontWeight": 600,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 360,
          "content": "he says without turning. \"I told",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 382,
          "content": "him: go. Learn everything. Then",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 404,
          "content": "come back and learn this.\"",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 448,
          "content": "The clay cools on a wooden shelf.",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 470,
          "content": "A jaguar. A woman carrying water.",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 492,
          "content": "A church that looks like his own.",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
