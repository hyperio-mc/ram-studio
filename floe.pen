        },
        {
          "type": "rect",
          "x": 290,
          "y": 764,
          "width": 78,
          "height": 34,
          "fill": "#3A5A3E",
          "rx": 8
        },
        {
          "type": "text",
          "x": 329,
          "y": 787,
          "content": "Done ✓",
          "fontSize": 11,
          "fill": "#FFF",
          "fontWeight": 700,
          "textAnchor": "middle"
        },
        {
          "type": "text",
          "x": 28,
          "y": 378,
          "content": "Don Aurelio does not speak of legacy.",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 400,
          "content": "He speaks of clay, and fire, and what",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 422,
          "content": "a piece needs to survive the kiln.",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 466,
          "content": "I ask about his son. He is quiet for",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 488,
          "content": "a moment, then places a finished jar",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 510,
          "content": "on the shelf beside the others.",
          "fontSize": 15,
          "fill": "#1C1815",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 532,
          "content": "\"He will understand,\" he says.",
          "fontSize": 15,
          "fill": "#3A5A3E",
          "fontWeight": 600,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
        {
          "type": "text",
          "x": 28,
          "y": 554,
          "content": "\"When he is ready, the clay will wait.\"",
          "fontSize": 15,
          "fill": "#3A5A3E",
          "fontWeight": 600,
          "fontFamily": "Georgia, serif",
          "letterSpacing": 0.1
        },
