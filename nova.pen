        {
          "id": "el-154",
          "type": "text",
          "x": 20,
          "y": 316,
          "content": "The real question isn't which app",
          "fontSize": 13,
          "fill": "#9899A8",
          "fontWeight": "400",
          "fontFamily": "Inter",
