"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">≡</text><line x1=\"166\" y1=\"60\" x2=\"166\" y2=\"76\" stroke=\"#2A2D3A\" stroke-width=\"1\" opacity=\"0.5\"/><text x=\"186\" y=\"73\" font-size=\"14\" fill=\"#60627A\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">⊞</text><line x1=\"206\" y1=\"60\" x2=\"206\" y2=\"76\" stroke=\"#2A2D3A\" stroke-width=\"1\" opacity=\"0.5\"/><text x=\"226\" y=\"73\" font-size=\"14\" fill=\"#60627A\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">✦</text><rect x=\"310\" y=\"52\" width=\"64\" height=\"32\" fill=\"#1A1B22\" rx=\"16\" stroke=\"#2A2D3A\" stroke-width=\"1\" opacity=\"1\"/><circle cx=\"324\" cy=\"68\" r=\"6\" fill=\"#7C3AED\" opacity=\"1\"/><text x=\"335\" y=\"72\" font-size=\"11\" fill=\"#9899A8\" font-family=\"Inter, sans-serif\">2847</text><rect x=\"0\" y=\"92\" width=\"390\" height=\"72\" fill=\"#0C0D10\" opacity=\"1\"/><rect x=\"20\" y=\"102\" width=\"78\" height=\"18\" fill=\"#FBBF2422\" rx=\"9\" opacity=\"1\"/><text x=\"59\" y=\"113.8\" font-size=\"8\" fill=\"#FBBF24\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">IN PROGRESS</text><text x=\"20\" y=\"138\" font-size=\"20\" fill=\"#EEEEF2\" font-weight=\"700\" font-family=\"Playfair Display, sans-serif\">The Signal Newsletter</text><rect x=\"0\" y=\"164\" width=\"390\" height=\"28\" fill=\"#1A1B22\" opacity=\"1\"/><rect x=\"16\" y=\"170\" width=\"358\" height=\"8\" fill=\"#2A2D3A\" rx=\"4\" opacity=\"1\"/><rect x=\"16\" y=\"170\" width=\"300.71999999999997\" height=\"8\" fill=\"#A78BFA\" rx=\"4\" opacity=\"1\"/><text x=\"16\" y=\"198\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">4,214 words</text><text x=\"374\" y=\"198\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\" text-anchor=\"end\">5,000 goal</text><text x=\"20\" y=\"220\" font-size=\"15\" fill=\"#EEEEF2\" font-weight=\"700\" font-family=\"Inter, sans-serif\">The infrastructure of attention</text><text x=\"20\" y=\"244\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\">Last week I noticed something strange:</text><text x=\"20\" y=\"262\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\">every app I opened was competing</text><text x=\"20\" y=\"280\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\">for the same 30-minute window.</text><text x=\"20\" y=\"298\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\"></text><text x=\"20\" y=\"316\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\">The real question isn't which app</text><text x=\"20\" y=\"334\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\">wins — it's what the competition</text><text x=\"20\" y=\"352\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\">costs us as creators.</text><text x=\"20\" y=\"370\" font-size=\"13\" fill=\"#9899A8\" font-weight=\"400\" font-family=\"Inter, sans-serif\"></text><text x=\"20\" y=\"388\" font-size=\"13\" fill=\"#EEEEF2\" font-weight=\"600\" font-family=\"Inter, sans-serif\">Three signals stood out:</text><rect x=\"16\" y=\"400\" width=\"358\" height=\"48\" fill=\"#7C3AED18\" rx=\"10\" stroke=\"#7C3AED44\" stroke-width=\"1\" opacity=\"1\"/><text x=\"28\" y=\"418\" font-size=\"12\" fill=\"#C4B5FD\" font-family=\"Inter, sans-serif\">✦</text><text x=\"44\" y=\"418\" font-size=\"10\" fill=\"#C4B5FD\" font-weight=\"600\" font-family=\"Inter, sans-serif\">AI Suggestion</text><text x=\"28\" y=\"436\" font-size=\"11\" fill=\"#C4B5FD\" font-family=\"Inter, sans-serif\">\"Signal fatigue is the hidden tax on creator productivity\"</text><rect x=\"28\" y=\"452\" width=\"60\" height=\"22\" fill=\"#7C3AED\" rx=\"11\" opacity=\"1\"/><text x=\"58\" y=\"466.5\" font-size=\"10\" fill=\"#EEEEF2\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">Accept</text><rect x=\"96\" y=\"452\" width=\"58\" height=\"22\" fill=\"#1A1B22\" rx=\"11\" opacity=\"1\"/><text x=\"125\" y=\"466.5\" font-size=\"10\" fill=\"#60627A\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">Skip</text><rect x=\"20\" y=\"474\" width=\"2\" height=\"16\" fill=\"#A78BFA\" rx=\"1\" opacity=\"0.9\"/><rect x=\"20\" y=\"498\" width=\"310\" height=\"10\" fill=\"#2A2D3A\" rx=\"5\" opacity=\"0.6\"/><rect x=\"20\" y=\"518\" width=\"270\" height=\"10\" fill=\"#2A2D3A\" rx=\"5\" opacity=\"0.6\"/><rect x=\"20\" y=\"538\" width=\"230\" height=\"10\" fill=\"#2A2D3A\" rx=\"5\" opacity=\"0.6\"/><rect x=\"0\" y=\"728\" width=\"390\" height=\"32\" fill=\"#1A1B22\" opacity=\"1\"/><line x1=\"0\" y1=\"728\" x2=\"390\" y2=\"728\" stroke=\"#2A2D3A\" stroke-width=\"0.5\" opacity=\"1\"/><text x=\"20\" y=\"748\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">4,214 words</text><text x=\"92\" y=\"748\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">·</text><text x=\"113\" y=\"748\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">267 lines</text><text x=\"185\" y=\"748\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">·</text><text x=\"206\" y=\"748\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">18 min read</text><text x=\"278\" y=\"748\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">·</text><text x=\"299\" y=\"748\" font-size=\"9\" fill=\"#60627A\" font-family=\"Inter, sans-serif\">87 clarity</text><rect x=\"0\" y=\"760\" width=\"390\" height=\"84\" fill=\"#14151A\" opacity=\"1\"/><line x1=\"0\" y1=\"760\" x2=\"390\" y2=\"760\" stroke=\"#2A2D3A\" stroke-width=\"1\" opacity=\"1\"/><text x=\"39\" y=\"794\" font-size=\"18\" fill=\"#60627A\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">⊞</text><text x=\"39\" y=\