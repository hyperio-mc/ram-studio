 text-anchor=\"start\">Recent activity</text>\n  <rect x=\"20\" y=\"558\" width=\"350\" height=\"44\" fill=\"#FFFFFF\" rx=\"10\" stroke=\"#E8DDD0\" stroke-width=\"1\"/>\n  <circle cx=\"42\" cy=\"580\" r=\"12\" fill=\"#4A7A57\" opacity=\"0.15\"/>\n  <text x=\"42\" y=\"584\" font-size=\"11\" fill=\"#4A7A57\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">↑</text>\n  <text x=\"60\" y=\"575\" font-size=\"12\" fill=\"#1A1410\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"start\">Added 6 items from Whole Foods</text>\n  <text x=\"60\" y=\"590\" font-size=\"10\" fill=\"#A0907E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\">2h ago</text>\n  <rect x=\"20\" y=\"610\" width=\"350\" height=\"44\" fill=\"#FFFFFF\" rx=\"10\" stroke=\"#E8DDD0\" stroke-width=\"1\"/>\n  <circle cx=\"42\" cy=\"632\" r=\"12\" fill=\"#C4622A\" opacity=\"0.15\"/>\n  <text x=\"42\" y=\"636\" font-size=\"11\" fill=\"#C4622A\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">✓</text>\n  <text x=\"60\" y=\"627\" font-size=\"12\" fill=\"#1A1410\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"start\">Cooked Shakshuka · used 5 items</text>\n  <text x=\"60\" y=\"642\" font-size=\"10\" fill=\"#A0907E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\">Yesterday</text>\n  <rect x=\"20\" y=\"662\" width=\"350\" height=\"44\" fill=\"#FFFFFF\" rx=\"10\" stroke=\"#E8DDD0\" stroke-width=\"1\"/>\n  <circle cx=\"42\" cy=\"684\" r=\"12\" fill=\"#2E6B9A\" opacity=\"0.15\"/>\n  <text x=\"42\" y=\"688\" font-size=\"11\" fill=\"#2E6B9A\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">↓</text>\n  <text x=\"60\" y=\"679\" font-size=\"12\" fill=\"#1A1410\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"start\">3 items expired — removed</text>\n  <text x=\"60\" y=\"694\" font-size=\"10\" fill=\"#A0907E\" font-weight=\"400