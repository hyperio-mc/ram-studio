      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 390 844\" width=\"390\" height=\"844\">\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FAF8F4\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"22\" font-size=\"12\" fill=\"#141210\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">9:41</text>\n  <text x=\"20\" y=\"46\" font-size=\"16\" fill=\"#141210\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"4\" opacity=\"1\">LIGA</text>\n  <line x1=\"0\" y1=\"54\" x2=\"390\" y2=\"54\" stroke=\"#E3DDD4\" stroke-width=\"1\" opacity=\"1\"/>\n  <text x=\"20\" y=\"84\" font-size=\"26\" fill=\"#141210\" font-weight=\"300\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"-0.5\" opacity=\"1\">Collections</text>\n  <text x=\"20\" y=\"104\" font-size=\"12\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Curated by foundry editors</text>\n  <line x1=\"0\" y1=\"116\" x2=\"390\" y2=\"116\" stroke=\"#E3DDD4\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <rect x=\"20\" y=\"124\" width=\"350\" height=\"150\" fill=\"#1A1510\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"360\" y=\"262\" font-size=\"110\" fill=\"rgba(255,255,255,0.05)\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">E</text>\n  <text x=\"362\" y=\"146\" font-size=\"9\" fill=\"rgba(255,255,255,0.55)\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"1\" opacity=\"1\">14 families</text>\n  <text x=\"28\" y=\"174\" font-size=\"18\" fill=\"#FFFFFF\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">For the Editorial Page</text>\n  <text x=\"28\" y=\"194\" font-size=\"11\" fill=\"rgba(255,255,255,0.55)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Serifs and display types for print-inspired digital media</text>\n  <rect x=\"28\" y=\"210\" width=\"50\" height=\"20\" fill=\"rgba(255,255,255,0.12)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"53\" y=\"223\" font-size=\"9\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Victor</text>\n  <rect x=\"84\" y=\"210\" width=\"44\" height=\"20\" fill=\"rgba(255,255,255,0.12)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"106\" y=\"223\" font-size=\"9\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Sabon</text>\n  <rect x=\"134\" y=\"210\" width=\"50\" height=\"20\" fill=\"rgba(255,255,255,0.12)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"159\" y=\"223\" font-size=\"9\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Canela</text>\n  <text x=\"362\" y=\"252\" font-size=\"18\" fill=\"rgba(255,255,255,0.55)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">→</text>\n  <rect x=\"20\" y=\"286\" width=\"350\" height=\"150\" fill=\"#F0EDE6\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"360\" y=\"424\" font-size=\"110\" fill=\"rgba(20,18,16,0.04)\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">M</text>\n  <text x=\"362\" y=\"308\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"1\" opacity=\"1\">9 families</text>\n  <text x=\"28\" y=\"336\" font-size=\"18\" fill=\"#141210\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Precision Instruments</text>\n  <text x=\"28\" y=\"356\" font-size=\"11\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Mono and technical faces for developer tools</text>\n  <rect x=\"28\" y=\"372\" width=\"50\" height=\"20\" fill=\"rgba(20,18,16,0.07)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"53\" y=\"385\" font-size=\"9\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Stabil</text>\n  <rect x=\"84\" y=\"372\" width=\"62\" height=\"20\" fill=\"rgba(20,18,16,0.07)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"115\" y=\"385\" font-size=\"9\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Berkeley</text>\n  <rect x=\"152\" y=\"372\" width=\"44\" height=\"20\" fill=\"rgba(20,18,16,0.07)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"174\" y=\"385\" font-size=\"9\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Geist</text>\n  <text x=\"362\" y=\"414\" font-size=\"18\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">→</text>\n  <rect x=\"20\" y=\"448\" width=\"350\" height=\"150\" fill=\"#9B7A45\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"360\" y=\"586\" font-size=\"110\" fill=\"rgba(255,255,255,0.05)\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">R</text>\n  <text x=\"362\" y=\"470\" font-size=\"9\" fill=\"rgba(255,255,255,0.55)\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"1\" opacity=\"1\">11 families</text>\n  <text x=\"28\" y=\"498\" font-size=\"18\" fill=\"#FFFFFF\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Radical Forms</text>\n  <text x=\"28\" y=\"518\" font-size=\"11\" fill=\"rgba(255,255,255,0.55)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Experimental and expressive display faces</text>\n  <rect x=\"28\" y=\"534\" width=\"50\" height=\"20\" fill=\"rgba(255,255,255,0.12)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"53\" y=\"547\" font-size=\"9\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Attila</text>\n  <rect x=\"84\" y=\"534\" width=\"56\" height=\"20\" fill=\"rgba(255,255,255,0.12)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"112\" y=\"547\" font-size=\"9\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Pangram</text>\n  <rect x=\"146\" y=\"534\" width=\"32\" height=\"20\" fill=\"rgba(255,255,255,0.12)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"162\" y=\"547\" font-size=\"9\" fill=\"rgba(255,255,255,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Noe</text>\n  <text x=\"362\" y=\"576\" font-size=\"18\" fill=\"rgba(255,255,255,0.55)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">→</text>\n  <rect x=\"20\" y=\"610\" width=\"350\" height=\"150\" fill=\"#F0EDE6\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"360\" y=\"748\" font-size=\"110\" fill=\"rgba(20,18,16,0.04)\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">G</text>\n  <text x=\"362\" y=\"632\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"1\" opacity=\"1\">18 families</text>\n  <text x=\"28\" y=\"660\" font-size=\"18\" fill=\"#141210\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">The Invisible Hand</text>\n  <text x=\"28\" y=\"680\" font-size=\"11\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Interface grotesques — readable, neutral, essential</text>\n  <rect x=\"28\" y=\"696\" width=\"62\" height=\"20\" fill=\"rgba(20,18,16,0.07)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"59\" y=\"709\" font-size=\"9\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Uniforma</text>\n  <rect x=\"96\" y=\"696\" width=\"44\" height=\"20\" fill=\"rgba(20,18,16,0.07)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"118\" y=\"709\" font-size=\"9\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Inter</text>\n  <rect x=\"146\" y=\"696\" width=\"44\" height=\"20\" fill=\"rgba(20,18,16,0.07)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"168\" y=\"709\" font-size=\"9\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.4\" opacity=\"1\">Geist</text>\n  <text x=\"362\" y=\"738\" font-size=\"18\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">→</text>\n  <rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" fill=\"#FFFFFF\" rx=\"0\" opacity=\"1\" s