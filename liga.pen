letter-spacing=\"0\" opacity=\"1\">247 typefaces from independent foundries</text>\n  <text x=\"370\" y=\"398\" font-size=\"11\" fill=\"#E3DDD4\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">01</text>\n  <line x1=\"0\" y1=\"466\" x2=\"390\" y2=\"466\" stroke=\"#E3DDD4\" stroke-width=\"0.3\" opacity=\"0.5\"/>\n  <text x=\"24\" y=\"448\" font-size=\"14\" fill=\"#9B7A45\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◎</text>\n  <text x=\"44\" y=\"448\" font-size=\"13\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Live in-browser type testing</text>\n  <text x=\"370\" y=\"448\" font-size=\"11\" fill=\"#E3DDD4\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">02</text>\n  <line x1=\"0\" y1=\"516\" x2=\"390\" y2=\"516\" stroke=\"#E3DDD4\" stroke-width=\"0.3\" opacity=\"0.5\"/>\n  <text x=\"24\" y=\"498\" font-size=\"14\" fill=\"#9B7A45\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">○</text>\n  <text x=\"44\" y=\"498\" font-size=\"13\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Curated editorial collections</text>\n  <text x=\"370\" y=\"498\" font-size=\"11\" fill=\"#E3DDD4\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">03</text>\n  <line x1=\"0\" y1=\"566\" x2=\"390\" y2=\"566\" stroke=\"#E3DDD4\" stroke-width=\"0.3\" opacity=\"0.5\"/>\n  <text x=\"24\" y=\"548\" font-size=\"14\" fill=\"#9B7A45\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◍</text>\n  <text x=\"44\" y=\"548\" font-size=\"13\" fill=\"#141210\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Instant licensing — no subscriptions</text>\n  <text x=\"370\" y=\"548\" font-size=\"11\" fill=\"#E3DDD4\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">04</text>\n  <line x1=\"0\" y1=\"566\" x2=\"390\" y2=\"566\" stroke=\"#E3DDD4\" stroke-width=\"1\" opacity=\"1\"/>\n  <text x=\"195\" y=\"600\" font-size=\"14\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">\"We believe type is culture.\"</text>\n  <text x=\"195\" y=\"622\" font-size=\"11\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">— LIGA, 2025</text>\n  <line x1=\"0\" y1=\"644\" x2=\"390\" y2=\"644\" stroke=\"#E3DDD4\" stroke-width=\"0.5\" opacity=\"1\"/>\n  <text x=\"20\" y=\"656\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">Curators</text>\n  <text x=\"370\" y=\"656\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">Basel / Berlin / Tokyo</text>\n  <line x1=\"0\" y1=\"666\" x2=\"390\" y2=\"666\" stroke=\"#E3DDD4\" stroke-width=\"0.3\" opacity=\"0.4\"/>\n  <text x=\"20\" y=\"684\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">Founded</text>\n  <text x=\"370\" y=\"684\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">2024</text>\n  <line x1=\"0\" y1=\"694\" x2=\"390\" y2=\"694\" stroke=\"#E3DDD4\" stroke-width=\"0.3\" opacity=\"0.4\"/>\n  <text x=\"20\" y=\"712\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">Foundries</text>\n  <text x=\"370\" y=\"712\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">38 independent</text>\n  <line x1=\"0\" y1=\"722\" x2=\"390\" y2=\"722\" stroke=\"#E3DDD4\" stroke-width=\"0.3\" opacity=\"0.4\"/>\n  <text x=\"20\" y=\"740\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">Typefaces</text>\n  <text x=\"370\" y=\"740\" font-size=\"9\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">247 and growing</text>\n  <rect x=\"20\" y=\"728\" width=\"350\" height=\"44\" fill=\"#141210\" rx=\"6\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"195\" y=\"755\" font-size=\"14\" fill=\"#FFFFFF\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Start Discovering</text>\n  <rect x=\"20\" y=\"780\" width=\"350\" height=\"38\" fill=\"none\" rx=\"6\" opacity=\"1\" stroke=\"#E3DDD4\" stroke-width=\"1\"/>\n  <text x=\"195\" y=\"804\" font-size=\"12\" fill=\"#7A746C\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">I'm a type foundry →</text>\n  <rect x=\"0\" y=\"826\" width=\"390\" height=\"18\" fill=\"#FAF8F4\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <line x1=\"145\" y1=\"838\" x2=\"245\" y2=\"838\" stroke=\"#141210\" stroke-width=\"3\" opacity=\"0.12\"/>\n  <line x1=\"8\" y1=\"60\" x2=\"8\" y2=\"754\" stroke=\"#E3DDD4\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n  <text x=\"8\" y=\"748\" font-size=\"8\" fill=\"#E3DDD4\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">01</text>\n  <text x