ont-weight=\"300\" font-family=\"Georgia, serif\" text-anchor=\"middle\" letter-spacing=\"-1\" opacity=\"1\">March 2026</text>\n    <line x1=\"20\" y1=\"108\" x2=\"370\" y2=\"108\" stroke=\"#FFFFFF\" stroke-width=\"0.5\" opacity=\"0.15\"/>\n    <text x=\"195\" y=\"136\" font-size=\"15\" fill=\"#FAF7F2\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">You saved 31% more</text>\n    <text x=\"195\" y=\"156\" font-size=\"15\" fill=\"#FAF7F2\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"0.6\">than February</text>\n    <text x=\"195\" y=\"176\" font-size=\"10\" fill=\"#C45E3A\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.5\" opacity=\"1\">↑ Best month this year</text>\n    <text x=\"78.33333333333334\" y=\"232\" font-size=\"8\" fill=\"#9A9390\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"1.5\" opacity=\"1\">EARNED</text>\n    <text x=\"78.33333333333334\" y=\"256\" font-size=\"16\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">$5,840</text>\n    <text x=\"78.33333333333334\" y=\"272\" font-size=\"9\" fill=\"#4A4540\" font-weight=\"500\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">+4.2%</text>\n    <line x1=\"136.66666666666669\" y1=\"220\" x2=\"136.66666666666669\" y2=\"280\" stroke=\"#DDD9D0\" stroke-width=\"0.5\" opacity=\"1\"/>\n    <text x=\"195.00000000000003\" y=\"232\" font-size=\"8\" fill=\"#9A9390\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"1.5\" opacity=\"1\">SPENT</text>\n    <text x=\"195.00000000000003\" y=\"256\" font-size=\"16\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">$1,892</text>\n    <text x=\"195.00000000000003\" y=\"272\" font-size=\"9\" fill=\"#4A7C6B\" font-weight=\"500\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">-22.4%</text>\n    <line x1=\"253.33333333333334\" y1=\"220\" x2=\"253.33333333333334\" y2=\"280\" stroke=\"#DDD9D0\" stroke-width=\"0.5\" opacity=\"1\"/>\n    <text x=\"311.6666666666667\" y=\"232\" font-size=\"8\" fill=\"#9A9390\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"1.5\" opacity=\"1\">SAVED</text>\n    <text x=\"311.6666666666667\" y=\"256\" font-size=\"16\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">$3,948</text>\n    <text x=\"311.6666666666667\" y=\"272\" font-size=\"9\" fill=\"#4A7C6B\" font-weight=\"500\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">+31.0%</text>\n    <line x1=\"20\" y1=\"288\" x2=\"370\" y2=\"288\" stroke=\"#DDD9D0\" stroke-width=\"0.5\" opacity=\"1\"/>\n    <text x=\"20\" y=\"312\" font-size=\"16\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Insights</text>\n    <line x1=\"20\" y1=\"320\" x2=\"60\" y2=\"320\" stroke=\"#C45E3A\" stroke-width=\"1.5\" opacity=\"1\"/>\n    <line x1=\"20\" y1=\"336\" x2=\"370\" y2=\"336\" stroke=\"#DDD9D0\" stroke-width=\"0.3\" opacity=\"0.5\"/>\n    <text x=\"20\" y=\"358\" font-size=\"11\" fill=\"#C45E3A\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">01</text>\n    <text x=\"44\" y=\"358\" font-size=\"13\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Dining under control</text>\n    <text x=\"44\" y=\"376\" font-size=\"11\" fill=\"#4A4540\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Food spending dropped $94 from February, your</text>\n    <text x=\"44\" y=\"392\" font-size=\"11\" fill=\"#4A4540\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">lowest in 6 months.</text>\n    <line x1=\"20\" y1=\"440\" x2=\"370\" y2=\"440\" stroke=\"#DDD9D0\" stroke-width=\"0.3\" opacity=\"0.5\"/>\n    <text x=\"20\" y=\"462\" font-size=\"11\" fill=\"#C45E3A\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">02</text>\n    <text x=\"44\" y=\"462\" font-size=\"13\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Subscriptions creeping</text>\n    <text x=\"44\" y=\"480\" font-size=\"11\" fill=\"#4A4540\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">You added 2 new subscriptions totalling $45/month.</text>\n    <text x=\"44\" y=\"496\" font-size=\"11\" fill=\"#4A4540\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Review quarterly.</text>\n    <line x1=\"20\" y1=\"544\" x2=\"370\" y2=\"544\" stroke=\"#DDD9D0\" stroke-width=\"0.3\" opacity=\"0.5\"/>\n    <text x=\"20\" y=\"566\" font-size=\"11\" fill=\"#C45E3A\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">03</text>\n    <text x=\"44\" y=\"566\" font-size=\"13\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Emergency fund milestone</text>\n    <text x=\"44\" y=\"584\" font-size=\"11\" fill=\"#4A4540\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">At 68% complete. At current pace, funded</text>\n    <text x=\"44\" y=\"600\" font-size=\"11\" fill=\"#4A4540\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">by August 2026.</text>\n    <line x1=\"20\" y1=\"648\" x2=\"370\" y2=\"648\" stroke=\"#DDD9D0\" stroke-width=\"0.5\" opacity=\"1\"/>\n    <text x=\"20\" y=\"668\" font-size=\"11\" fill=\"#1A1714\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Daily Activity — March</text>\n    <line x1=\"20\" y1=\"676\" x2=\"370\" y2=\"676\" stroke=\"#DDD9D0\" stroke-width=\"0.3\" opacity=\"0.5\"/>\n    <circle cx=\"45\" cy=\"696\" r=\"4\" fill=\"#DDD9D0\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"95\" cy=\"696\" r=\"4\" fill=\"#B8943F\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"145\" cy=\"696\" r=\"4\" fill=\"#C45E3A\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"195\" cy=\"696\" r=\"4\" fill=\"#DDD9D0\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"245\" cy=\"696\" r=\"4\" fill=\"#F4F0E8\" opacity=\"0.3\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"295\" cy=\"696\" r=\"4\" fill=\"#F4F0E8\" opacity=\"0.3\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"345\" cy=\"696\" r=\"4\" fill=\"#F4F0E8\" opacity=\"0.3\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"45\" cy=\"710\" r=\"4\" fill=\"#B8943F\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"95\" cy=\"710\" r=\"4\" fill=\"#C45E3A\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"145\" cy=\"710\" r=\"4\" fill=\"#DDD9D0\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"195\" cy=\"710\" r=\"4\" fill=\"#B8943F\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"245\" cy=\"710\" r=\"4\" fill=\"#DDD9D0\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"295\" cy=\"710\" r=\"4\" fill=\"#F4F0E8\" opacity=\"0