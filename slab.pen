><rect x=\"20\" y=\"102\" width=\"350\" height=\"52\" fill=\"#FFFFFF\" rx=\"6\" stroke=\"#DDD7CE\" stroke-width=\"0.5\"/><text x=\"63.75\" y=\"121\" font-size=\"16\" fill=\"#C4511A\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"middle\">847</text><text x=\"63.75\" y=\"135\" font-size=\"9\" fill=\"#9C958D\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"middle\" letter-spacing=\"0.06em\">Words</text><line x1=\"107.5\" y1=\"112\" x2=\"107.5\" y2=\"148\" stroke=\"#DDD7CE\" stroke-width=\"0.5\"/><text x=\"151.25\" y=\"121\" font-size=\"16\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"middle\">4m</text><text x=\"151.25\" y=\"135\" font-size=\"9\" fill=\"#9C958D\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"middle\" letter-spacing=\"0.06em\">Read</text><line x1=\"195\" y1=\"112\" x2=\"195\" y2=\"148\" stroke=\"#DDD7CE\" stroke-width=\"0.5\"/><text x=\"238.75\" y=\"121\" font-size=\"16\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"middle\">11</text><text x=\"238.75\" y=\"135\" font-size=\"9\" fill=\"#9C958D\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"middle\" letter-spacing=\"0.06em\">Grade</text><line x1=\"282.5\" y1=\"112\" x2=\"282.5\" y2=\"148\" stroke=\"#DDD7CE\" stroke-width=\"0.5\"/><text x=\"326.25\" y=\"121\" font-size=\"16\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"middle\">94%</text><text x=\"326.25\" y=\"135\" font-size=\"9\" fill=\"#9C958D\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"middle\" letter-spacing=\"0.06em\">Score</text><line x1=\"20\" y1=\"163\" x2=\"370\" y2=\"163\" stroke=\"#DDD7CE\" stroke-width=\"0.5\"/><text x=\"20\" y=\"177\" font-size=\"11\" fill=\"#9C958D\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"start\" letter-spacing=\"0.12em\">THE QUIET REVOLUTION</text><text x=\"370\" y=\"177\" font-size=\"11\" fill=\"#5C5650\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"end\">In Independent Media</text><line x1=\"20\" y1=\"184\" x2=\"370\" y2=\"184\" stroke=\"#DDD7CE\" stroke-width=\"0.5\"/><rect x=\"20\" y=\"192\" width=\"350\" height=\"380\" fill=\"#FFFFFF\" rx=\"4\" stroke=\"#DDD7CE\" stroke-width=\"0.5\"/><text x=\"32\" y=\"228\" font-size=\"22\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"start\" letter-spacing=\"-0.02em\">Something is shifting</text><text x=\"32\" y=\"250\" font-size=\"22\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"start\" letter-spacing=\"-0.02em\">in how we read.</text><rect x=\"32\" y=\"262\" width=\"28\" height=\"36\" fill=\"#F5E6DD\" rx=\"3\"/><text x=\"46\" y=\"290\" font-size=\"26\" fill=\"#C4511A\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"middle\">I</text><text x=\"68\" y=\"272\" font-size=\"13\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"start\">n 2026, the independent newsletter has become</text><text x=\"32\" y=\"287\" font-size=\"13\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"start\">something more than a side project. With tools like</text><text x=\"32\" y=\"302\" font-size=\"13\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"start\">SLAB, a single writer can reach audiences that</text><text x=\"32\" y=\"317\" font-size=\"13\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"start\">rival established media outlets — without the</text><text x=\"32\" y=\"332\" font-size=\"13\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"start\">overhead, the editorial layers, or the paywall.</text><rect x=\"32\" y=\"340\" width=\"2\" height=\"16\" fill=\"#C4511A\" rx=\"1\"/><rect x=\"32\" y=\"362\" width=\"326\" height=\"50\" fill=\"#F5F1EA\" rx=\"4\"/><line x1=\"32\" y1=\"362\" x2=\"32\" y2=\"412\" stroke=\"#C4511A\" stroke-width=\"3\"/><text x=\"44\" y=\"378\" font-size=\"13\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"500\" text-anchor=\"start\">\"The essay is the last form</text><text x=\"44\" y=\"394\" font-size=\"13\" fill=\"#1A1714\" font-family=\"Georgia, serif\" font-weight=\"500\" text-anchor=\"start\">where thinking is visible.\"</text><text x=\"44\" y=\"407\" font-size=\"10\" fill=\"#9C958D\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"start\">— Notes on writing</text><rect x=\"95\" y=\"548\" width=\"200\" height=\"40\" fill=\"#1A1714\" rx=\"8\"/><text x=\"119\" y=\"574\" font-size=\"14\" fill=\"#FFFFFF\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"middle\">B</text><line x1=\"137\" y1=\"558\" x2=\"137\" y2=\"578\" stroke=\"#FFFFFF\" stroke-width=\"0.5\" opacity=\"0.15\"/><text x=\"153\" y=\"574\" font-size=\"14\" fill=\"#FFFFFF\" font-family=\"Georgia, serif\" font-weight=\"700\" text-anchor=\"middle\">I</text><line x1=\"171\" y1=\"558\" x2=\"171\" y2=\"578\" stroke=\"#FFFFFF\" stroke-width=\"0.5\" opacity=\"0.15\"/><text x=\"187\" y=\"574\" font-size=\"14\" fill=\"#FFFFFF\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"middle\">H</text><line x1=\"205\" y1=\"558\" x2=\"205\" y2=\"578\" stroke=\"#FFFFFF\" stroke-width=\"0.5\" opacity=\"0.15\"/><text x=\"221\" y=\"574\" font-size=\"14\" fill=\"#FFFFFF\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"middle\">¶</text><line x1=\"239\" y1=\"558\" x2=\"239\" y2=\"578\" stroke=\"#FFFFFF\" stroke-width=\"0.5\" opacity=\"0.15\"/><text x=\"255\" y=\"574\" font-size=\"14\" fill=\"#FFFFFF\" font-family=\"Georgia, serif\" font-weight=\"400\" text-anchor=\"middle\">»</text><line x1=\"273\" y1=\"558\" x2=\"273\" y2=\"578\" stroke=\"#FFFFFF\" stroke-width=\"0.5\" opacity=\"0.15\"/><text x=\"289\" y=\"574\" font-size=\"14\" fill=\"#C4511A\" font-family=\"Georgia, serif\" f