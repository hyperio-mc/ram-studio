    {
      "id": "el-15",
      "type": "text",
      "x": 20,
      "y": 90,
      "content": "On the quiet\nart of noticing",
      "fontSize": 38,
      "fill": "#FAFAFA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "300",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.15,
      "fontStyle": "normal"
    },
    {
      "id": "el-16",
      "type": "text",
      "x": 20,
      "y": 200,
      "content": "April 4, 2026  ·  Essay",
      "fontSize": 12,
      "fill": "#71717A",
      "fontFamily": "Inter, system-ui, sans-serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0.05em",
      "opacity": 1,
      "width": 300,
      "lineHeight": 1.4,
      "fontStyle": "normal"
    },
    {
      "id": "el-17",
      "type": "line",
      "x1": 20,
      "y1": 222,
      "x2": 130,
      "y2": 222,
      "stroke": "#3F3F46",
      "strokeWidth": 1,
      "opacity": 1
    },
    {
      "id": "el-18",
      "type": "text",
      "x": 20,
      "y": 236,
      "content": "There is a kind of attention that asks nothing",
      "fontSize": 14.5,
      "fill": "#FAFAFA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-19",
      "type": "text",
      "x": 20,
      "y": 258,
      "content": "of the world — no answers, no resolution,",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-20",
      "type": "text",
      "x": 20,
      "y": 280,
      "content": "only the willingness to sit with what is.",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-21",
      "type": "text",
      "x": 20,
      "y": 302,
      "content": "",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-22",
      "type": "text",
      "x": 20,
      "y": 324,
      "content": "I have been practicing this lately: walking",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-23",
      "type": "text",
      "x": 20,
      "y": 346,
      "content": "the same route each morning, trying to notice",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-24",
      "type": "text",
      "x": 20,
      "y": 368,
      "content": "one thing I had not seen before.",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-25",
      "type": "text",
      "x": 20,
      "y": 390,
      "content": "",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-26",
      "type": "text",
      "x": 20,
      "y": 412,
      "content": "Yesterday it was the way light moved through",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-27",
      "type": "text",
      "x": 20,
      "y": 434,
      "content": "a crack in the pavement — amber and thin,",
      "fontSize": 14.5,
      "fill": "#A1A1AA",
      "fontFamily": "Georgia, serif",
      "fontWeight": "400",
      "textAlign": "left",
      "letterSpacing": "0",
      "opacity": 1,
      "width": 350,
      "lineHeight": 1.5,
      "fontStyle": "normal"
    },
    {
      "id": "el-28",
      "type": "text",
      "x": 20,
      "y": 456,
      "content": "like a sentence that means more than it says.",
      "fontSize": 14.5,
