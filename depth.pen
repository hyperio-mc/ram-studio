0\" fill=\"#5A5F7E22\" rx=\"10\" opacity=\"1\"/><text x=\"221\" y=\"133.5\" font-size=\"9.5\" fill=\"#5A5F7E\" font-weight=\"600\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Apr 8</text><text x=\"20\" y=\"160\" font-size=\"22\" fill=\"#E0E2F4\" font-weight=\"800\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Migrate auth to Clerk SDK</text><text x=\"20\" y=\"180\" font-size=\"22\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">and deprecate our JWT infrastructure</text><text x=\"20\" y=\"210\" font-size=\"10\" fill=\"#5A5F7E\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">Participants</text><circle cx=\"34\" cy=\"238\" r=\"12\" fill=\"#818CF8\" opacity=\"0.85\"/><text x=\"34\" y=\"242\" font-size=\"8\" fill=\"#080A12\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">JL</text><circle cx=\"62\" cy=\"238\" r=\"12\" fill=\"#34D399\" opacity=\"0.85\"/><text x=\"62\" y=\"242\" font-size=\"8\" fill=\"#080A12\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">MK</text><circle cx=\"90\" cy=\"238\" r=\"12\" fill=\"#F472B6\" opacity=\"0.85\"/><text x=\"90\" y=\"242\" font-size=\"8\" fill=\"#080A12\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">AR</text><circle cx=\"118\" cy=\"238\" r=\"12\" fill=\"#FB923C\" opacity=\"0.85\"/><text x=\"118\" y=\"242\" font-size=\"8\" fill=\"#080A12\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">PW</text><circle cx=\"146\" cy=\"238\" r=\"12\" fill=\"#60A5FA\" opacity=\"0.85\"/><text x=\"146\" y=\"242\" font-size=\"8\" fill=\"#080A12\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">SA</text><text x=\"170\" y=\"242\" font-size=\"10\" fill=\"#5A5F7E\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">+ 7 more</text><text x=\"20\" y=\"268\" font-size=\"11\" fill=\"#5A5F7E\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">#backend-team · 12 messages · Slack + GitHub</text><line x1=\"0\" y1=\"286\" x2=\"390\" y2=\"286\" stroke=\"#1E2035\" stroke-width=\"1\" opacity=\"1\"/><text x=\"20\" y=\"306\" font-size=\"11\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">⏱ 47 min discussion</text><text x=\"195\" y=\"306\" font-size=\"11\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">🔗 3 PRs linked</text><text x=\"330\" y=\"306\" font-size=\"11\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">📋 2 docs</text><rect x=\"20\" y=\"326\" width=\"350\" height=\"110\" fill=\"#161828\" rx=\"12\" opacity=\"1\" stroke=\"#818CF833\" stroke-width=\"1\"/><circle cx=\"36\" cy=\"342\" r=\"8\" fill=\"#818CF8\" opacity=\"0.2\"/><text x=\"36\" y=\"346\" font-size=\"9\" fill=\"#818CF8\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">✦</text><text x=\"50\" y=\"346\" font-size=\"9\" fill=\"#818CF8\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">DEPTH SUMMARY</text><text x=\"34\" y=\"364\" font-size=\"11\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Team agreed to replace home-grown JWT with Clerk,</text><text x=\"34\" y=\"378\" font-size=\"11\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">citing maintenance burden and MFA requirements.</text><text x=\"34\" y=\"392\" font-size=\"11\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Migration phased over 3 sprints; rollback plan required</text><text x=\"34\" y=\"406\" font-size=\"11\" fill=\"#9EA3C0\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">before cutting over production traffic.</text><text x=\"34\" y=\"422\" font-size=\"10\" fill=\"#5A5F7E\" font-weight=\"400\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Confidence: High · 3 dissenting voices logged</text><text x=\"20\" y=\"448\" font-size=\"10\" fill=\"#5A5F7E\" font-weight=\"700\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"1.5\" opacity=\"1\">WHY THIS WAS DECIDED</text><rect x=\"20\" y=\"464\" width=\"350\" height=\"44\" fill=\"#161828\" rx=\"8\" opacity=\"1\" stroke=\"#1E2035\" stroke-width=\"1\"/><text x=\"36\" y=\"479\" font-size=\"10\" fill=\"#818CF8\" font-weight=\"800\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">01</text><line x1=\"50\" y1=\"472\" x2=\"50\" y2=\"500\" stroke=\"#1E2035\" stroke-width=\"1\" opacity=\"1\"/><text x=\"62\" y=\"490\" font-size=\"11\" fill=\"#E0E2F4\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">JWT refresh logic causing 3 production bugs per month</text><rect x=\"20\" y=\"516\" width=\"350\" height=\"44\" fill=\"#161828\" rx=\"8\" opacity=\"1\" stroke=\"#1E2035\" stroke-width=\"1\"/><text x=\"36\" y=\"531\" font-size=\"10\" fill=\"#818CF8\" font-weight=\"800\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">02</text><line x1=\"50\" y1=\"524\" x2=\"50\" y2=\"552\" stroke=\"#1E2035\" stroke-width=\"1\" opacity=\"1\"/><text x=\"62\" y=\"542\" font-size=\"11\" fill=\"#E0E2F4\" font-weight=\"500\" font-family=\"Inter\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Clerk MFA m