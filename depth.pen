          "fill": "#9EA3C0",
          "fontWeight": 400,
          "fontFamily": "Inter",
          "textAnchor": "start",
          "letterSpacing": 0,
          "opacity": 1
        },
        {
          "type": "text",
          "x": 34,
          "y": 276,
          "content": "1. Clerk's built-in MFA meets your SOC 2 Type II",
          "fontSize": 11,
