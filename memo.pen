      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FFFFFF\" rx=\"0\"/>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"48\" fill=\"#FAF8F4\" rx=\"0\"/>\n  <text x=\"20\" y=\"31\" style=\"font-size:14px;font-family:system-ui, sans-serif;font-weight:600;fill:#1C1A17;text-anchor:start\">9:41</text>\n  <text x=\"370\" y=\"31\" style=\"font-size:12px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:end\" opacity=\"0.6\">●●● ▌▌</text>\n  <text x=\"20\" y=\"82\" style=\"font-size:14px;font-family:system-ui, sans-serif;font-weight:500;fill:rgba(28,26,23,0.42);text-anchor:start\">✕ Discard</text>\n  <rect x=\"302\" y=\"66\" width=\"72\" height=\"32\" fill=\"#C0392B\" rx=\"16\"/>\n  <text x=\"338\" y=\"86\" style=\"font-size:14px;font-family:system-ui, sans-serif;font-weight:600;fill:#FFFFFF;text-anchor:middle\">Send</text>\n  <line x1=\"20\" y1=\"106\" x2=\"370\" y2=\"106\" stroke=\"#E8E2D8\" stroke-width=\"1\"/>\n  <text x=\"20\" y=\"136\" style=\"font-size:12px;font-family:system-ui, sans-serif;font-weight:600;fill:rgba(28,26,23,0.42);text-anchor:start;letter-spacing:0.5px\">To</text>\n  <rect x=\"46\" y=\"120\" width=\"62\" height=\"26\" fill=\"#F9EDE9\" rx=\"13\"/>\n  <circle cx=\"58\" cy=\"133\" r=\"7\" fill=\"#C0392B\" opacity=\"0.3\"/>\n  <text x=\"82\" y=\"137\" style=\"font-size:12px;font-family:system-ui, sans-serif;font-weight:500;fill:#C0392B;text-anchor:middle\">Design</text>\n  <rect x=\"116\" y=\"120\" width=\"69\" height=\"26\" fill=\"#F9EDE9\" rx=\"13\"/>\n  <circle cx=\"128\" cy=\"133\" r=\"7\" fill=\"#C0392B\" opacity=\"0.3\"/>\n  <text x=\"155.5\" y=\"137\" style=\"font-size:12px;font-family:system-ui, sans-serif;font-weight:500;fill:#C0392B;text-anchor:middle\">Product</text>\n  <text x=\"195\" y=\"137\" style=\"font-size:12px;font-family:system-ui, sans-serif;font-weight:500;fill:#C0392B;text-anchor:start\">+ Add</text>\n  <line x1=\"20\" y1=\"152\" x2=\"370\" y2=\"152\" stroke=\"#E8E2D8\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n  <text x=\"20\" y=\"176\" style=\"font-size:10px;font-family:system-ui, sans-serif;font-weight:700;fill:rgba(28,26,23,0.42);text-anchor:start;letter-spacing:1.5px\">SUBJECT</text>\n  <text x=\"20\" y=\"202\" style=\"font-size:20px;font-family:Georgia, serif;font-weight:700;fill:#1C1A17;text-anchor:start;letter-spacing:-0.3px\">Q3 Creative Direction Brief</text>\n  <rect x=\"282\" y=\"186\" width=\"2\" height=\"18\" fill=\"#C0392B\" rx=\"1\" opacity=\"0.9\"/>\n  <line x1=\"20\" y1=\"214\" x2=\"370\" y2=\"214\" stroke=\"#E8E2D8\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n  <rect x=\"20\" y=\"222\" width=\"36\" height=\"28\" fill=\"#F3EFE8\" rx=\"6\"/>\n  <text x=\"38\" y=\"240\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:700;fill:#1C1A17;text-anchor:middle\">B</text>\n  <rect x=\"64\" y=\"222\" width=\"36\" height=\"28\" fill=\"#F3EFE8\" rx=\"6\"/>\n  <text x=\"82\" y=\"240\" style=\"font-size:13px;font-family:Georgia, serif;font-weight:400;fill:#1C1A17;text-anchor:middle\">I</text>\n  <rect x=\"108\" y=\"222\" width=\"36\" height=\"28\" fill=\"#F3EFE8\" rx=\"6\"/>\n  <text x=\"126\" y=\"240\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:middle\">H</text>\n  <text x=\"170\" y=\"240\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">\"</text>\n  <text x=\"214\" y=\"240\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">•</text>\n  <text x=\"258\" y=\"240\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">—</text>\n  <text x=\"302\" y=\"240\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">🔗</text>\n  <text x=\"346\" y=\"240\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">📎</text>\n  <line x1=\"20\" y1=\"258\" x2=\"370\" y2=\"258\" stroke=\"#E8E2D8\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n  <text x=\"20\" y=\"290\" style=\"font-size:15px;font-family:Georgia, serif;font-weight:400;fill:#1C1A17;text-anchor:start;letter-spacing:-0.1px\">Following last week's strategy session, here</text>\n  <text x=\"20\" y=\"312\" style=\"font-size:15px;font-family:Georgia, serif;font-weight:400;fill:#1C1A17;text-anchor:start;letter-spacing:-0.1px\">are the creative principles for Q3.</text>\n  <text x=\"20\" y=\"344\" style=\"font-size:10px;font-family:system-ui;font-weight:700;fill:rgba(28,26,23,0.42);text-anchor:start;letter-spacing:1.5px\">VISUAL IDENTITY</text>\n  <text x=\"20\" y=\"368\" style=\"font-size:14px;font-family:Georgia, serif;font-weight:400;fill:#1C1A17;text-anchor:start;letter-spacing:-0.1px\">We shift toward warm neutrals and reduce our</text>\n  <text x=\"20\" y=\"388\" style=\"font-size:14px;font-family:Georgia, serif;font-weight:400;fill:#1C1A17;text-anchor:start;letter-spacing:-0.1px\">reliance on pure digital blues. The editorial red</text>\n  <text x=\"20\" y=\"408\" style=\"font-size:14px;font-family:Georgia, serif;font-weight:400;fill:#1C1A17;text-anchor:start;letter-spacing:-0.1px\">becomes our sole accent.</text>\n  <text x=\"20\" y=\"438\" style=\"font-size:10px;font-family:system-ui;font-weight:700;fill:rgba(28,26,23,0.42);text-anchor:start;letter-spacing:1.5px\">TYPOGRAPHY</text>\n  <text x=\"20\" y=\"462\" style=\"font-size:14px;font-family:Georgia, serif;font-weight:400;fill:#1C1A17;text-anchor:start;letter-spacing:-0.1px\">Headlines in Georgia. Body in system-ui.</text>\n  <text x=\"20\" y=\"510\" style=\"font-size:11px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:start\">127 words</text>\n  <rect x=\"20\" y=\"526\" width=\"350\" height=\"48\" fill=\"#F3EFE8\" rx=\"10\"/>\n  <text x=\"36\" y=\"544\" style=\"font-size:14px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:start\">📎</text>\n  <text x=\"56\" y=\"544\" style=\"font-size:13px;font-family:system-ui, sans-serif;font-weight:500;fill:#1C1A17;text-anchor:start\">Attach a file or image</text>\n  <text x=\"56\" y=\"560\" style=\"font-size:11px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:start\">PDF, image, Figma link…</text>\n  <rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" fill=\"#FFFFFF\" rx=\"0\"/>\n  <line x1=\"0\" y1=\"764\" x2=\"390\" y2=\"764\" stroke=\"#E8E2D8\" stroke-width=\"1\"/>\n  <text x=\"39\" y=\"795\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">✉</text>\n  <text x=\"39\" y=\"816\" style=\"font-size:10px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">Inbox</text>\n  <rect x=\"95\" y=\"776\" width=\"44\" height=\"28\" fill=\"#F9EDE9\" rx=\"14\"/>\n  <text x=\"117\" y=\"795\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:#C0392B;text-anchor:middle\">✎</text>\n  <text x=\"117\" y=\"816\" style=\"font-size:10px;font-family:system-ui, sans-serif;font-weight:600;fill:#C0392B;text-anchor:middle\">Write</text>\n  <text x=\"195\" y=\"795\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">◎</text>\n  <text x=\"195\" y=\"816\" style=\"font-size:10px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">Signals</text>\n  <text x=\"273\" y=\"795\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:middle\">⊞</text>\n  <text x=\"273\" y=\"816\" style=\"font-size:10px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42