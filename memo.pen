=\"font-size:11px;font-family:system-ui, sans-serif;font-weight:600;fill:#C0392B;text-anchor:middle\">89% read rate</text>\n  <text x=\"20\" y=\"218\" style=\"font-size:10px;font-family:system-ui, sans-serif;font-weight:700;fill:rgba(28,26,23,0.42);text-anchor:start;letter-spacing:1.5px\">WRITING PREFERENCES</text>\n  <rect x=\"20\" y=\"234\" width=\"350\" height=\"150\" fill=\"#FFFFFF\" rx=\"14\"/>\n  <text x=\"38\" y=\"264\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:start\">✒</text>\n  <text x=\"60\" y=\"264\" style=\"font-size:14px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:start\">Default font</text>\n  <text x=\"362\" y=\"264\" style=\"font-size:12px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:end\">Georgia, serif</text>\n  <text x=\"372\" y=\"264\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:end\">›</text>\n  <line x1=\"52\" y1=\"284\" x2=\"370\" y2=\"284\" stroke=\"#E8E2D8\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n  <text x=\"38\" y=\"314\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:start\">⏱</text>\n  <text x=\"60\" y=\"314\" style=\"font-size:14px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:start\">Reading time estimate</text>\n  <text x=\"362\" y=\"314\" style=\"font-size:12px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:end\">On</text>\n  <text x=\"372\" y=\"314\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:rgba(28,26,23,0.42);text-anchor:end\">›</text>\n  <line x1=\"52\" y1=\"334\" x2=\"370\" y2=\"334\" stroke=\"#E8E2D8\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n  <text x=\"38\" y=\"364\" style=\"font-size:16px;font-family:system-ui, sans-serif;font-weight:400;fill:#1C1A17;text-anchor:start\">💬</text>\n