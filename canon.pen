          "y": 200,
          "content": "p.502 · epilogue",
          "fontSize": 11,
          "fontWeight": 400,
          "fontFamily": "Inter",
          "color": "rgba(28,24,20,0.42)",
          "align": "left",
          "width": 160,
          "opacity": 1,
          "letterSpacing": 0
        },
        {
          "id": "c375",
          "type": "text",
          "x": 266,
          "y": 200,
          "content": "Just names remain.",
          "fontSize": 11,
          "fontWeight": 500,
          "fontFamily": "Inter",
          "color": "#C2613A",
          "align": "right",
          "width": 90,
          "opacity": 1,
          "letterSpacing": 0
        },
        {
          "id": "c376",
          "type": "rect",
          "x": 24,
          "y": 228,
          "width": 342,
          "height": 112,
          "fill": "#EDF2EE",
          "radius": 14,
          "opacity": 1
        },
        {
          "id": "c377",
          "type": "rect",
          "x": 24,
          "y": 228,
          "width": 4,
          "height": 112,
          "fill": "#C2613A",
          "radius": 2,
          "opacity": 1
        },
        {
          "id": "c378",
          "type": "text",
          "x": 38,
          "y": 240,
          "content": "\"The order that our mind imagines is like a net, or like a ladder, built to attain something. But afterward you must throw the ladder away.\"",
          "fontSize": 13,
          "fontWeight": 400,
          "fontFamily": "Georgia",
          "color": "#1C1814",
          "align": "left",
          "width": 314,
          "opacity": 1,
          "letterSpacing": 0
        },
        {
          "id": "c379",
          "type": "line",
          "x1": 38,
          "y1": 312,
          "x2": 352,
          "y2": 312,
          "stroke": "rgba(28,24,20,0.09)",
          "strokeWidth": 1
        },
        {
