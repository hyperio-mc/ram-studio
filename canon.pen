          "opacity": 1
        },
        {
          "id": "c384",
          "type": "text",
          "x": 38,
          "y": 362,
          "content": "\"Books are not made to be believed, but to be subjected to inquiry.\"",
          "fontSize": 13,
          "fontWeight": 400,
          "fontFamily": "Georgia",
          "color": "#1C1814",
