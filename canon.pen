          "y": 322,
          "content": "p.208 · day three",
          "fontSize": 11,
          "fontWeight": 400,
          "fontFamily": "Inter",
          "color": "rgba(28,24,20,0.42)",
          "align": "left",
          "width": 160,
          "opacity": 1,
          "letterSpacing": 0
        },
        {
          "id": "c381",
          "type": "text",
          "x": 266,
          "y": 322,
          "content": "Wittgenstein echoes.",
          "fontSize": 11,
          "fontWeight": 500,
          "fontFamily": "Inter",
          "color": "#C2613A",
          "align": "right",
          "width": 90,
          "opacity": 1,
