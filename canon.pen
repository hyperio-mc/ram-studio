          "opacity": 1
        },
        {
          "id": "c372",
          "type": "text",
          "x": 38,
          "y": 134,
          "content": "\"Stat rosa pristina nomine, nomina nuda tenemus.\" The rose of old is in its name; we hold bare names.",
          "fontSize": 13,
          "fontWeight": 400,
          "fontFamily": "Georgia",
          "color": "#1C1814",
          "align": "left",
          "width": 314,
          "opacity": 1,
          "letterSpacing": 0
        },
        {
          "id": "c373",
          "type": "line",
          "x1": 38,
          "y1": 190,
          "x2": 352,
          "y2": 190,
          "stroke": "rgba(28,24,20,0.09)",
          "strokeWidth": 1
        },
        {
