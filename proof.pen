      "textAlign": "left"
    },
    {
      "id": "el-128",
      "type": "text",
      "x": 16,
      "y": 1404,
      "content": "The solution",
      "fontSize": 13,
      "fontWeight": "700",
      "fontFamily": "Inter",
      "fill": "#0E1523",
      "textAlign": "left",
      "letterSpacing": 0.4
    },
    {
      "id": "el-129",
      "type": "text",
      "x": 16,
      "y": 1422,
      "content": "Ramp deployed an isolated payment vault with per-transaction runtime keys, reducing the blast radius of any single credential compromise from 40,000 cards to exactly one.",
      "fontSize": 13.5,
      "fontWeight": "400",
      "fontFamily": "Inter",
