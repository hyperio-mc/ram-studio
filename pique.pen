      "svg": "\n  <svg viewBox=\"0 0 390 844\" xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\">\n    <rect width=\"390\" height=\"844\" fill=\"#FDFAF6\"/>\n    \n    <text x=\"20\" y=\"26\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#2A1F1B\">9:41</text>\n    <g transform=\"translate(310,14)\" fill=\"#2A1F1B\">\n      <rect x=\"0\" y=\"2\" width=\"3\" height=\"7\" rx=\"1\" opacity=\"0.4\"/>\n      <rect x=\"5\" y=\"0\" width=\"3\" height=\"9\" rx=\"1\" opacity=\"0.6\"/>\n      <rect x=\"10\" y=\"-2\" width=\"3\" height=\"11\" rx=\"1\" opacity=\"0.9\"/>\n      <rect x=\"17\" y=\"1\" width=\"7\" height=\"5\" rx=\"1.5\" opacity=\"0.85\" fill=\"none\" stroke=\"#2A1F1B\" stroke-width=\"1.2\"/>\n      <rect x=\"18\" y=\"2\" width=\"4\" height=\"3\" rx=\"0.5\" opacity=\"0.85\"/>\n      <rect x=\"26\" y=\"2\" width=\"1.5\" height=\"3\" rx=\"0.8\" opacity=\"0.85\"/>\n    </g>\n    \n    <!-- back button -->\n    <circle cx=\"34\" cy=\"56\" r=\"18\" fill=\"#F5EFE8\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    <path d=\"M37 50 L31 56 L37 62\" stroke=\"#2A1F1B\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    \n    <!-- title -->\n    <text x=\"W/2\" y=\"50\" text-anchor=\"middle\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"16\" font-weight=\"600\" fill=\"#2A1F1B\" x=\"195\">Item Detail</text>\n    \n    <!-- share -->\n    <circle cx=\"356\" cy=\"56\" r=\"18\" fill=\"#F5EFE8\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    <path d=\"M351 58 L356 52 L361 58 M356 52 L356 64\" stroke=\"#2A1F1B\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    \n    <!-- main editorial photo with annotations -->\n    \n    <defs>\n      <linearGradient id=\"photo_0_78\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#C8AE94\"/>\n        <stop offset=\"100%\" stop-color=\"#9A7A