    {
      "id": "screen-style",
      "label": "Style Profile",
      "width": 390,
      "height": 844,
      "svg": "\n  <svg viewBox=\"0 0 390 844\" xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\">\n    <rect width=\"390\" height=\"844\" fill=\"#FDFAF6\"/>\n    \n    <text x=\"20\" y=\"26\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#2A1F1B\">9:41</text>\n    <g transform=\"translate(310,14)\" fill=\"#2A1F1B\">\n      <rect x=\"0\" y=\"2\" width=\"3\" height=\"7\" rx=\"1\" opacity=\"0.4\"/>\n      <rect x=\"5\" y=\"0\" width=\"3\" height=\"9\" rx=\"1\" opacity=\"0.6\"/>\n      <rect x=\"10\" y=\"-2\" width=\"3\" height=\"11\" rx=\"1\" opacity=\"0.9\"/>\n      <rect x=\"17\" y=\"1\" width=\"7\" height=\"5\" rx=\"1.5\" opacity=\"0.85\" fill=\"none\" stroke=\"#2A1F1B\" stroke-width=\"1.2\"/>\n      <rect x=\"18\" y=\"2\" width=\"4\" height=\"3\" rx=\"0.5\" opacity=\"0.85\"/>\n      <rect x=\"26\" y=\"2\" width=\"1.5\" height=\"3\" rx=\"0.8\" opacity=\"0.85\"/>\n    </g>\n    \n    <!-- header -->\n    <text x=\"20\" y=\"58\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"24\" font-weight=\"700\" fill=\"#2A1F1B\">Your Style</text>\n    <text x=\"20\" y=\"78\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"13\" fill=\"#8C7B73\">Updated this week</text>\n    \n    <!-- archetype card -->\n    <rect x=\"20\" y=\"92\" width=\"350\" height=\"110\" rx=\"18\" fill=\"#F5EFE8\"/>\n    <defs>\n      <linearGradient id=\"archetypeGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#C07A56\" stop-opacity=\"0.15\"/>\n        <stop offset=\"100%\" stop-color=\"#7BA897\" stop-opacity=\"0.08\"/>\n      </linearGradient>\n    </defs>\n    <rect x=\"20\" y=\"92\" width=\"350\" height=\"110\" rx=\"18\" fill=\"url(#archetypeGrad)\"/>\n    <text x=\"36\" y=\"122\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#C07A56\" letter-spacing=\"1\">YOUR ARCHETYPE</text>\n    <text x=\"36\" y=\"148\" font-family=