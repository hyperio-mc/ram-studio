600\" fill=\"#2A1F1B\">Linen Blend</text>\n    <text x=\"68\" y=\"208\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#8C7B73\">67% linen</text>\n  \n    \n    <!-- dot + ring -->\n    <circle cx=\"155\" cy=\"280\" r=\"12\" fill=\"#FDFAF6\" opacity=\"0.85\"/>\n    <circle cx=\"155\" cy=\"280\" r=\"7\" fill=\"#C07A56\"/>\n    <circle cx=\"155\" cy=\"280\" r=\"3\" fill=\"#FDFAF6\"/>\n    <!-- connector -->\n    <line x1=\"167\" y1=\"280\" x2=\"169\" y2=\"280\" stroke=\"#FDFAF6\" stroke-width=\"1\" opacity=\"0.7\"/>\n    <!-- tooltip -->\n    <rect x=\"169\" y=\"258\" width=\"130\" height=\"44\" rx=\"10\" fill=\"#FDFAF6\" opacity=\"0.92\"/>\n    <rect x=\"169\" y=\"258\" width=\"130\" height=\"44\" rx=\"10\" fill=\"none\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    <text x=\"181\" y=\"274\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#2A1F1B\">Pocket</text>\n    <text x=\"181\" y=\"288\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#8C7B73\">Patch detail</text>\n  \n    \n    <!-- bottom sheet panel -->\n    <rect x=\"0\" y=\"376\" width=\"390\" height=\"468\" rx=\"0\" fill=\"#FDFAF6\"/>\n    <!-- pull tab -->\n    <rect x=\"175\" y=\"386\" width=\"40\" height=\"4\" rx=\"2\" fill=\"#E5DDD5\"/>\n    \n    <!-- item name & price -->\n    <text x=\"20\" y=\"416\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"21\" font-weight=\"700\" fill=\"#2A1F1B\">Linen Safari Jacket</text>\n    <text x=\"20\" y=\"440\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"14\" fill=\"#8C7B73\">ARKET · Spring Collection 2026</text>\n    \n    <!-- price badge -->\n    <rect x=\"290\" y=\"403\" width=\"80\" height=\"30\" rx=\"15\" fill=\"#F5EFE8\"/>\n    <text x=\"330\" y=\"422\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"16\" font-weight=\"700\" fill=\"#C07A56\" text-anchor=\"middle\">£189</text>\n    \n    <!-- fabric pills -->\n    <