      "width": 390,
      "height": 844,
      "svg": "\n  <svg viewBox=\"0 0 390 844\" xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\">\n    <rect width=\"390\" height=\"844\" fill=\"#FDFAF6\"/>\n    \n    <text x=\"20\" y=\"26\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#2A1F1B\">9:41</text>\n    <g transform=\"translate(310,14)\" fill=\"#2A1F1B\">\n      <rect x=\"0\" y=\"2\" width=\"3\" height=\"7\" rx=\"1\" opacity=\"0.4\"/>\n      <rect x=\"5\" y=\"0\" width=\"3\" height=\"9\" rx=\"1\" opacity=\"0.6\"/>\n      <rect x=\"10\" y=\"-2\" width=\"3\" height=\"11\" rx=\"1\" opacity=\"0.9\"/>\n      <rect x=\"17\" y=\"1\" width=\"7\" height=\"5\" rx=\"1.5\" opacity=\"0.85\" fill=\"none\" stroke=\"#2A1F1B\" stroke-width=\"1.2\"/>\n      <rect x=\"18\" y=\"2\" width=\"4\" height=\"3\" rx=\"0.5\" opacity=\"0.85\"/>\n      <rect x=\"26\" y=\"2\" width=\"1.5\" height=\"3\" rx=\"0.8\" opacity=\"0.85\"/>\n    </g>\n    \n    <!-- header -->\n    <text x=\"20\" y=\"58\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"24\" font-weight=\"700\" fill=\"#2A1F1B\">Build Outfit</text>\n    <text x=\"20\" y=\"78\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"13\" fill=\"#8C7B73\">Occasion: Smart Casual</text>\n    \n    <!-- occasion chips -->\n    <rect x=\"20\" y=\"90\" width=\"100\" height=\"28\" rx=\"14\" fill=\"#C07A56\" opacity=\"0.12\" stroke=\"#C07A56\" stroke-width=\"1\"/>\n    <text x=\"70\" y=\"108\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" font-weight=\"600\" fill=\"#C07A56\" text-anchor=\"middle\">Smart Casual</text>\n    <rect x=\"130\" y=\"90\" width=\"72\" height=\"28\" rx=\"14\" fill=\"#F5EFE8\"/>\n    <text x=\"166\" y=\"108\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" text-anchor=\"middle\">Evening</text>\n    <rect x=\"212\" y=\"90\" width=\"70\" height=\"28\" rx=\"14\" fill=\"#F5EFE8\"/>\n    <text x=\"247\" y=\"108\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" text-anchor=\"middle\">Holiday</text>\n    \n    <!-- outfit canvas — central mannequin area -->\n    <rect x=\"20\" y=\"126\" width=\"350\" height=\"300\" rx=\"18\" fill=\"#F5EFE8\"/>\n    \n    <!-- layered items in outfit view -->\n    <!-- Item A: top -->\n    <rect x=\"90\" y=\"148\" width=\"210\" height=\"120\" rx=\"12\" fill=\"#EDE5D8\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    \n    <defs>\n      <linearGradient id=\"photo_90_148\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#C8AE94\"/>\n        <stop offset=\"100%\" stop-color=\"#9A7A6A\"/>\n      </linearGradient>\n    </defs>\n    <rect x=\"90\" y=\"148\" width=\"210\" height=\"120\" rx=\"0\" fill=\"url(#photo_90_148)\"/>\n    \n      <!-- jacket silhouette -->\n      <path d=\"M155 248 L150 178 L180 163 L195 173 L210 163 L240 178 L235 248Z\" fill=\"#FDFAF6\" opacity=\"0.12\"/>\n    \n  \n    <rect x=\"90\" y=\"148\" width=\"210\" height=\"120\" rx=\"12\" fill=\"none\" stroke=\"#C07A56\" stroke-width=\"2\"/>\n    <rect x=\"90\" y=\"148\" width=\"80\" height=\"22\" rx=\"11\" fill=\"#C07A56\"/>\n    <text x=\"130\" y=\"163\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#FDFAF6\" text-anchor=\"middle\">Linen Jacket</text>\n    \n    <!-- Item B: bottom -->\n    <rect x=\"90\" y=\"278\" width=\"100\" height=\"120\" rx=\"12\" fill=\"#EDE5D8\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    \n    <defs>\n      <linearGradient id=\"photo_90_278\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#D4C4A8\"/>\n        <stop offset=\"100%\" stop-color=\"#A89878\"/>\n      </linearGradient>\n    </defs>\n    <rect x=\"90\" y=\"278\" width=\"100\" height=\"120\" rx=\"0\" fill=\"url(#photo_90_278)\"/>\n    \n      <!-- dress silhouette -->\n      <path d=\"M115 298 L105 350 L90 378 L190 378 L175 350 L165 298 Q140 288 115 298Z\" fill=\"#FDFAF6\" opacity=\"0.12\"/>\n      <ellipse cx=\"140\" cy=\"298\" rx=\"20\" ry=\"18\" fill=\"#FDFAF6\" opacity=\"0.1\"/>\n    \n  \n    <rect x=\"90\" y=\"278\" width=\"100\" height=\"120\" rx=\"12\" fill=\"none\" stroke=\"#E5DDD5\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\"/>\n    \n    <!-- Item C: bag -->\n    <rect x=\"200\" y=\"278\" width=\"100\" height=\"120\" rx=\"12\" fill=\"#EDE5D8\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    \n    <defs>\n      <linearGradient id=\"photo_200_278\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#C4B0D8\"/>\n        <stop offset=\"100%\" stop-color=\"#8A7A9A\"/>\n      </linearGradient>\n    </defs>\n    <rect x=\"200\" y=\"278\" width=\"100\" height=\"120\" rx=\"0\" fill=\"url(#photo_200_278)\"/>\n    \n      <!-- bag silhouette -->\n      <rect x=\"215\" y=\"314\" width=\"70\" height=\"55\" rx=\"8\" fill=\"#FDFAF6\" opacity=\"0.12\"/>\n      <path d=\"M230 314 Q230 296 250 296 Q270 296 270 314\" stroke=\"#FDFAF6\" stroke-width=\"3\" fill=\"none\" opacity=\"0.15\"/>\n    \n  \n    \n    <!-- + add slot -->\n    <rect x=\"90\" y=\"416\" width=\"260\" height=\"0\" rx=\"12\" fill=\"none\"/>\n    \n    <!-- annotation pin on outfit -->\n    \n    <!-- dot + ring -->\n    <circle cx=\"190\" cy=\"185\" r=\"12\" fill=\"#FDFAF6\" opacity=\"0.85\"/>\n    <circle cx=\"190\" cy=\"185\" r=\"7\" fill=\"#C07A56\"/>\n    <circle cx=\"190\" cy=\"185\" r=\"3\" fill=\"#FDFAF6\"/>\n    <!-- connector -->\n    <line x1=\"202\" y1=\"185\" x2=\"204\" y2=\"185\" stroke=\"#FDFAF6\" stroke-width=\"1\" opacity=\"0.7\"/>\n    <!-- tooltip -->\n    <rect x=\"204\" y=\"163\" width=\"130\" height=\"44\" rx=\"10\" fill=\"#FDFAF6\" opacity=\"0.92\"/>\n    <rect x=\"204\" y=\"163\" width=\"130\" height=\"44\" rx=\"10\" fill=\"none\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    <text x=\"216\" y=\"179\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#2A1F1B\">Hero Piece</text>\n    <text x=\"216\" y=\"193\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#8C7B73\">Anchor this look</text>\n  \n    \n    <!-- compatibility score -->\n    <rect x=\"20\" y=\"440\" width=\"350\" height=\"68\" rx=\"16\" fill=\"#F5EFE8\"/>\n    <text x=\"36\" y=\"464\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" font-weight=\"600\" fill=\"#8C7B73\" letter-spacing=\"0.5\">OUTFIT HARMONY</text>\n    <rect x=\"36\" y=\"472\" width=\"254.2\" height=\"8\" rx=\"4\" fill=\"#E5DDD5\"/>\n    <rect x=\"36\" y=\"472\" width=\"254.2\" height=\"8\" rx=\"4\" fill=\"#7BA897\"/>\n    <text x=\"354\" y=\"480\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"14\" font-weight=\"700\" fill=\"#7BA897\" text-anchor=\"end\">82%</text>\n    <text x=\"36\" y=\"497\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\">Palette aligned · Occasion suitable · 1 suggestion</text>\n    \n    <!-- suggestions -->\n    <text x=\"20\" y=\"530\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#2A1F1B\">AI Suggestions</text>\n    \n    <!-- suggestion pill -->\n    <rect x=\"20\" y=\"540\" width=\"350\" height=\"56\" rx=\"14\" fill=\"#F5EFE8\"/>\n    <circle cx=\"46\" cy=\"568\" r=\"16\" fill=\"#C07A56\" opacity=\"0.15\"/>\n    <path d=\"M40 568 L52 568 M46 562 L46 574\" stroke=\"#C07A56\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n    <text x=\"70\" y=\"561\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"13\" font-weight=\"600\" fill=\"#2A1F1B\">Add tan sandals</text>\n    <text x=\"70\" y=\"578\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\">Completes the earthy palette story</text>\n    <text x=\"360\" y=\"571\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"20\" fill=\"#C07A56\" text-anchor=\"end\">+</text>\n    \n    <!-- save CTA -->\n    <rect x=\"20\" y=\"610\" width=\"350\" height=\"46\" rx=\"23\" fill=\"#C07A56\"/>\n    <text x=\"195\" y=\"637\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"15\" font-weight=\"700\" fill=\"#FDFAF6\" text-anchor=\"middle\">Save Outfit Look</text>\n    \n    <!-- nav -->\n    \n    <rect x=\"0\" y=\"761\" width=\"390\" height=\"83\" fill=\"#FDFAF6\"/>\n    <line x1=\"0\" y1=\"761\" x2=\"390\" y2=\"761\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    \n        <g transform=\"translate(36.75, 774)\">\n          <path d=\"M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z\" fill=\"#8C7B73\"/>\n        </g>\n        <text x=\"48.75\" y=\"798\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#8C7B73\" text-anchor=\"middle\" font-weight=\"400\">Discover</text>\n        \n      \n        <g transform=\"translate(134.25, 774)\">\n          <rect x=\"2\" y=\"2\" width=\"8\" height=\"8\" rx=\"1.5\" fill=\"#C07A56\"/><rect x=\"14\" y=\"2\" width=\"8\" height=\"8\" rx=\"1.5\" fill=\"#C07A56\"/><rect x=\"2\" y=\"14\" width=\"8\" height=\"8\" rx=\"1.5\" fill=\"#C07A56\"/><rect x=\"14\" y=\"14\" width=\"8\" height=\"8\" rx=\"1.5\" fill=\"#C07A56\"/>\n        </g>\n        <text x=\"146.25\" y=\"798\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#C07A56\" text-anchor=\"middle\" font-weight=\"600\">Wardrobe</text>\n        <rect x=\"134.25\" y=\"764\" width=\"24\" height=\"3\" rx=\"1.5\" fill=\"#C07A56\"/>\n      \n        <g transform=\"translate(231.75, 774)\">\n          <path d=\"M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z\" fill=\"#8C7B73\"/>\n        </g>\n        <text x=\"243.75\" y=\"798\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#8C7B73\" text-anchor=\"middle\" font-weight=\"400\">Style</text>\n        \n      \n        <g transform=\"translate(329.25, 774)\">\n          <circle cx=\"12\" cy=\"8\" r=\"4\" fill=\"#8C7B73\"/><path d=\"M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8\" stroke=\"#8C7B73\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\"/>\n        </g>\n        <text x=\"341.25\" y=\"798\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#8C7B73\" text-anchor=\"middle\" font-weight=\"400\">Me</text>\n        \n      \n    <rect x=\"147\" y=\"834\" width=\"96\" height=\"4\" rx=\"2\" fill=\"#2A1F1B\" opacity=\"0.15\"/>\n  \n  </svg>"
    }
  ]
}