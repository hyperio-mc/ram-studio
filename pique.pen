" fill=\"#C4B0D8\"/>\n        <text x=\"221.16666666666666\" y=\"306.3333333333333\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\" text-anchor=\"middle\">14%</text>\n      \n        <rect x=\"253.33333333333334\" y=\"238\" width=\"52.333333333333336\" height=\"52.333333333333336\" rx=\"10\" fill=\"#8A6A5A\"/>\n        <text x=\"279.5\" y=\"306.3333333333333\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\" text-anchor=\"middle\">10%</text>\n      \n        <rect x=\"311.6666666666667\" y=\"238\" width=\"52.333333333333336\" height=\"52.333333333333336\" rx=\"10\" fill=\"#2A1F1B\"/>\n        <text x=\"337.83333333333337\" y=\"306.3333333333333\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\" text-anchor=\"middle\">8%</text>\n      \n    \n    <!-- stats grid -->\n    <text x=\"20\" y=\"330\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#2A1F1B\">Style Intelligence</text>\n    \n    <!-- 4 stat cards -->\n    \n        <rect x=\"20\" y=\"342\" width=\"167\" height=\"102\" rx=\"16\" fill=\"#F5EFE8\"/>\n        <text x=\"40\" y=\"372\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" font-weight=\"500\">Pieces Saved</text>\n        <text x=\"40\" y=\"406\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"34\" font-weight=\"700\" fill=\"#C07A56\">24</text>\n        <text x=\"40\" y=\"428\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\">+3 this week</text>\n      \n        <rect x=\"203\" y=\"342\" width=\"167\" height=\"102\" rx=\"16\" fill=\"#F5EFE8\"/>\n        <text x=\"223\" y=\"372\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" font-weight=\"500\">Outfits Built</text>\n        <text x=\"223\" y=\"406\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"34\" font-weight=\"700\" fill=\"#7BA897\">6</text>\n        <text x=\"223\" y=\"428\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\">Complete looks</text>\n      \n        <rect x=\"20\" y=\"456\" width=\"167\" height=\"102\" rx=\"16\" fill=\"#F5EFE8\"/>\n        <text x=\"40\" y=\"486\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" font-weight=\"500\">Style Score</text>\n        <text x=\"40\" y=\"520\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"34\" font-weight=\"700\" fill=\"#D4A853\">91</text>\n        <text x=\"40\" y=\"542\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\">Top 12%</text>\n      \n        <rect x=\"203\" y=\"456\" width=\"167\" height=\"102\" rx=\"16\" fill=\"#F5EFE8\"/>\n        <text x=\"223\" y=\"486\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" font-weight=\"500\">Annotations</text>\n        <text x=\"223\" y=\"520\" font-family=\"SF Pro Display,Helvetica,sans-serif\" font-size=\"34\" font-weight=\"700\" fill=\"#C07A56\">47</text>\n        <text x=\"223\" y=\"542\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"11\" fill=\"#8C7B73\">Detail tags</text>\n      \n    \n    <!-- occasions radar -->\n    <text x=\"20\" y=\"582\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#2A1F1B\">Occasion Breakdown</text>\n    \n      <text x=\"20\" y=\"600\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"13\" fill=\"#2A1F1B\">Everyday</text>\n      <rect x=\"130\" y=\"590\" width=\"220\" height=\"8\" rx=\"4\" fill=\"#F5EFE8\"/>\n      <rect x=\"130\" y=\"590\" width=\"158.4\" height=\"8\" rx=\"4\" fill=\"#7BA897\"/>\n      <text x=\"370\" y=\"600\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" text-anchor=\"end\">72%</text>\n    \n      <text x=\"20\" y=\"632\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"13\" fill=\"#2A1F1B\">Smart Casual</text>\n      <rect x=\"130\" y=\"622\" width=\"220\" height=\"8\" rx=\"4\" fill=\"#F5EFE8\"/>\n      <rect x=\"130\" y=\"622\" width=\"121\" height=\"8\" rx=\"4\" fill=\"#7BA897\"/>\n      <text x=\"370\" y=\"632\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" text-anchor=\"end\">55%</text>\n    \n      <text x=\"20\" y=\"664\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"13\" fill=\"#2A1F1B\">Evening</text>\n      <rect x=\"130\" y=\"654\" width=\"220\" height=\"8\" rx=\"4\" fill=\"#F5EFE8\"/>\n      <rect x=\"130\" y=\"654\" width=\"83.6\" height=\"8\" rx=\"4\" fill=\"#7BA897\"/>\n      <text x=\"370\" y=\"664\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" text-anchor=\"end\">38%</text>\n    \n      <text x=\"20\" y=\"696\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"13\" fill=\"#2A1F1B\">Holiday</text>\n      <rect x=\"130\" y=\"686\" width=\"220\" height=\"8\" rx=\"4\" fill=\"#F5EFE8\"/>\n      <rect x=\"130\" y=\"686\" width=\"140.8\" height=\"8\" rx=\"4\" fill=\"#7BA897\"/>\n      <text x=\"370\" y=\"696\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"12\" fill=\"#8C7B73\" text-anchor=\"end\">64%</text>\n    \n    \n    <!-- nav -->\n    \n    <rect x=\"0\" y=\"761\" width=\"390\" height=\"83\" fill=\"#FDFAF6\"/>\n    <line x1=\"0\" y1=\"761\" x2=\"390\" y2=\"761\" stroke=\"#E5DDD5\" stroke-width=\"0.75\"/>\n    \n        <g transform=\"translate(36.75, 774)\">\n          <path d=\"M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z\" fill=\"#8C7B73\"/>\n        </g>\n        <text x=\"48.75\" y=\"798\" font-family=\"SF Pro Text,Helvetica,sans-serif\" font-size=\"10\" fill=\"#8C7B73\" text-anchor=\"middle\" font-weight=\"400\">Discover</text>\n        \n      \n        <g transform=\"translate(134.25, 774)\">\n          <rect x=\"2\" y=\"2\" width=\"8\" height=\"8\" rx=\"1.5\" fill=\"#8C7