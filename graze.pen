-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Top up, 500ml bottle</text>\n    <rect x=\"20\" y=\"614\" width=\"350\" height=\"46\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"30\" y=\"627\" width=\"20\" height=\"20\" fill=\"#7B9B6B\" rx=\"5\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"40\" y=\"641\" font-size=\"12\" fill=\"#FFFFFF\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">✓</text>\n    <text x=\"62\" y=\"638\" font-size=\"13\" fill=\"#9E978F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Sea salt flakes</text>\n    <text x=\"62\" y=\"652\" font-size=\"10\" fill=\"#9E978F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"0.7\">Maldon preferred</text>\n    <rect x=\"20\" y=\"668\" width=\"350\" height=\"46\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"30\" y=\"681\" width=\"20\" height=\"20\" fill=\"none\" rx=\"5\" opacity=\"1\" stroke=\"#E8E0D5\" stroke-width=\"1.5\"/>\n    <text x=\"62\" y=\"692\" font-size=\"13\" fill=\"#1A1818\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Greek yoghurt</text>\n    <text x=\"62\" y=\"706\" font-size=\"10\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">500g tub, full fat</text>\n    <rect x=\"20\" y=\"730\" width=\"350\" height=\"44\" fill=\"#E8E0D5\" rx=\"22\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"195\" y=\"757\" font-size=\"13\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">+ Add item manually</text>\n 