      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"300\" fill=\"#F2EDE3\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"160\" cy=\"140\" r=\"80\" fill=\"#C4714F\" opacity=\"0.12\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"240\" cy=\"180\" r=\"55\" fill=\"#7B9B6B\" opacity=\"0.1\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"90\" cy=\"200\" r=\"40\" fill=\"#C4714F\" opacity=\"0.08\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"195\" y=\"160\" font-size=\"52\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">🍋🌿🐓</text>\n    <circle cx=\"28\" cy=\"52\" r=\"18\" fill=\"#FFFFFF\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"28\" y=\"57\" font-size=\"16\" fill=\"#1A1818\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">←</text>\n    <circle cx=\"362\" cy=\"52\" r=\"18\" fill=\"#FFFFFF\" opacity=\"0.9\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"362\" y=\"58\" font-size=\"15\" fill=\"#C4714F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">♥</text>\n    <rect x=\"0\" y=\"280\" width=\"390\" height=\"564\" fill=\"#FFFFFF\" rx=\"20\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"24\" y=\"330\" font-size=\"28\" fill=\"#1A1818\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Lemon Herb</text>\n    <text x=\"24\" y=\"363\" font-size=\"28\" fill=\"#1A1818\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Roast Chicken</text>\n    <circle cx=\"8\" cy=\"0\" r=\"3\" fill=\"#7B9B6B\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"24\" y=\"388\" font-size=\"12\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">⏱ 1h 20m</text>\n    <text x=\"144\" y=\"388\" font-size=\"12\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">👥 4 servings</text>\n    <text x=\"264\" y=\"388\" font-size=\"12\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">★ 4.8 (312)</text>\n    <line x1=\"24\" y1=\"402\" x2=\"366\" y2=\"402\" stroke=\"#E8E0D5\" stroke-width=\"1\" opacity=\"1\"/>\n    <text x=\"24\" y=\"426\" font-size=\"13\" fill=\"#1A1818\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Ingredients</text>\n    <rect x=\"24\" y=\"430\" width=\"90\" height=\"2\" fill=\"#C4714F\" rx=\"1\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"130\" y=\"426\" font-size=\"13\" fill=\"#9E978F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Method</text>\n    <text x=\"210\" y=\"426\" font-size=\"13\" fill=\"#9E978F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Notes</text>\n    <rect x=\"24\" y=\"448\" width=\"342\" height=\"36\" fill=\"#FAF7F2\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"32\" y=\"470\" font-size=\"11\" fill=\"#C4714F\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">1 whole</text>\n    <text x=\"90\" y=\"470\" font-size=\"12\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">free-range chicken (1.8kg)</text>\n    <rect x=\"334\" y=\"456\" width=\"20\" height=\"20\" fill=\"#E8E0D5\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"24\" y=\"490\" width=\"342\" height=\"36\" fill=\"#FFFFFF\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"32\" y=\"512\" font-size=\"11\" fill=\"#C4714F\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">2</text>\n    <text x=\"90\" y=\"512\" font-size=\"12\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">unwaxed lemons, zested and halved</text>\n    <rect x=\"334\" y=\"498\" width=\"20\" height=\"20\" fill=\"#E8E0D5\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"24\" y=\"532\" width=\"342\" height=\"36\" fill=\"#FAF7F2\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"32\" y=\"554\" font-size=\"11\" fill=\"#C4714F\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">40g</text>\n    <text x=\"90\" y=\"554\" font-size=\"12\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">unsalted butter, softened</text>\n    <rect x=\"334\" y=\"540\" width=\"20\" height=\"20\" fill=\"#E8E0D5\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"24\" y=\"574\" width=\"342\" height=\"36\" fill=\"#FFFFFF\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"32\" y=\"596\" font-size=\"11\" fill=\"#C4714F\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">4 cloves</text>\n    <text x=\"90\" y=\"596\" font-size=\"12\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">garlic, crushed</text>\n    <rect x=\"334\" y=\"582\" width=\"20\" height=\"20\" fill=\"#E8E0D5\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"24\" y=\"616\" width=\"342\" height=\"36\" fill=\"#FAF7F2\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"32\" y=\"638\" font-size=\"11\" fill=\"#C4714F\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">1 bunch</text>\n    <text x=\"90\" y=\"638\" font-size=\"12\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">fresh thyme</text>\n    <rect x=\"334\" y=\"624\" width=\"20\" height=\"20\" fill=\"#E8E0D5\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"24\" y=\"658\" width=\"342\" height=\"36\" fill=\"#FFFFFF\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"32\" y=\"680\" font-size=\"11\" fill=\"#C4714F\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">2 tbsp</text>\n    <text x=\"90\" y=\"680\" font-size=\"12\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">olive oil, extra virgin</text>\n    <rect x=\"334\" y=\"666\" width=\"20\" height=\"20\" fill=\"#E8E0D5\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"24\" y=\"700\" width=\"342\" height=\"36\" fill=\"#FAF7F2\" rx=\"8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"32\" y=\"722\" font-size=\"11\" fill=\"#C4714F\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">1 tsp</text>\n    <text x=\"90\" y=\"722\" font-size=\"12\" fill=\"#1A1818\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">sea salt flakes</text>\n    <rect x=\"334\" y=\"708\" width=\"20\" height=\"20\" fill=\"#E8E0D5\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"24\" y=\"756\" width=\"342\" height=\"48\" fill=\"#C4714F\" rx=\"24\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"195\" y=\"785\" font-size=\"14\" fill=\"#FFFFFF\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Add to Grocery List</text>\n    <rect x=\"155\" y=\"818\" width=\"80\" height=\"4\" fill=\"#E8E0D5\" rx=\"2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n</svg>",
