>\n    <text x=\"62\" y=\"286\" font-size=\"10\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Ripe, for breakfast</text>\n    <rect x=\"20\" y=\"302\" width=\"350\" height=\"46\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"30\" y=\"315\" width=\"20\" height=\"20\" fill=\"none\" rx=\"5\" opacity=\"1\" stroke=\"#E8E0D5\" stroke-width=\"1.5\"/>\n    <text x=\"62\" y=\"326\" font-size=\"13\" fill=\"#1A1818\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Cherry tomatoes</text>\n    <text x=\"62\" y=\"340\" font-size=\"10\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">250g punnet</text>\n    <text x=\"20\" y=\"366\" font-size=\"10\" fill=\"#9E978F\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"2\" opacity=\"1\">PROTEIN</text>\n    <rect x=\"20\" y=\"378\" width=\"350\" height=\"46\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"30\" y=\"391\" width=\"20\" height=\"20\" fill=\"#7B9B6B\" rx=\"5\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"40\" y=\"405\" font-size=\"12\" fill=\"#FFFFFF\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">✓</text>\n    <text x=\"62\" y=\"402\" font-size=\"13\" fill=\"#9E978F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Whole chicken (1.8kg)</text>\n    <text x=\"62\" y=\"416\" font-size=\"10\" fill=\"#9E978F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"0.7\">Free-range preferred</text>\n    <rect x=\"20\" y=\"432\" width=\"350\" height=\"46\" fill=\"#FFFFFF\" rx=