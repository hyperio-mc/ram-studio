      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FAF7F2\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"20\" y=\"22\" font-size=\"13\" fill=\"#1A1818\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">9:41</text>\n    <text x=\"20\" y=\"58\" font-size=\"26\" fill=\"#1A1818\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Grocery List</text>\n    <text x=\"20\" y=\"78\" font-size=\"13\" fill=\"#5C5550\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">14 items · This week's meals</text>\n    <rect x=\"20\" y=\"90\" width=\"350\" height=\"6\" fill=\"#E8E0D5\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"20\" y=\"90\" width=\"199.49999999999997\" height=\"6\" fill=\"#7B9B6B\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"20\" y=\"108\" font-size=\"11\" fill=\"#9E978F\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">8 of 14 in cart</text>\n    <rect x=\"290\" y=\"44\" width=\"80\" height=\"32\" fill=\"#C4714F\" rx=\"16\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"330\" y=\"64\" font-size=\"11\" fill=\"#FFFFFF\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Share list</text>\n    <text x=\"20\" y=\"128\" font-size=\"10\" fill=\"#9E978F\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"2\" opacity=\"1\">PRODUCE</text>\n    <rect x=\"20\" y=\"140\" width=\"350\" height=\"46\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"30\" y=\"153\" width=