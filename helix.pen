          "type": "svg",
          "content": "\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#070710\"/>\n      \n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#070710\"/>\n    <text x=\"20\" y=\"26\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"14\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"start\">9:41</text>\n    <text x=\"370\" y=\"25\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"13\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"end\">⚡ 84%</text>\n\n      <!-- Header -->\n      <text x=\"20\" y=\"74\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#7B5CFF\" letter-spacing=\"3\">THIS WEEK</text>\n      <text x=\"20\" y=\"104\" font-family=\"Georgia,serif\" font-size=\"30\" font-weight=\"700\" fill=\"#E4E4F0\">Sleep Trends</text>\n      <text x=\"20\" y=\"126\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"rgba(228,228,240,0.4)\">Mar 31 – Apr 6  ·  7 nights</text>\n\n      <!-- Avg score -->\n      <rect x=\"20\" y=\"144\" width=\"350\" height=\"80\" fill=\"#0F0F1E\" rx=\"16\"/>\n      <text x=\"40\" y=\"170\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"2\">WEEKLY AVERAGE</text>\n      <text x=\"40\" y=\"208\" font-family=\"Georgia,serif\" font-size=\"40\" font-weight=\"700\" fill=\"#7B5CFF\">78.3</text>\n      <text x=\"116\" y=\"204\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"rgba(228,228,240,0.4)\">/ 100</text>\n      <text x=\"300\" y=\"196\" font-family=\"system-ui,sans-serif\" font-size=\"13\" fill=\"#2EE5C8\" text-anchor=\"end\">▲ +3.1 vs last week</text>\n\n      <!-- Bar chart section -->\n      <text x=\"20\" y=\"250\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"2\">NIGHTLY SCORES</text>\n\n      \n          <rect x=\"34\" y=\"180\" width=\"36\" height=\"160\" fill=\"#0F0F1E\" rx=\"8\"/>\n          <rect x=\"34\" y=\"221.6\" width=\"36\" height=\"118.4\" fill=\"#7B5CFF40\" rx=\"8\"/>\n          <text x=\"52\" y=\"215.6\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\">74</text>\n          <text x=\"52\" y=\"358\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" font-weight=\"400\">M</text>\n        \n          <rect x=\"80\" y=\"180\" width=\"36\" height=\"160\" fill=\"#0F0F1E\" rx=\"8\"/>\n          <rect x=\"80\" y=\"210.39999999999998\" width=\"36\" height=\"129.60000000000002\" fill=\"#7B5CFF40\" rx=\"8\"/>\n          <text x=\"98\" y=\"204.39999999999998\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\">81</text>\n          <text x=\"98\" y=\"358\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" font-weight=\"400\">T</text>\n        \n          <rect x=\"126\" y=\"180\" width=\"36\" height=\"160\" fill=\"#0F0F1E\" rx=\"8\"/>\n          <rect x=\"126\" y=\"229.60000000000002\" width=\"36\" height=\"110.39999999999999\" fill=\"#7B5CFF40\" rx=\"8\"/>\n          <text x=\"144\" y=\"223.60000000000002\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\">69</text>\n          <text x=\"144\" y=\"358\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" font-weight=\"400\">W</text>\n        \n          <rect x=\"172\" y=\"180\" width=\"36\" height=\"160\" fill=\"#0F0F1E\" rx=\"8\"/>\n          <rect x=\"172\" y=\"199.2\" width=\"36\" height=\"140.8\" fill=\"#7B5CFF40\" rx=\"8\"/>\n          <text x=\"190\" y=\"193.2\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\">88</text>\n          <text x=\"190\" y=\"358\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" font-weight=\"400\">T</text>\n        \n          <rect x=\"218\" y=\"180\" width=\"36\" height=\"160\" fill=\"#0F0F1E\" rx=\"8\"/>\n          <rect x=\"218\" y=\"218.4\" width=\"36\" height=\"121.6\" fill=\"#7B5CFF40\" rx=\"8\"/>\n          <text x=\"236\" y=\"212.4\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\">76</text>\n          <text x=\"236\" y=\"358\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" font-weight=\"400\">F</text>\n        \n          <rect x=\"264\" y=\"180\" width=\"36\" height=\"160\" fill=\"#0F0F1E\" rx=\"8\"/>\n          <rect x=\"264\" y=\"208.8\" width=\"36\" height=\"131.2\" fill=\"#7B5CFF40\" rx=\"8\"/>\n          <text x=\"282\" y=\"202.8\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\">82</text>\n          <text x=\"282\" y=\"358\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" font-weight=\"400\">S</text>\n        \n          <rect x=\"310\" y=\"180\" width=\"36\" height=\"160\" fill=\"#0F0F1E\" rx=\"8\"/>\n          <rect x=\"310\" y=\"215.2\" width=\"36\" height=\"124.80000000000001\" fill=\"#7B5CFF\" rx=\"8\"/>\n          <text x=\"328\" y=\"209.2\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#7B5CFF\" text-anchor=\"middle\">78</text>\n          <text x=\"328\" y=\"358\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"#7B5CFF\" text-anchor=\"middle\" font-weight=\"700\">S</text>\n        \n\n      <!-- Average line -->\n      <line x1=\"34\" y1=\"214.72000000000003\" x2=\"346\" y2=\"214.72000000000003\" stroke=\"#2EE5C8\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\"/>\n      <text x=\"360\" y=\"218.72000000000003\" font-family=\"system-ui,sans-serif\" font-size=\"10\" fill=\"#2EE5C8\">avg</text>\n\n      <!-- Metric rows -->\n      <text x=\"20\" y=\"390\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"2\">DEEP DIVE</text>\n\n      \n          <rect x=\"20\" y=\"404\" width=\"350\" height=\"58\" fill=\"#0F0F1E\" rx=\"12\"/>\n          <text x=\"40\" y=\"426\" font-family=\"system-ui,sans-serif\" font-size=\"12\" fill=\"rgba(228,228,240,0.4)\">Avg Deep Sleep</text>\n          <text x=\"350\" y=\"426\" font-family=\"system-ui,sans-serif\" font-size=\"13\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"end\">1h 42m</text>\n          <rect x=\"40\" y=\"436\" width=\"270\" height=\"6\" fill=\"#161628\" rx=\"3\"/>\n          <rect x=\"40\" y=\"436\" width=\"183.6\" height=\"6\" fill=\"#7B5CFF\" rx=\"3\"/>\n        \n          <rect x=\"20\" y=\"476\" width=\"350\" height=\"58\" fill=\"#0F0F1E\" rx=\"12\"/>\n          <text x=\"40\" y=\"498\" font-family=\"system-ui,sans-serif\" font-size=\"12\" fill=\"rgba(228,228,240,0.4)\">Avg REM</text>\n          <text x=\"350\" y=\"498\" font-family=\"system-ui,sans-serif\" font-size=\"13\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"end\">1h 51m</text>\n          <rect x=\"40\" y=\"508\" width=\"270\" height=\"6\" fill=\"#161628\" rx=\"3\"/>\n          <rect x=\"40\" y=\"508\" width=\"199.8\" height=\"6\" fill=\"#7B5CFF\" rx=\"3\"/>\n        \n          <rect x=\"20\" y=\"548\" width=\"350\" height=\"58\" fill=\"#0F0F1E\" rx=\"12\"/>\n          <text x=\"40\" y=\"570\" font-family=\"system-ui,sans-serif\" font-size=\"12\" fill=\"rgba(228,228,240,0.4)\">Consistency</text>\n          <text x=\"350\" y=\"570\" font-family=\"system-ui,sans-serif\" font-size=\"13\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"end\">±18 min</text>\n          <rect x=\"40\" y=\"580\" width=\"270\" height=\"6\" fill=\"#161628\" rx=\"3\"/>\n          <rect x=\"40\" y=\"580\" width=\"221.4\" height=\"6\" fill=\"#7B5CFF\" rx=\"3\"/>\n        \n\n      <!-- Best night callout -->\n      <rect x=\"20\" y=\"628\" width=\"350\" height=\"72\" fill=\"#0F0F1E\" rx=\"14\"/>\n      <rect x=\"20\" y=\"628\" width=\"350\" height=\"3\" fill=\"#F59E2B\" rx=\"1.5\"/>\n      <text x=\"40\" y=\"654\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#F59E2B\" letter-spacing=\"2\">BEST NIGHT</text>\n      <text x=\"40\" y=\"680\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"700\" fill=\"#E4E4F0\">Thursday  ·  Score 88</text>\n      <text x=\"350\" y=\"672\" font-family=\"system-ui,sans-serif\" font-size=\"24\" text-anchor=\"end\">🏆</text>\n\n      \n      <rect x=\"0\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"48.75\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">🌙</text>\n      <text x=\"48.75\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" letter-spacing=\"1\">TONIGHT</text>\n      \n    \n      <rect x=\"97.5\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"146.25\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">📈</text>\n      <text x=\"146.25\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"700\" fill=\"#7B5CFF\" text-anchor=\"middle\" letter-spacing=\"1\">TRENDS</text>\n      <rect x=\"130.25\" y=\"783\" width=\"32\" height=\"3\" fill=\"#7B5CFF\" rx=\"1.5\"/>\n    \n      <rect x=\"195\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"243.75\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">☀️</text>\n      <text x=\"243.75\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" letter-spacing=\"1\">WAKE</text>\n      \n    \n      <rect x=\"292.5\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"341.25\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">🎯</text>\n      <text x=\"341.25\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" letter-spacing=\"1\">GOALS</text>\n      \n    \n    </svg>"
        }
      ]
    },
    {
      "id": "s5",
      "name": "Goals",
