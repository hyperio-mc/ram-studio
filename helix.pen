          "type": "svg",
          "content": "\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#070710\"/>\n      \n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#070710\"/>\n    <text x=\"20\" y=\"26\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"14\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"start\">9:41</text>\n    <text x=\"370\" y=\"25\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"13\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"end\">⚡ 84%</text>\n\n      <!-- Ghost decorative waveform -->\n      <polyline points=\"0,214 20.526315789473685,211.25173628020903 41.05263157894737,216.8602267904535 61.578947368421055,219.7019002669873 82.10526315789474,218.95235635072794 102.63157894736842,223.26892893787095 123.15789473684211,233.5223319415289 143.68421052631578,237.15697247151675 164.21052631578948,225.08928360121192 184.73684210526318,207.29521492457914 205.26315789473685,202.86812678891783 225.78947368421052,216.2779091772966 246.31578947368422,232.0453423761463 266.8421052631579,234.8920637399332 287.36842105263156,227.37931298748043 307.89473684210526,222.07235525749365 328.42105263157896,222.18662870548266 348.94736842105266,219.64271046915613 369.47368421052636,211.70201039600215 390,208.90065895170486\" fill=\"none\" stroke=\"#7B5CFF\" stroke-width=\"1.5\" opacity=\"0.08\"/>\n      <polyline points=\"0,266.414709848079 20.526315789473685,265.2211467901957 41.05263157894737,252.43606142312564 61.578947368421055,239.8092640049063 82.10526315789474,238.61902108042818 102.63157894736842,248.53245975713338 123.15789473684211,258.7376317922707 143.68421052631578,259.74876651735724 164.21052631578948,252.98860397854222 184.73684210526318,248.04478928523673 205.26315789473685,251.15768434605548 225.78947368421052,258.0068578159509 246.31578947368422,258.8645346024635 266.8421052631579,250.28