          "visible": true,
          "locked": false,
          "type": "svg",
          "content": "\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#070710\"/>\n      \n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#070710\"/>\n    <text x=\"20\" y=\"26\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"14\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"start\">9:41</text>\n    <text x=\"370\" y=\"25\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"13\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"end\">⚡ 84%</text>\n\n      <!-- Header -->\n      <text x=\"20\" y=\"74\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#7B5CFF\" letter-spacing=\"3\">YOUR GOALS</text>\n      <text x=\"20\" y=\"104\" font-family=\"Georgia,serif\" font-size=\"30\" font-weight=\"700\" fill=\"#E4E4F0\">Sleep Setup</text>\n      <text x=\"20\" y=\"126\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"rgba(228,228,240,0.4)\">Personalise your targets</text>\n\n      <!-- Sleep duration goal -->\n      <text x=\"20\" y=\"162\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"2\">SLEEP DURATION GOAL</text>\n      <rect x=\"20\" y=\"172\" width=\"350\" height=\"80\" fill=\"#0F0F1E\" rx=\"16\"/>\n      <text x=\"40\" y=\"204\" font-family=\"Georgia,serif\" font-size=\"36\" font-weight=\"700\" fill=\"#7B5CFF\">7h 30m</text>\n      <text x=\"40\" y=\"222\" font-family=\"system-ui,sans-serif\" font-size=\"12\" fill=\"rgba(228,228,240,0.4)\">Recommended for your age group</text>\n      <!-- stepper -->\n      <rect x=\"280\" y=\"188\" width=\"40\" height=\"32\" fill=\"#161628\" rx=\"8\"/>\n      <text x=\"300\" y=\"209\" font-family=\"Georgia,serif\" font-size=\"20\" fill=\"#E4E4F0\" text-anchor=\"middle\">−</text>\n      <rect x=\"326\" y=\"188\" width=\"40\" height=\"32\" fill=\"#7B5CFF\" rx=\"8\"/>\n      <text x=\"346\" y=\"209\" font-family=\"Georgia,serif\" font-size=\"20\" fill=\"#fff\" text-anchor=\"middle\">+</text>\n\n      <!-- Bedtime / wake time -->\n      <text x=\"20\" y=\"278\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"2\">SCHEDULE</text>\n      <rect x=\"20\" y=\"288\" width=\"165\" height=\"80\" fill=\"#0F0F1E\" rx=\"14\"/>\n      <text x=\"40\" y=\"314\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"1\">BEDTIME</text>\n      <text x=\"40\" y=\"350\" font-family=\"Georgia,serif\" font-size=\"28\" font-weight=\"700\" fill=\"#E4E4F0\">10:30</text>\n      <text x=\"130\" y=\"342\" font-family=\"system-ui,sans-serif\" font-size=\"13\" fill=\"rgba(228,228,240,0.4)\">PM</text>\n\n      <rect x=\"205\" y=\"288\" width=\"165\" height=\"80\" fill=\"#0F0F1E\" rx=\"14\"/>\n      <text x=\"225\" y=\"314\" font-family=\"system-ui,sans-serif\" font-size=\"11\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"1\">WAKE TIME</text>\n      <text x=\"225\" y=\"350\" font-family=\"Georgia,serif\" font-size=\"28\" font-weight=\"700\" fill=\"#E4E4F0\">6:00</text>\n      <text x=\"285\" y=\"342\" font-family=\"system-ui,sans-serif\" font-size=\"13\" fill=\"rgba(228,228,240,0.4)\">AM</text>\n\n      <!-- Tracking toggles -->\n      <text x=\"20\" y=\"398\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"rgba(228,228,240,0.4)\" letter-spacing=\"2\">TRACKING</text>\n\n      \n          <rect x=\"20\" y=\"408\" width=\"350\" height=\"50\" fill=\"#0F0F1E\" rx=\"12\"/>\n          <text x=\"40\" y=\"437\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"#E4E4F0\">Heart Rate Monitor</text>\n          <!-- Toggle -->\n          <rect x=\"300\" y=\"422\" width=\"48\" height=\"24\" fill=\"#7B5CFF\" rx=\"12\"/>\n          <circle cx=\"336\" cy=\"434\" r=\"9\" fill=\"#fff\"/>\n        \n          <rect x=\"20\" y=\"468\" width=\"350\" height=\"50\" fill=\"#0F0F1E\" rx=\"12\"/>\n          <text x=\"40\" y=\"497\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"#E4E4F0\">HRV Analysis</text>\n          <!-- Toggle -->\n          <rect x=\"300\" y=\"482\" width=\"48\" height=\"24\" fill=\"#7B5CFF\" rx=\"12\"/>\n          <circle cx=\"336\" cy=\"494\" r=\"9\" fill=\"#fff\"/>\n        \n          <rect x=\"20\" y=\"528\" width=\"350\" height=\"50\" fill=\"#0F0F1E\" rx=\"12\"/>\n          <text x=\"40\" y=\"557\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"rgba(228,228,240,0.4)\">Snore Detection</text>\n          <!-- Toggle -->\n          <rect x=\"300\" y=\"542\" width=\"48\" height=\"24\" fill=\"#161628\" rx=\"12\"/>\n          <circle cx=\"316\" cy=\"554\" r=\"9\" fill=\"#fff\"/>\n        \n          <rect x=\"20\" y=\"588\" width=\"350\" height=\"50\" fill=\"#0F0F1E\" rx=\"12\"/>\n          <text x=\"40\" y=\"617\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"#E4E4F0\">Smart Wake Window</text>\n          <!-- Toggle -->\n          <rect x=\"300\" y=\"602\" width=\"48\" height=\"24\" fill=\"#7B5CFF\" rx=\"12\"/>\n          <circle cx=\"336\" cy=\"614\" r=\"9\" fill=\"#fff\"/>\n        \n\n      <!-- Streak badge -->\n      <rect x=\"20\" y=\"660\" width=\"350\" height=\"70\" fill=\"#0F0F1E\" rx=\"14\"/>\n      <rect x=\"20\" y=\"660\" width=\"350\" height=\"3\" fill=\"#2EE5C8\" rx=\"1.5\"/>\n      <text x=\"56\" y=\"690\" font-family=\"system-ui,sans-serif\" font-size=\"32\">🔥</text>\n      <text x=\"92\" y=\"686\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"700\" fill=\"#E4E4F0\">14-night streak</text>\n      <text x=\"92\" y=\"702\" font-family=\"system-ui,sans-serif\" font-size=\"12\" fill=\"rgba(228,228,240,0.4)\">Keep it up! Best ever: 21 nights</text>\n\n      \n      <rect x=\"0\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"48.75\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">🌙</text>\n      <text x=\"48.75\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" letter-spacing=\"1\">TONIGHT</text>\n      \n    \n      <rect x=\"97.5\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"146.25\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">📈</text>\n      <text x=\"146.25\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" letter-spacing=\"1\">TRENDS</text>\n      \n    \n      <rect x=\"195\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"243.75\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">☀️</text>\n      <text x=\"243.75\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\" letter-spacing=\"1\">WAKE</text>\n      \n    \n      <rect x=\"292.5\" y=\"786\" width=\"97.5\" height=\"58\" fill=\"#0F0F1E\"/>\n      <text x=\"341.25\" y=\"810\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"20\" text-anchor=\"middle\">🎯</text>\n      <text x=\"341.25\" y=\"830\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"10\" font-weight=\"700\" fill=\"#7B5CFF\" text-anchor=\"middle\" letter-spacing=\"1\">GOALS</text>\n      <rect x=\"325.25\" y=\"783\" width=\"32\" height=\"3\" fill=\"#7B5CFF\" rx=\"1.5\"/>\n    \n    </svg>"
        }
