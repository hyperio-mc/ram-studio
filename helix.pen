          "content": "\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#070710\"/>\n\n      <!-- Ambient glow -->\n      <ellipse cx=\"195\" cy=\"300\" rx=\"160\" ry=\"100\" fill=\"#7B5CFF\" opacity=\"0.04\"/>\n      <ellipse cx=\"195\" cy=\"300\" rx=\"100\" ry=\"60\" fill=\"#2EE5C8\" opacity=\"0.05\"/>\n\n      \n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#070710\"/>\n    <text x=\"20\" y=\"26\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"14\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"start\">9:41</text>\n    <text x=\"370\" y=\"25\" font-family=\"system-ui,-apple-system,sans-serif\" font-size=\"13\" font-weight=\"400\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"end\">⚡ 84%</text>\n\n      <!-- \"Recording\" pulse indicator -->\n      <circle cx=\"20\" cy=\"68\" r=\"5\" fill=\"#FF4F6A\"/>\n      <circle cx=\"20\" cy=\"68\" r=\"5\" fill=\"#FF4F6A\" opacity=\"0.3\">\n        <animate attributeName=\"r\" values=\"5;12;5\" dur=\"2s\" repeatCount=\"indefinite\"/>\n        <animate attributeName=\"opacity\" values=\"0.3;0;0.3\" dur=\"2s\" repeatCount=\"indefinite\"/>\n      </circle>\n      <text x=\"34\" y=\"73\" font-family=\"system-ui,sans-serif\" font-size=\"12\" font-weight=\"700\" fill=\"#FF4F6A\" letter-spacing=\"2\">TRACKING</text>\n\n      <!-- Stage label -->\n      <text x=\"195\" y=\"130\" font-family=\"system-ui,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#2EE5C8\" letter-spacing=\"3\" text-anchor=\"middle\">CURRENT STAGE</text>\n      <text x=\"195\" y=\"180\" font-family=\"Georgia,serif\" font-size=\"48\" font-weight=\"700\" fill=\"#E4E4F0\" text-anchor=\"middle\">REM</text>\n      <text x=\"195\" y=\"210\" font-family=\"system-ui,sans-serif\" font-size=\"14\" fill=\"rgba(228,228,240,0.4)\" text-anchor=\"middle\">Rapid Eye Movement · Cycle 2</text>\n\n      <!-- Timer -->\n      <