"height":32,"fill":"#0A200A","cornerRadius":16,"children":[{"type":"text","x":0,"y":9,"width":120,"height":16,"fill":"#39FF14","text":"🔥 12-DAY STREAK","fontSize":9,"fontWeight":700,"textAlign":"center","letterSpacing":1.5}]},{"type":"frame","x":0,"y":63,"width":1440,"height":1,"fill":"#182818"}]},{"type":"frame","x":48,"y":88,"width":640,"height":770,"fill":"#060E06","children":[{"type":"frame","x":0,"y":12,"width":180,"height":32,"fill":"transparent","children":[{"type":"frame","x":0,"y":4,"width":48,"height":24,"fill":"#39FF14","cornerRadius":2,"opacity":0.12},{"type":"text","x":0,"y":8,"width":48,"height":16,"fill":"#39FF14","text":"EX·01","fontSize":8,"fontWeight":700,"textAlign":"center","letterSpacing":1.5},{"type":"text","x":56,"y":8,"width":124,"height":16,"fill":"#4A7A4A","text":"WING I — THE FUNDAMENTALS","fontSize":8,"letterSpacing":2}]},{"type":"text","x":0,"y":54,"width":600,"height":56,"fill":"#E4EEE4","text":"Compound","fontSize":52,"fontWeight":700,"letterSpacing":-1},{"type":"text","x":0,"y":104,"width":600,"height":56,"fill":"#39FF14","text":"Interest","fontSize":52,"fontWeight":700,"letterSpacing":-1},{"type":"text","x":0,"y":168,"width":600,"height":14,"fill":"#4A7A4A","opacity":0.7,"text":"THE EIGHTH WONDER OF THE WORLD","fontSize":8,"letterSpacing":3},{"type":"frame","x":0,"y":188,"width":600,"height":1,"fill":"#182818"},{"type":"text","x":0,"y":204,"width":600,"height":22,"fill":"#E4EEE4","text":"What is it?","fontSize":14,"fontWeight":700},{"type":"text","x":0,"y":232,"width":600,"height":52,"fill":"#4A7A4A","text":"When you earn interest on both your initial deposit and all the interest you've already earned, your money begins to multiply — slowly at first, then explosively over time. This is compound interest.","fontSize":12,"letterSpacing":0.2},{"type":"text","x":0,"y":296,"width":600,"height":22,"fill":"#E4EEE4","text":"Why does it matter?","fontSize":14,"fontWeight":700},{"type":"text","x":0,"y":322,"width":600,"height":52,"fill":"#4A7A4A","text":"A single $10,000 deposit at 8% annual return becomes $100,600 after 30 years — without adding another dollar. The early years feel slow. The final decade is where the magic happens.","fontSize":12,"letterSpacing":0.2},{"type":"text","x":0,"y":386,"width":600,"height":22,"fill":"#E4EEE4","text":"The golden rule: time > amount.","fontSize":14,"fontWeight":700},{"type":"text","x":0,"y":410,"width":600,"height":52,"fill":"#4A7A4A","text":"A 25-year-old investing $200/month for 40 years ends with more than a 35-year-old investing $400/month for 30 years — despite contributing half the capital. Start early, even small.","fontSize":12,"letterSpacing":0.2},{"type":"frame","x":0,"y":476,"width":180,"height":48,"fill":"#39FF14","cornerRadius":4,"children":[{"type":"text","x":0,"y":14,"width":180,"height":20,"fill":"#060E06","text":"TAKE THE QUIZ  →","fontSize":11,"fontWeight":700,"textAlign":"center","letterSpacing":2.5}]},{"type":"frame","x":188,"y":476,"width":140,"height":48,"fill":"#0D1A0D","cornerRadius":4,"children":[{"type":"text","x":0,"y":14,"width":140,"height":20,"fill":"#4A7A4A","text":"BOOKMARK ☆","fontSize":11,"textAlign":"center","letterSpacing":2}]}]},{"type":"frame","x":720,"y":88,"width":672,"height":770,"fill":"#060E06","children":[{"type":"frame","x":0,"y":0,"width":672,"height":280,"fill":"#0D1A0D","cornerRadius":4,"children":[{"type":"text","x":24,"y":20,"width":400,"height":14,"fill":"#4A7A4A","text":"$10,000 AT 8% ANNUAL RETURN","fontSize":8,"fontWeight":700,"letterSpacing":2},{"type":"text","x":24,"y":38,"width":400,"height":14,"fill":"#39FF14","text":"30-YEAR COMPOUND GROWTH","fontSize":8,"letterSpacing":1.5},{"type":"frame","x":0,"y":60,"width":672,"height":1,"fill":"#182818"},{"type":"frame","x":24,"y":62,"width":64,"height":240,"fill":"transparent","children":[{"type":"frame","x":8,"y":218,"width":48,"height":22,"fill":"#182818","cornerRadius":3},{"type":"text","x":0,"y":244,"width":64,"height":16,"fill":"#4A7A4A","text":"0Y","fontSize