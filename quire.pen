8\" fill=\"#F2EDE3\" rx=\"2\" opacity=\"1\"/><rect x=\"22\" y=\"536\" width=\"52\" height=\"52\" fill=\"#EEF2FF\" rx=\"2\" opacity=\"1\"/><text x=\"48\" y=\"566\" font-size=\"24\" fill=\"#1D4ED8\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"middle\" opacity=\"1\">T</text><rect x=\"22\" y=\"536\" width=\"52\" height=\"14\" fill=\"#1D4ED8\" rx=\"2\" opacity=\"0.15\"/><text x=\"22\" y=\"603\" font-size=\"9\" fill=\"#1D4ED8\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" letter-spacing=\"1\" opacity=\"1\">Tech</text><text x=\"22\" y=\"617\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"600\" font-family=\"Georgia, serif\" opacity=\"1\">Why open-source</text><text x=\"22\" y=\"631\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"600\" font-family=\"Georgia, serif\" opacity=\"1\">won the AI race</text><rect x=\"203\" y=\"534\" width=\"167\" height=\"88\" fill=\"#F2EDE3\" rx=\"2\" opacity=\"1\"/><rect x=\"205\" y=\"536\" width=\"52\" height=\"52\" fill=\"#EAF4EE\" rx=\"2\" opacity=\"1\"/><text x=\"231\" y=\"566\" font-size=\"24\" fill=\"#2D6A4F\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"middle\" opacity=\"1\">E</text><text x=\"205\" y=\"603\" font-size=\"9\" fill=\"#2D6A4F\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" letter-spacing=\"1\" opacity=\"1\">Environ</text><text x=\"205\" y=\"617\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"600\" font-family=\"Georgia, serif\" opacity=\"1\">The river cities</text><text x=\"205\" y=\"631\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"600\" font-family=\"Georgia, serif\" opacity=\"1\">that refused to flood</text><rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" fill=\"#FFFFFF\" opacity=\"1\"/><line x1=\"0\" y1=\"764\" x2=\"390\" y2=\"764\" stroke=\"rgba(28,25,23,0.08)\" stroke-width=\"1\" opacity=\"1\"/><circle cx=\"48\" cy=\"792\" r=\"10\" fill=\"#EDE6D8\" opacity=\"1\"/><text x=\"48\" y=\"800\" font-size=\"14\" fill=\"#1C1917\" font-weight=\"400\"