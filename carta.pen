              "type": "raw",
              "html": "<div style=\"padding:0 14px\">\n              \n                <div style=\"background:#FFFDF8;border:1px solid #D8D0BF;border-radius:12px;padding:14px;margin-bottom:10px;box-shadow:0 1px 3px rgba(26,21,16,0.08), 0 4px 12px rgba(26,21,16,0.06)\">\n                  <div style=\"display:flex;gap:12px;align-items:flex-start\">\n                    <div style=\"width:56px;height:83.5820895522388px;background:#5A3D3D;border-radius:3px;display:flex;flex-direction:column;justify-content:center;align-items:center;flex-shrink:0;box-shadow:1px 2px 6px rgba(0,0,0,0.15)\">\n    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15.680000000000001px;color:rgba(255,255,255,0.9);font-weight:400;letter-spacing:1px\">I</div>\n  </div>\n                    <div style=\"flex:1\">\n                      <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15px;color:#1A1510;font-style:italic;margin-bottom:2px\">Intermezzo</div>\n                      <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:11px;color:#6B5E4A;margin-bottom:6px\">Sally Rooney</div>\n                      <div style=\"margin-bottom:6px\"><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">Literary Fiction</span><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">Contemporary</span></div>\n                      <div style=\"display:flex;align-items:center;gap:4px\">\n                        <div style=\"width:3px;height:3px;border-radius:50%;background:#8B3B1F\"></div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:#8B3B1F\">Because you loved Normal People</div>\n                      </div>\n                    </div>\n                    <div style=\"font-size:16px;color:#D8D0BF\">+</div>\n                  </div>\n                </div>\n              \n                <div style=\"background:#FFFDF8;border:1px solid #D8D0BF;border-radius:12px;padding:14px;margin-bottom:10px;box-shadow:0 1px 3px rgba(26,21,16,0.08), 0 4px 12px rgba(26,21,16,0.06)\">\n                  <div style=\"display:flex;gap:12px;align-items:flex-start\">\n                    <div style=\"width:56px;height:83.5820895522388px;background:#4A3D2A;border-radius:3px;display:flex;flex-direction:column;justify-content:center;align-items:center;flex-shrink:0;box-shadow:1px 2px 6px rgba(0,0,0,0.15)\">\n    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15.680000000000001px;color:rgba(255,255,255,0.9);font-weight:400;letter-spacing:1px\">TW</div>\n  </div>\n                    <div style=\"flex:1\">\n                      <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15px;color:#1A1510;font-style:italic;margin-bottom:2px\">The Women</div>\n                      <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:11px;color:#6B5E4A;margin-bottom:6px\">Kristin Hannah</div>\n                      <div style=\"margin-bottom:6px\"><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">Historical Fiction</span><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">War</span></div>\n                      <div style=\"display:flex;align-items:center;gap:4px\">\n                        <div style=\"width:3px;height:3px;border-radius:50%;background:#8B3B1F\"></div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:#8B3B1F\">Trending in your network</div>\n                      </div>\n                    </div>\n                    <div style=\"font-size:16px;color:#D8D0BF\">+</div>\n                  </div>\n                </div>\n              \n                <div style=\"background:#FFFDF8;border:1px solid #D8D0BF;border-radius:12px;padding:14px;margin-bottom:10px;box-shadow:0 1px 3px rgba(26,21,16,0.08), 0 4px 12px rgba(26,21,16,0.06)\">\n                  <div style=\"display:flex;gap:12px;align-items:flex-start\">\n                    <div style=\"width:56px;height:83.5820895522388px;background:#3D4A5C;border-radius:3px;display:flex;flex-direction:column;justify-content:center;align-items:center;flex-shrink:0;box-shadow:1px 2px 6px rgba(0,0,0,0.15)\">\n    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15.680000000000001px;color:rgba(255,255,255,0.9);font-weight:400;letter-spacing:1px\">AF</div>\n  </div>\n                    <div style=\"flex:1\">\n                      <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15px;color:#1A1510;font-style:italic;margin-bottom:2px\">All Fours</div>\n                      <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:11px;color:#6B5E4A;margin-bottom:6px\">Miranda July</div>\n                      <div style=\"margin-bottom:6px\"><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">Literary Fiction</span><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">Feminist</span></div>\n                      <div style=\"display:flex;align-items:center;gap:4px\">\n                        <div style=\"width:3px;height:3px;border-radius:50%;background:#8B3B1F\"></div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:#8B3B1F\">Booker longlist 2025</div>\n                      </div>\n                    </div>\n                    <div style=\"font-size:16px;color:#D8D0BF\">+</div>\n                  </div>\n                </div>\n              \n                <div style=\"background:#FFFDF8;border:1px solid #D8D0BF;border-radius:12px;padding:14px;margin-bottom:10px;box-shadow:0 1px 3px rgba(26,21,16,0.08), 0 4px 12px rgba(26,21,16,0.06)\">\n                  <div style=\"display:flex;gap:12px;align-items:flex-start\">\n                    <div style=\"width:56px;height:83.5820895522388px;background:#3D5A4A;border-radius:3px;display:flex;flex-direction:column;justify-content:center;align-items:center;flex-shrink:0;box-shadow:1px 2px 6px rgba(0,0,0,0.15)\">\n    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15.680000000000001px;color:rgba(255,255,255,0.9);font-weight:400;letter-spacing:1px\">O</div>\n  </div>\n                    <div style=\"flex:1\">\n                      <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:15px;color:#1A1510;font-style:italic;margin-bottom:2px\">Orbital</div>\n                      <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:11px;color:#6B5E4A;margin-bottom:6px\">Samantha Harvey</div>\n                      <div style=\"margin-bottom:6px\"><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">Literary Fiction</span><span style=\"display:inline-block;background:#EDE8DC;color:#6B5E4A;border:1px solid #D8D0BF;border-radius:4px;padding:3px 8px;font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;font-weight:500;letter-spacing:0.5px;margin-right:5px;margin-bottom:5px\">Short</span></div>\n                      <div style=\"display:flex;align-items:center;gap:4px\">\n                        <div style=\"width:3px;height:3px;border-radius:50%;background:#8B3B1F\"></div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:#8B3B1F\">Booker Prize winner</div>\n                      </div>\n                    </div>\n                    <div style=\"font-size:16px;color:#D8D0BF\">+</div>\n                  </div>\n                </div>\n              \n            </div>"
            }
          ]
        }
      ]
