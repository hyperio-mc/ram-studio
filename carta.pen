          "children": [
            {
              "type": "raw",
              "html": "<div style=\"padding:20px 18px 14px\">\n              <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:26px;color:#1A1510;font-style:italic;margin-bottom:4px\">Notes</div>\n              <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:12px;color:#6B5E4A\">47 highlights across 23 books</div>\n            </div>"
            },
            {
              "type": "raw",
              "html": "<div style=\"padding:0 14px\">\n              \n                <div style=\"background:#FFFDF8;border:1px solid #D8D0BF;border-radius:12px;overflow:hidden;margin-bottom:12px;box-shadow:0 1px 3px rgba(26,21,16,0.08), 0 4px 12px rgba(26,21,16,0.06)\">\n                  <div style=\"height:3px;background:#3B4F6B\"></div>\n                  <div style=\"padding:16px\">\n                    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:16px;color:#1A1510;line-height:1.55;font-style:italic;margin-bottom:12px\">\"I looked out upon the Hall of the Heart-Shaped Column. The light had a quality of late afternoon — golden, slow, with dust motes rising.\"</div>\n                    <div style=\"display:flex;align-items:center;gap:8px\">\n                      <div style=\"width:28px;height:41.7910447761194px;background:#3B4F6B;border-radius:3px;display:flex;flex-direction:column;justify-content:center;align-items:center;flex-shrink:0;box-shadow:1px 2px 6px rgba(0,0,0,0.15)\">\n    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:7.840000000000001px;color:rgba(255,255,255,0.9);font-weight:400;letter-spacing:1px\">P</div>\n  </div>\n                      <div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:11px;color:#1A1510;font-weight:500\">Piranesi</div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:#6B5E4A\">Susanna Clarke · p.124</div>\n                      </div>\n                      <div style=\"margin-left:auto;font-family:'JetBrains Mono', 'Courier New', monospace;font-size:10px;color:rgba(26,21,16,0.4)\">Mar 20</div>\n                    </div>\n                  </div>\n                </div>\n              \n                <div style=\"background:#FFFDF8;border:1px solid #D8D0BF;border-radius:12px;overflow:hidden;margin-bottom:12px;box-shadow:0 1px 3px rgba(26,21,16,0.08), 0 4px 12px rgba(26,21,16,0.06)\">\n                  <div style=\"height:3px;background:#7A5C3A\"></div>\n                  <div style=\"padding:16px\">\n                    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:16px;color:#1A1510;line-height:1.55;font-style:italic;margin-bottom:12px\">\"The world has become exhausting in its demands upon the soul. We forget we have one.\"</div>\n                    <div style=\"display:flex;align-items:center;gap:8px\">\n                      <div style=\"width:28px;height:41.7910447761194px;background:#7A5C3A;border-radius:3px;display:flex;flex-direction:column;justify-content:center;align-items:center;flex-shrink:0;box-shadow:1px 2px 6px rgba(0,0,0,0.15)\">\n    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:7.840000000000001px;color:rgba(255,255,255,0.9);font-weight:400;letter-spacing:1px\">J</div>\n  </div>\n                      <div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:11px;color:#1A1510;font-weight:500\">James</div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:#6B5E4A\">Percival Everett · p.89</div>\n                      </div>\n                      <div style=\"margin-left:auto;font-family:'JetBrains Mono', 'Courier New', monospace;font-size:10px;color:rgba(26,21,16,0.4)\">Mar 10</div>\n                    </div>\n                  </div>\n                </div>\n              \n                <div style=\"background:#FFFDF8;border:1px solid #D8D0BF;border-radius:12px;overflow:hidden;margin-bottom:12px;box-shadow:0 1px 3px rgba(26,21,16,0.08), 0 4px 12px rgba(26,21,16,0.06)\">\n                  <div style=\"height:3px;background:#3D4F3A\"></div>\n                  <div style=\"padding:16px\">\n                    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:16px;color:#1A1510;line-height:1.55;font-style:italic;margin-bottom:12px\">\"What small things can make the world turn over. What small things have always made the world turn over.\"</div>\n                    <div style=\"display:flex;align-items:center;gap:8px\">\n                      <div style=\"width:28px;height:41.7910447761194px;background:#3D4F3A;border-radius:3px;display:flex;flex-direction:column;justify-content:center;align-items:center;flex-shrink:0;box-shadow:1px 2px 6px rgba(0,0,0,0.15)\">\n    <div style=\"font-family:'Georgia', 'Times New Roman', serif;font-size:7.840000000000001px;color:rgba(255,255,255,0.9);font-weight:400;letter-spacing:1px\">ST</div>\n  </div>\n                      <div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:11px;color:#1A1510;font-weight:500\">Small Things Like These</div>\n                        <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:#6B5E4A\">Claire Keegan · p.112</div>\n                      </div>\n                      <div style=\"margin-left:auto;font-family:'JetBrains Mono', 'Courier New', monospace;font-size:10px;color:rgba(26,21,16,0.4)\">Mar 3</div>\n                    </div>\n                  </div>\n                </div>\n              \n            </div>"
            },
            {
              "type": "raw",
              "html": "<div style=\"margin:0 14px\">\n              <div style=\"background:#EDE8DC;border:1.5px dashed #D8D0BF;border-radius:12px;padding:16px;text-align:center\">\n                <div style=\"font-size:20px;margin-bottom:6px\">📖</div>\n                <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:12px;color:#6B5E4A;font-weight:500;margin-bottom:2px;line-height:1.5\">Add a highlight or note</div>\n                <div style=\"font-family:'Inter', 'Helvetica Neue', sans-serif;font-size:10px;color:rgba(26,21,16,0.4);font-weight:400;margin-bottom:0;line-height:1.5\">Capture what moved you</div>\n              </div>\n            </div>"
            }
