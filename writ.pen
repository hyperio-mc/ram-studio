      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 390 844\" width=\"390\" height=\"844\"><rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#090807\" opacity=\"1\"/><rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#090807\" opacity=\"1\"/><text x=\"20\" y=\"28\" font-size=\"13\" fill=\"#9A9082\" font-weight=\"500\" font-family=\"DM Mono, sans-serif\">9:41</text><rect x=\"340\" y=\"16\" width=\"22\" height=\"11\" fill=\"none\" rx=\"2\" stroke=\"#5A5248\" stroke-width=\"1.5\" opacity=\"1\"/><rect x=\"342\" y=\"18\" width=\"14\" height=\"7\" fill=\"#5A5248\" rx=\"1\" opacity=\"1\"/><rect x=\"364\" y=\"20\" width=\"3\" height=\"4\" fill=\"#5A5248\" rx=\"1\" opacity=\"1\"/><circle cx=\"322\" cy=\"22\" r=\"3\" fill=\"#5A5248\" opacity=\"1\"/><circle cx=\"314\" cy=\"22\" r=\"3\" fill=\"#5A5248\" opacity=\"1\"/><circle cx=\"306\" cy=\"22\" r=\"3\" fill=\"#5A5248\" opacity=\"1\"/><rect x=\"0\" y=\"44\" width=\"390\" height=\"48\" fill=\"#090807\" opacity=\"1\"/><text x=\"20\" y=\"72\" font-size=\"13\" fill=\"#9A9082\" font-weight=\"500\" font-family=\"Inter, sans-serif\">← Signals</text><text x=\"370\" y=\"72\" font-size=\"13\" fill=\"#E8855A\" font-family=\"Inter, sans-serif\" text-anchor=\"end\">Share</text><line x1=\"0\" y1=\"92\" x2=\"390\" y2=\"92\" stroke=\"#2A2520\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"20\" y=\"116\" font-size=\"10\" fill=\"#E8855A\" font-weight=\"700\" font-family=\"DM Mono, sans-serif\">MACRO ANALYSIS</text><text x=\"370\" y=\"116\" font-size=\"10\" fill=\"#5A5248\" font-family=\"DM Mono, sans-serif\" text-anchor=\"end\">APR 08 · 07:32</text><text x=\"20\" y=\"150\" font-size=\"32\" fill=\"#F0EAE0\" font-weight=\"800\" font-family=\"Inter, sans-serif\">Fed Signals</text><text x=\"20\" y=\"184\" font-size=\"32\" fill=\"#F0EAE0\" font-weight=\"800\" font-family=\"Inter, sans-serif\">Pause on</text><text x=\"20\" y=\"218\" font-size=\"32\" fill=\"#F0EAE0\" font-weight=\"800\" font-family=\"Inter, sans-serif\">Rate Cuts</text><rect x=\"20\" y=\"226\" width=\"44\" height=\"3\" fill=\"#D4602A\" rx=\"1.5\" opacity=\"1\"/><rect x=\"68\" y=\"227.5\" width=\"302\" height=\"1\" fill=\"#2A2520\" opacity=\"1\"/><circle cx=\"20\" cy=\"248\" r=\"10\" fill=\"#231F19\" opacity=\"1\"/><text x=\"20\" y=\"252\" font-size=\"8\" fill=\"#9A9082\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">R</text><text x=\"36\" y=\"252\" font-size=\"11\" fill=\"#5A5248\" font-family=\"Inter, sans-serif\">Reuters Wire · Analyzed by Writ AI</text><text x=\"20\" y=\"270\" font-size=\"11\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">6 min read</text><rect x=\"118\" y=\"262\" width=\"60\" height=\"20\" fill=\"rgba(154,46,46,0.25)\" rx=\"10\" opacity=\"1\"/><text x=\"148\" y=\"275.42\" font-size=\"9\" fill=\"#9A2E2E\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\">● BEARISH</text><text x=\"20\" y=\"296\" font-size=\"13\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">Federal Reserve Chair Jerome Powell indicated</text><text x=\"20\" y=\"314\" font-size=\"13\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">Wednesday that the central bank is in no hurry</text><text x=\"20\" y=\"332\" font-size=\"13\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">to resume cutting rates, as inflation data remains</text><text x=\"20\" y=\"350\" font-size=\"13\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">above target for a third consecutive quarter.</text><rect x=\"16\" y=\"366\" width=\"358\" height=\"70\" fill=\"#D4602A\" rx=\"10\" opacity=\"0.08\"/><rect x=\"16\" y=\"366\" width=\"3\" height=\"70\" fill=\"#D4602A\" rx=\"2\" opacity=\"1\"/><text x=\"28\" y=\"388\" font-size=\"13\" fill=\"#E8855A\" font-weight=\"600\" font-family=\"Inter, sans-serif\">&quot;The economy is strong enough that we</text><text x=\"28\" y=\"406\" font-size=\"13\" fill=\"#E8855A\" font-weight=\"600\" font-family=\"Inter, sans-serif\">can afford to be patient.&quot;</text><text x=\"28\" y=\"428\" font-size=\"10\" fill=\"#5A5248\" font-family=\"Inter, sans-serif\">— Jerome Powell, April 8 2026</text><text x=\"20\" y=\"452\" font-size=\"13\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">10-year Treasury yields surged 18 basis points</text><text x=\"20\" y=\"470\" font-size=\"13\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">following the remarks. Rate-sensitive sectors sold</text><text x=\"20\" y=\"488\" font-size=\"13\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">off sharply in after-hours trading.</text><text x=\"20\" y=\"512\" font-size=\"10\" fill=\"#5A5248\" font-weight=\"700\" font-family=\"DM Mono, sans-serif\">KEY DATA</text><line x1=\"20\" y1=\"520\" x2=\"370\" y2=\"520\" stroke=\"#2A2520\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"20\" y=\"544\" font-size=\"11\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">10Y Treasury Yield</text><text x=\"370\" y=\"544\" font-size=\"11\" fill=\"#9A2E2E\" font-weight=\"600\" font-family=\"DM Mono, sans-serif\" text-anchor=\"end\">+18bps</text><line x1=\"20\" y1=\"556\" x2=\"370\" y2=\"556\" stroke=\"#2A2520\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"20\" y=\"576\" font-size=\"11\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">Fed Funds Target</text><text x=\"370\" y=\"576\" font-size=\"11\" fill=\"#9A9082\" font-weight=\"600\" font-family=\"DM Mono, sans-serif\" text-anchor=\"end\">4.75–5.00%</text><line x1=\"20\" y1=\"588\" x2=\"370\" y2=\"588\" stroke=\"#2A2520\" stroke-width=\"0.5\" opacity=\"1\" stroke-linecap=\"round\"/><text x=\"20\" y=\"608\" font-size=\"11\" fill=\"#9A9082\" font-family=\"Inter, sans-serif\">PCE Inflation (Feb)</text><text x=\"370\" y=\"608\" font-size=\"11\" fill=\"#E8855A\" font-weight=\"600\" font-family=\"DM Mono, sans-serif\" text-anchor=\"end\">+2.7% YoY</text><line x1=\"20\" y1=\"620\" x2=\"370\" y2=\"620\" stroke=\"#2A2520\" stroke-width=\"0.