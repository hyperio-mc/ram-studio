if\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">total</text>\n    <rect x=\"135\" y=\"220\" width=\"105\" height=\"78\" fill=\"#FFF1EC\" rx=\"12\" opacity=\"1\" stroke=\"none\" stroke-width=\"1\"/>\n    <text x=\"149\" y=\"238\" font-size=\"8\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">STREAK</text>\n    <text x=\"149\" y=\"272\" font-size=\"28\" fill=\"#C2410C\" font-weight=\"700\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">21</text>\n    <text x=\"149\" y=\"288\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">days</text>\n    <rect x=\"250\" y=\"220\" width=\"105\" height=\"78\" fill=\"#FFFFFF\" rx=\"12\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <text x=\"264\" y=\"238\" font-size=\"8\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">WORDS</text>\n    <text x=\"264\" y=\"272\" font-size=\"28\" fill=\"#1C1917\" font-weight=\"700\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">14k</text>\n    <text x=\"264\" y=\"288\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">written</text>\n    <line x1=\"20\" y1=\"310\" x2=\"370\" y2=\"310\" stroke=\"#E7E1D8\" stroke-width=\"1\" opacity=\"1\"/>\n    <text x=\"20\" y=\"328\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">PREFERENCES</text>\n    <rect x=\"