<line x1=\"36\" y1=\"306\" x2=\"354\" y2=\"306\" stroke=\"#E7E1D8\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n    <line x1=\"36\" y1=\"332\" x2=\"354\" y2=\"332\" stroke=\"#E7E1D8\" stroke-width=\"0.5\" opacity=\"0.5\"/>\n    <text x=\"354\" y=\"320\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">143</text>\n    <text x=\"36\" y=\"320\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">tap to continue writing...</text>\n    <text x=\"20\" y=\"350\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">MOOD</text>\n    <circle cx=\"56\" cy=\"376\" r=\"18\" fill=\"#E57373\" opacity=\"0.3\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"56\" y=\"403\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">rough</text>\n    <circle cx=\"110\" cy=\"376\" r=\"18\" fill=\"#FFAB76\" opacity=\"0.3\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"110\" y=\"403\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">low</text>\n    <circle cx=\"164\" cy=\"376\" r=\"18\" fill=\"#F4CC72\" opacity=\"0.3\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"164\" y=\"403\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">okay</text>\n    <circle cx=\"218\" cy=\"376\" r=\"18\" fill=\"#81C784\" opacity=\"1\" stroke=\"none\" stroke-width=\"0