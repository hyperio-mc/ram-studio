      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 390 844\" width=\"390\" height=\"844\">\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FAF8F4\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#FFFFFF\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"20\" y=\"28\" font-size=\"14\" fill=\"#1C1917\" font-weight=\"600\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">9:41</text>\n    <rect x=\"335\" y=\"18\" width=\"32\" height=\"12\" fill=\"#1C1917\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"336\" y=\"19\" width=\"28\" height=\"10\" fill=\"#FFFFFF\" rx=\"2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"337\" y=\"20\" width=\"18\" height=\"8\" fill=\"#1C1917\" rx=\"1\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"367\" y=\"21\" width=\"3\" height=\"6\" fill=\"#1C1917\" rx=\"1\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"320\" cy=\"24\" r=\"5\" fill=\"none\" opacity=\"1\" stroke=\"#1C1917\" stroke-width=\"1.5\"/>\n    <circle cx=\"320\" cy=\"24\" r=\"3\" fill=\"#1C1917\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"306\" cy=\"24\" r=\"5\" fill=\"none\" opacity=\"1\" stroke=\"#1C1917\" stroke-width=\"1.5\"/>\n    <circle cx=\"306\" cy=\"24\" r=\"2\" fill=\"#1C1917\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"0\" y=\"44\" width=\"390\" height=\"60\" fill=\"#FAF8F4\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"24\" y=\"76\" font-size=\"28\" fill=\"#1C1917\" font-weight=\"700\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">mote</text>\n    <text x=\"24\" y=\"96\" font-size=\"12\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.02em\" opacity=\"1\">Thursday, April 10</text>\n    <circle cx=\"356\" cy=\"72\" r=\"22\" fill=\"#F4F0E8\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"356\" cy=\"72\" r=\"22\" fill=\"none\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <text x=\"356\" y=\"78\" font-size=\"13\" fill=\"#78716C\" font-weight=\"600\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">RK</text>\n    <rect x=\"20\" y=\"112\" width=\"350\" height=\"148\" fill=\"#FFFFFF\" rx=\"14\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <rect x=\"20\" y=\"112\" width=\"3\" height=\"148\" fill=\"#C2410C\" rx=\"2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"38\" y=\"138\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">HOW ARE YOU FEELING?</text>\n    <circle cx=\"60\" cy=\"188\" r=\"20\" fill=\"#E57373\" opacity=\"0.25\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"60\" y=\"224\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">rough</text>\n    <circle cx=\"108\" cy=\"188\" r=\"20\" fill=\"#FFAB76\" opacity=\"0.25\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"108\" y=\"224\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">low</text>\n    <circle cx=\"156\" cy=\"188\" r=\"20\" fill=\"#F4CC72\" opacity=\"0.25\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"156\" y=\"224\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">okay</text>\n    <circle cx=\"204\" cy=\"188\" r=\"26\" fill=\"#81C784\" opacity=\"0.15\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"204\" cy=\"188\" r=\"20\" fill=\"#81C784\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <circle cx=\"204\" cy=\"188\" r=\"20\" fill=\"none\" opacity=\"1\" stroke=\"#81C784\" stroke-width=\"2\"/>\n    <text x=\"204\" y=\"224\" font-size=\"9\" fill=\"#81C784\" font-weight=\"600\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">good</text>\n    <circle cx=\"256\" cy=\"188\" r=\"20\" fill=\"#4D7C5C\" opacity=\"0.25\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"256\" y=\"224\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">great</text>\n    <text x=\"38\" y=\"246\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">last checked 2 min ago</text>\n    <rect x=\"20\" y=\"272\" width=\"165\" height=\"84\" fill=\"#FFFFFF\" rx=\"14\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <text x=\"36\" y=\"294\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">STREAK</text>\n    <text x=\"36\" y=\"329\" font-size=\"38\" fill=\"#C2410C\" font-weight=\"700\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">21</text>\n    <text x=\"36\" y=\"346\" font-size=\"10\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">days in a row</text>\n    <rect x=\"197\" y=\"272\" width=\"173\" height=\"84\" fill=\"#EEF5F1\" rx=\"14\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <text x=\"213\" y=\"294\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">TODAY</text>\n    <text x=\"213\" y=\"329\" font-size=\"38\" fill=\"#4D7C5C\" font-weight=\"700\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">3</text>\n    <text x=\"213\" y=\"346\" font-size=\"10\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">moments captured</text>\n    <line x1=\"20\" y1=\"368\" x2=\"370\" y2=\"368\" stroke=\"#E7E1D8\" stroke-width=\"1\" opacity=\"1\"/>\n    <text x=\"20\" y=\"385\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.12em\" opacity=\"1\">RECENT MOMENTS</text>\n    <rect x=\"20\" y=\"396\" width=\"350\" height=\"96\" fill=\"#FFFFFF\" rx=\"12\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <rect x=\"20\" y=\"396\" width=\"3\" height=\"96\" fill=\"#81C784\" rx=\"1.5\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"36\" y=\"414\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">8:42 AM</text>\n    <circle cx=\"356\" cy=\"412\" r=\"5\" fill=\"#81C784\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"36\" y=\"432\" font-size=\"13\" fill=\"#1C1917\" font-weight=\"500\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Finally finished the Murakami novel.</text>\n    <text x=\"36\" y=\"450\" font-size=\"12\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">A quiet sense of completion, like setting down weight.</text>\n    <rect x=\"36\" y=\"462\" width=\"36\" height=\"18\" fill=\"#F4F0E8\" rx=\"9\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"54\" y=\"474\" font-size=\"9\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">books</text>\n    <rect x=\"20\" y=\"506\" width=\"350\" height=\"96\" fill=\"#FFFFFF\" rx=\"12\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <rect x=\"20\" y=\"506\" width=\"3\" height=\"96\" fill=\"#F4CC72\" rx=\"1.5\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"36\" y=\"524\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">12:15 PM</text>\n    <circle cx=\"356\" cy=\"522\" r=\"5\" fill=\"#F4CC72\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"36\" y=\"542\" font-size=\"13\" fill=\"#1C1917\" font-weight=\"500\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Lunch alone with the window open.</text>\n    <text x=\"36\" y=\"560\" font-size=\"12\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Street sounds, coffee cooling. Ordinary and enough.</text>\n    <rect x=\"36\" y=\"572\" width=\"60\" height=\"18\" fill=\"#F4F0E8\" rx=\"9\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"66\" y=\"584\" font-size=\"9\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">stillness</text>\n    <rect x=\"20\" y=\"616\" width=\"350\" height=\"96\" fill=\"#FFFFFF\" rx=\"12\" opacity=\"1\" stroke=\"#E7E1D8\" stroke-width=\"1\"/>\n    <rect x=\"20\" y=\"616\" width=\"3\" height=\"96\" fill=\"#4D7C5C\" rx=\"1.5\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"36\" y=\"634\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">3:30 PM</text>\n    <circle cx=\"356\" cy=\"632\" r=\"5\" fill=\"#4D7C5C\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"36\" y=\"652\" font-size=\"13\" fill=\"#1C1917\" font-weight=\"500\" font-family=\"Georgia, \"Times New Roman\", serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Call with Mia — laughed properly for the first time this week.</text>\n    <text x=\"36\" y=\"670\" font-size=\"12\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Connection feels different when it surprises you.</text>\n    <rect x=\"36\" y=\"682\" width=\"42\" height=\"18\" fill=\"#F4F0E8\" rx=\"9\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"57\" y=\"694\" font-size=\"9\" fill=\"#78716C\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">people</text>\n    <rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" fill=\"#FFFFFF\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <line x1=\"0\" y1=\"764\" x2=\"390\" y2=\"764\" stroke=\"#E7E1D8\" stroke-width=\"1\" opacity=\"1\"/>\n    <rect x=\"48\" y=\"776\" width=\"20\" height=\"16\" fill=\"none\" rx=\"2\" opacity=\"1\" stroke=\"#C2410C\" stroke-width=\"1.5\"/>\n    <rect x=\"53\" y=\"784\" width=\"10\" height=\"8\" fill=\"#C2410C\" rx=\"1\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"58\" y=\"818\" font-size=\"10\" fill=\"#C2410C\" font-weight=\"600\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.04em\" opacity=\"1\">today</text>\n    <circle cx=\"147\" cy=\"784\" r=\"10\" fill=\"none\" opacity=\"1\" stroke=\"#A8A29E\" stroke-width=\"1.5\"/>\n    <line x1=\"147\" y1=\"776\" x2=\"147\" y2=\"792\" stroke=\"#A8A29E\" stroke-width=\"1.5\" opacity=\"1\"/>\n    <line x1=\"139\" y1=\"784\" x2=\"155\" y2=\"784\" stroke=\"#A8A29E\" stroke-width=\"1.5\" opacity=\"1\"/>\n    <text x=\"147\" y=\"818\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.04em\" opacity=\"1\">add</text>\n    <rect x=\"234\" y=\"777\" width=\"18\" height=\"15\" fill=\"none\" rx=\"2\" opacity=\"1\" stroke=\"#A8A29E\" stroke-width=\"1.5\"/>\n    <line x1=\"237\" y1=\"775\" x2=\"237\" y2=\"779\" stroke=\"#A8A29E\" stroke-width=\"1.5\" opacity=\"1\"/>\n    <line x1=\"249\" y1=\"775\" x2=\"249\" y2=\"779\" stroke=\"#A8A29E\" stroke-width=\"1.5\" opacity=\"1\"/>\n    <line x1=\"237\" y1=\"784\" x2=\"249\" y2=\"784\" stroke=\"#A8A29E\" stroke-width=\"1\" opacity=\"1\"/>\n    <line x1=\"237\" y1=\"788\" x2=\"247\" y2=\"788\" stroke=\"#A8A29E\" stroke-width=\"1\" opacity=\"1\"/>\n    <text x=\"243\" y=\"818\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"\"Helvetica Neue\", Arial, system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.04em\" opacity=\"1\">archive</text>\n    <circle cx=\"336\" cy=\"780\" r=\"7\" fill=\"none\" opacity=\"1\" stroke=\"#A8A29E\" stroke-width=\"1.5\"/>\n    <rect x=\"325\" y=\"789\" width=\"22\" height=\"7\" fill=\"none\" rx=\"3\" opacity=\"1\" stroke=\"#A8A29E\" stroke-width=\"1.5\"/>\n    <text x=\"336\" y=\"818\" font-size=\"10\" fill=\"#A8A29E\" font-weight=\"400\" fo