ke-width=\"0.75\"/>\n      <text x=\"32\" y=\"92\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" letter-spacing=\"2\" fill=\"#D4781A\">✦ SOL INTELLIGENCE · APR 1</text>\n      <text x=\"32\" y=\"114\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"15.5\" fill=\"#1C1611\" style=\"font-style:italic\">Your energy is climbing. Three</text>\n      <text x=\"32\" y=\"134\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"15.5\" fill=\"#1C1611\" style=\"font-style:italic\">patterns are working for you.</text>\n      <rect x=\"32\" y=\"148\" width=\"326\" height=\"1\" fill=\"#EDE4D0\"/>\n      <circle cx=\"44\" cy=\"162\" r=\"3\" fill=\"#E8A020\"/>\n      <text x=\"54\" y=\"166\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#A8937A\">Updated based on last 14 days of data</text>\n\n      <!-- Weekly chart card -->\n      <rect x=\"16\" y=\"194\" width=\"358\" height=\"140\" rx=\"20\" fill=\"#FFFCF5\" filter=\"url(#warmShadow)\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <text x=\"32\" y=\"218\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" letter-spacing=\"1.5\" fill=\"#A8937A\">ENERGY THIS WEEK</text>\n\n      <!-- Bar chart -->\n      \n          <rect x=\"32\" y=\"268.4\" width=\"50\" height=\"49.6\" rx=\"5\"\n            fill=\"rgba(232,160,32,0.2)\"/>\n          <text x=\"57\" y=\"332\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"middle\" fill=\"#A8937A\">M</text>\n          <text x=\"57\" y=\"264.4\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"8.5\" text-anchor=\"middle\" fill=\"#A8937A\" opacity=\"0.7\">62</text>\n        \n          <rect x=\"86\" y=\"255.6\" width=\"50\" height=\"62.400000000000006\" rx=\"5\"\n            fill=\"rgba(232,160,32,0.2)\"/>\n          <text x=\"111\" y=\"332\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"middle\" fill=\"#A8937A\">T</text>\n          <text x=\"111\" y=\"251.6\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"8.5\" text-anchor=\"middle\" fill=\"#A8937A\" opacity=\"0.7\">78</text>\n        \n          <rect x=\"140\" y=\"274\" width=\"50\" height=\"44\" rx=\"5\"\n            fill=\"url(#amberGrad)\"/>\n          <text x=\"165\" y=\"332\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"middle\" fill=\"#D4781A\">W</text>\n          <text x=\"165\" y=\"270\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"8.5\" text-anchor=\"middle\" fill=\"#D4781A\" opacity=\"0.7\">55</text>\n        \n          <rect x=\"194\" y=\"247.6\" width=\"50\" height=\"70.4\" rx=\"5\"\n            fill=\"rgba(232,160,32,0.2)\"/>\n          <text x=\"219\" y=\"332\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"middle\" fill=\"#A8937A\">T</text>\n          <text x=\"219\" y=\"243.6\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"8.5\" text-anchor=\"middle\" fill=\"#A8937A\" opacity=\"0.7\">88</text>\n        \n          <rect x=\"248\" y=\"245.2\" width=\"50\" height=\"72.8\" rx=\"5\"\n            fill=\"rgba(232,160,32,0.2)\"/>\n          <text x=\"273\" y=\"332\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"middle\" fill=\"#A8937A\">F</text>\n          <text x=\"273\" y=\"241.2\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"8.5\" text-anchor=\"middle\" fill=\"#A8937A\" opacity=\"0.7\">91</text>\n        \n          <rect x=\"302\" y=\"259.6\" width=\"50\" height=\"58.4\" rx=\"5\"\n            fill=\"rgba(232,160,32,0.2)\"/>\n          <text x=\"327\" y=\"332\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"middle\" fill=\"#A8937A\">S</text>\n          <text x=\"327\" y=\"255.6\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"8.5\" text-anchor=\"middle\" fill=\"#A8937A\" opacity=\"0.7\">73</text>\n        \n          <rect x=\"356\" y=\"265.2\" width=\"50\" height=\"52.800000000000004\" rx=\"5\"\n            fill=\"rgba(232,160,32,0.2)\"/>\n          <text x=\"381\" y=\"332\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"middle\" fill=\"#A8937A\">S</text>\n          <text x=\"381\" y=\"261.2\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"8.5\" text-anchor=\"middle\" fill=\"#A8937A\" opacity=\"0.7\">66</text>\n        \n\n      <!-- Pattern cards -->\n      <text x=\"22\" y=\"354\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" letter-spacing=\"1.5\" fill=\"#A8937A\">KEY PATTERNS</text>\n\n      \n        <rect x=\"16\" y=\"366\" width=\"358\" height=\"88\" rx=\"18\" fill=\"rgba(232,160,32,0.08)\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n        <text x=\"38\" y=\"400\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"20\">☀</text>\n        <text x=\"70\" y=\"396\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" font-weight=\"600\" fill=\"#E8A020\">Early sunlight → +18% energy</text>\n        <text x=\"70\" y=\"414\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">Days you get 10+ min sunlight before 8am s</text>\n        <text x=\"70\" y=\"430\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">core 18 points higher on average.</text>\n        <rect x=\"16\" y=\"466\" width=\"358\" height=\"88\" rx=\"18\" fill=\"rgba(90,138,106,0.08)\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n        <text x=\"38\" y=\"500\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"20\">🏃</text>\n        <text x=\"70\" y=\"496\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" font-weight=\"600\" fill=\"#5A8A6A\">Movement drives mental clarity</text>\n        <text x=\"70\" y=\"514\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">Your mental energy score peaks 2h after mo</text>\n        <text x=\"70\" y=\"530\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">rning walks. Skip days show 31% lower focus.</text>\n        <rect x=\"16\" y=\"566\" width=\"358\" height=\"88\" rx=\"18\" fill=\"rgba(232,112,112,0.08)\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n        <text x=\"38\" y=\"600\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"20\">📓</text>\n        <text x=\"70\" y=\"596\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" font-weight=\"600\" fill=\"#E87070\">Journaling predicts deep work</text>\n        <text x=\"70\" y=\"614\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">Journaling correlates 0.78 with entering f</text>\n        <text x=\"70\" y=\"630\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">low state before noon. Strongest signal found.</text>\n\n      <!-- Recommendation -->\n      <rect x=\"16\" y=\"668\" width=\"358\" height=\"62\" rx=\"16\" fill=\"url(#amberGrad)\"/>\n      <text x=\"32\" y=\"693\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" letter-spacing=\"1.5\" fill=\"rgba(255,255,255,0.7)\">✦ RECOMMENDATION</text>\n      <text x=\"32\" y=\"713\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"13\" font-weight=\"600\" fill=\"white\">Complete journaling before 8:30am today</text>\n\n      \n  <g id=\"bottomnav\">\n    <rect x=\"0\" y=\"748\" width=\"390\" height=\"96\" fill=\"rgba(255,252,245,0.72)\" opacity=\"1\"/>\n    <path d=\"M0,748 h390\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n    \n        <g transform=\"translate(21,758)\">\n          <path d=\"M8,14 L8,6 L18,0 L28,6 L28,14 Z\" stroke=\"#A8937A\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\"/>\n               <rect x=\"13\" y=\"8\" width=\"10\" height=\"6\" rx=\"1\" stroke=\"#A8937A\" stroke-width=\"1.2\" fill=\"none\"/>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Today</text>\n          \n        </g>\n        <g transform=\"translate(99,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">☀</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Ritual</text>\n          \n        </g>\n        <g transform=\"translate(177,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#D4781A\">✦</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#D4781A\">Insight</text>\n          <circle cx=\"18\" cy=\"34\" r=\"2\" fill=\"#E8A020\"/>\n        </g>\n        <g transform=\"translate(255,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">◷</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Schedule</text>\n          \n        </g>\n        <g transform=\"translate(333,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">◎</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Reflect</text>\n          \n        </g>\n  </g>\n      <rect x=\"148\" y=\"824\" width=\"94\" height=\"4\" rx=\"2\" fill=\"#1C1611\" opacity=\"0.25\"/>\n    </g>\n  </svg>"
