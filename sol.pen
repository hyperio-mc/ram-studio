      "svg": "\n  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    \n  <defs>\n    <linearGradient id=\"bgGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#FDF8F0\"/>\n      <stop offset=\"60%\" stop-color=\"#FEF4E4\"/>\n      <stop offset=\"100%\" stop-color=\"#FBF0E2\"/>\n    </linearGradient>\n    <linearGradient id=\"amberGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#E8A020\"/>\n      <stop offset=\"100%\" stop-color=\"#D4781A\"/>\n    </linearGradient>\n    <linearGradient id=\"sageGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#5A8A6A\"/>\n      <stop offset=\"100%\" stop-color=\"#3D6B50\"/>\n    </linearGradient>\n    <linearGradient id=\"goldGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#F5C842\" stop-opacity=\"0.6\"/>\n      <stop offset=\"100%\" stop-color=\"#E8A020\" stop-opacity=\"0\"/>\n    </linearGradient>\n    <linearGradient id=\"cardGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"rgba(255,252,245,0.95)\"/>\n      <stop offset=\"100%\" stop-color=\"rgba(254,242,214,0.85)\"/>\n    </linearGradient>\n    <filter id=\"warmShadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"130%\">\n      <feDropShadow dx=\"0\" dy=\"4\" stdDeviation=\"12\" flood-color=\"rgba(139,110,70,0.12)\"/>\n    </filter>\n    <filter id=\"softGlow\">\n      <feGaussianBlur stdDeviation=\"18\" result=\"blur\"/>\n      <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\"/>\n    </filter>\n    <clipPath id=\"screenClip\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"40\"/>\n    </clipPath>\n  </defs>\n    <g clip-path=\"url(#screenClip)\">\n      <!-- Warm base -->\n      <rect width=\"390\" height=\"844\" fill=\"url(#bgGrad)\"/>\n      <!-- Ambient light orb top-right -->\n      <circle cx=\"340\" cy=\"120\" r=\"160\" fill=\"#F5C842\" opacity=\"0.12\" filter=\"url(#softGlow)\"/>\n      <circle cx=\"60\"  cy=\"520\" r=\"100\" fill=\"#5A8A6A\"  opacity=\"0.06\" filter=\"url(#softGlow)\"/>\n\n      \n  <g id=\"statusbar\">\n    <text x=\"20\" y=\"22\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"600\" fill=\"#1C1611\">9:41</text>\n    <g transform=\"translate(310,10)\">\n      <!-- Signal -->\n      <rect x=\"0\" y=\"7\" width=\"3\" height=\"5\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"5\" y=\"5\" width=\"3\" height=\"7\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"10\" y=\"3\" width=\"3\" height=\"9\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"15\" y=\"1\" width=\"3\" height=\"11\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- WiFi -->\n      <path d=\"M28,11 Q33,6 38,11\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <path d=\"M30,13.5 Q33,10 36,13.5\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <circle cx=\"33\" cy=\"16\" r=\"1.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- Battery -->\n      <rect x=\"45\" y=\"5\" width=\"22\" height=\"12\" rx=\"3\" stroke=\"#1C1611\" stroke-width=\"1.2\" fill=\"none\" opacity=\"0.9\"/>\n      <rect x=\"67\" y=\"8\" width=\"2.5\" height=\"6\" rx=\"1\" fill=\"#1C1611\" opacity=\"0.6\"/>\n      <rect x=\"46.5\" y=\"6.5\" width=\"16\" height=\"9\" rx=\"2\" fill=\"#1C1611\" opacity=\"0.9\"/>\n    </g>\n  </g>\n\n      <!-- Header -->\n      <text x=\"22\" y=\"58\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"13\" fill=\"#A8937A\" letter-spacing=\"2\">WEDNESDAY · APR 1</text>\n      <text x=\"22\" y=\"86\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"32\" font-style=\"italic\" fill=\"#1C1611\">Good morning,</text>\n      <text x=\"22\" y=\"116\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"32\" font-weight=\"700\" fill=\"#1C1611\">Rakis ✦</text>\n\n      <!-- Energy Gauge Card -->\n      <rect x=\"16\" y=\"130\" width=\"358\" height=\"200\" rx=\"22\" fill=\"url(#cardGrad)\" filter=\"url(#warmShadow)\"/>\n      <rect x=\"16\" y=\"130\" width=\"358\" height=\"200\" rx=\"22\" stroke=\"rgba(237,228,208,0.6)\" stroke-width=\"1\" fill=\"none\"/>\n      \n      <!-- Energy arc (centered in card) -->\n      \n    <circle cx=\"195\" cy=\"238\" r=\"72\" stroke=\"#EDE4D0\" stroke-width=\"8\" fill=\"none\" opacity=\"0.3\"/>\n    <circle cx=\"195\" cy=\"238\" r=\"72\" stroke=\"url(#amberGrad)\" stroke-width=\"8\" fill=\"none\"\n      stroke-dasharray=\"330.24421974535903 122.14512237157118\"\n      stroke-dashoffset=\"113.09733552923255\"\n      stroke-linecap=\"round\"/>\n      <!-- Inner arc (secondary metric) -->\n      \n    <circle cx=\"195\" cy=\"238\" r=\"56\" stroke=\"#EDE4D0\" stroke-width=\"8\" fill=\"none\" opacity=\"0.3\"/>\n    <circle cx=\"195\" cy=\"238\" r=\"56\" stroke=\"#5A8A6A\" stroke-width=\"8\" fill=\"none\"\n      stroke-dasharray=\"158.3362697409256 193.52210746113124\"\n      stroke-dashoffset=\"87.96459430051421\"\n      stroke-linecap=\"round\"/>\n      \n      <!-- Arc labels -->\n      <text x=\"195\" y=\"228\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"28\" font-weight=\"700\" text-anchor=\"middle\" fill=\"#1C1611\">73</text>\n      <text x=\"195\" y=\"246\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\" letter-spacing=\"1\">ENERGY SCORE</text>\n      \n      <!-- Legend -->\n      <circle cx=\"80\" cy=\"300\" r=\"4\" fill=\"#E8A020\"/>\n      <text x=\"90\" y=\"304\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">Physical 73%</text>\n      <circle cx=\"220\" cy=\"300\" r=\"4\" fill=\"#5A8A6A\"/>\n      <text x=\"230\" y=\"304\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" fill=\"#6B5C47\">Mental 45%</text>\n\n      <!-- AI Nudge pill -->\n      <rect x=\"16\" y=\"344\" width=\"358\" height=\"56\" rx=\"16\" fill=\"#FEF2D6\" stroke=\"#E8DCC8\" stroke-width=\"0.75\"/>\n      <text x=\"44\" y=\"368\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" letter-spacing=\"1.5\" fill=\"#D4781A\">✦ SOL AI</text>\n      <text x=\"44\" y=\"386\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#6B5C47\">Your focus window peaks 10–11:30am today.</text>\n\n      <!-- Today's ritual progress -->\n      <text x=\"22\" y=\"420\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" letter-spacing=\"1.5\" fill=\"#A8937A\">MORNING RITUAL</text>\n      <text x=\"368\" y=\"420\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#D4781A\" text-anchor=\"end\">3/5 done</text>\n\n      <!-- Ritual items (compact) -->\n      \n        <rect x=\"16\" y=\"438\" width=\"358\" height=\"34\" rx=\"10\" fill=\"rgba(90,138,106,0.08)\" stroke=\"rgba(90,138,106,0.25)\" stroke-width=\"0.75\"/>\n        <circle cx=\"42\" cy=\"455\" r=\"9\" fill=\"#5A8A6A\" stroke=\"#5A8A6A\" stroke-width=\"1.5\"/>\n        <path d=\"M37,455 L41,459 L48,451\" stroke=\"white\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\"/>\n        <text x=\"62\" y=\"458\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#6B5C47\" opacity=\"0.7\">Hydration — 500ml</text>\n        \n        <rect x=\"16\" y=\"478\" width=\"358\" height=\"34\" rx=\"10\" fill=\"rgba(90,138,106,0.08)\" stroke=\"rgba(90,138,106,0.25)\" stroke-width=\"0.75\"/>\n        <circle cx=\"42\" cy=\"495\" r=\"9\" fill=\"#5A8A6A\" stroke=\"#5A8A6A\" stroke-width=\"1.5\"/>\n        <path d=\"M37,495 L41,499 L48,491\" stroke=\"white\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\"/>\n        <text x=\"62\" y=\"498\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#6B5C47\" opacity=\"0.7\">Sunlight — 10 min</text>\n        \n        <rect x=\"16\" y=\"518\" width=\"358\" height=\"34\" rx=\"10\" fill=\"rgba(90,138,106,0.08)\" stroke=\"rgba(90,138,106,0.25)\" stroke-width=\"0.75\"/>\n        <circle cx=\"42\" cy=\"535\" r=\"9\" fill=\"#5A8A6A\" stroke=\"#5A8A6A\" stroke-width=\"1.5\"/>\n        <path d=\"M37,535 L41,539 L48,531\" stroke=\"white\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\"/>\n        <text x=\"62\" y=\"538\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#6B5C47\" opacity=\"0.7\">Movement — 20 min</text>\n        \n        <rect x=\"16\" y=\"558\" width=\"358\" height=\"34\" rx=\"10\" fill=\"#FFFCF5\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n        <circle cx=\"42\" cy=\"575\" r=\"9\" fill=\"none\" stroke=\"#E8DCC8\" stroke-width=\"1.5\"/>\n        \n        <text x=\"62\" y=\"578\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#1C1611\" opacity=\"1\">Cold shower</text>\n        \n        <rect x=\"16\" y=\"598\" width=\"358\" height=\"34\" rx=\"10\" fill=\"#FFFCF5\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n        <circle cx=\"42\" cy=\"615\" r=\"9\" fill=\"none\" stroke=\"#E8DCC8\" stroke-width=\"1.5\"/>\n        \n        <text x=\"62\" y=\"618\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#1C1611\" opacity=\"1\">Journaling</text>\n        \n\n      \n  <g id=\"bottomnav\">\n    <rect x=\"0\" y=\"748\" width=\"390\" height=\"96\" fill=\"rgba(255,252,245,0.72)\" opacity=\"1\"/>\n    <path d=\"M0,748 h390\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n    \n        <g transform=\"translate(21,758)\">\n          <path d=\"M8,14 L8,6 L18,0 L28,6 L28,14 Z\" stroke=\"#D4781A\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\"/>\n               <rect x=\"13\" y=\"8\" width=\"10\" height=\"6\" rx=\"1\" stroke=\"#D4781A\" stroke-width=\"1.2\" fill=\"#D4781A\"/>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#D4781A\">Today</text>\n          <circle cx=\"18\" cy=\"34\" r=\"2\" fill=\"#E8A020\"/>\n        </g>\n        <g transform=\"translate(99,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">☀</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Ritual</text>\n          \n        </g>\n        <g transform=\"translate(177,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">✦</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Insight</text>\n          \n        </g>\n        <g transform=\"translate(255,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">◷</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Schedule</text>\n          \n        </g>\n        <g transform=\"translate(333,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-