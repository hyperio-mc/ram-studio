    {
      "id": "reflect",
      "name": "Reflection",
      "order": 4,
      "width": 390,
      "height": 844,
      "svg": "\n  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    \n  <defs>\n    <linearGradient id=\"bgGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#FDF8F0\"/>\n      <stop offset=\"60%\" stop-color=\"#FEF4E4\"/>\n      <stop offset=\"100%\" stop-color=\"#FBF0E2\"/>\n    </linearGradient>\n    <linearGradient id=\"amberGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#E8A020\"/>\n      <stop offset=\"100%\" stop-color=\"#D4781A\"/>\n    </linearGradient>\n    <linearGradient id=\"sageGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#5A8A6A\"/>\n      <stop offset=\"100%\" stop-color=\"#3D6B50\"/>\n    </linearGradient>\n    <linearGradient id=\"goldGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#F5C842\" stop-opacity=\"0.6\"/>\n      <stop offset=\"100%\" stop-color=\"#E8A020\" stop-opacity=\"0\"/>\n    </linearGradient>\n    <linearGradient id=\"cardGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"rgba(255,252,245,0.95)\"/>\n      <stop offset=\"100%\" stop-color=\"rgba(254,242,214,0.85)\"/>\n    </linearGradient>\n    <filter id=\"warmShadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"130%\">\n      <feDropShadow dx=\"0\" dy=\"4\" stdDeviation=\"12\" flood-color=\"rgba(139,110,70,0.12)\"/>\n    </filter>\n    <filter id=\"softGlow\">\n      <feGaussianBlur stdDeviation=\"18\" result=\"blur\"/>\n      <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\"/>\n    </filter>\n    <clipPath id=\"screenClip\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"40\"/>\n    </clipPath>\n  </defs>\n    <g clip-path=\"url(#screenClip)\">\n      <rect width=\"390\" height=\"844\" fill=\"url(#bgGrad)\"/>\n      <!-- Warm evening glow -->\n      <circle cx=\"195\" cy=\"H\" r=\"300\" fill=\"#E87070\" opacity=\"0.04\"/>\n      <circle cx=\"195\" cy=\"350\" r=\"220\" fill=\"#E8A020\" opacity=\"0.06\"/>\n\n      \n  <g id=\"statusbar\">\n    <text x=\"20\" y=\"22\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"600\" fill=\"#1C1611\">9:41</text>\n    <g transform=\"translate(310,10)\">\n      <!-- Signal -->\n      <rect x=\"0\" y=\"7\" width=\"3\" height=\"5\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"5\" y=\"5\" width=\"3\" height=\"7\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"10\" y=\"3\" width=\"3\" height=\"9\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"15\" y=\"1\" width=\"3\" height=\"11\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- WiFi -->\n      <path d=\"M28,11 Q33,6 38,11\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <path d=\"M30,13.5 Q33,10 36,13.5\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <circle cx=\"33\" cy=\"16\" r=\"1.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- Battery -->\n      <rect x=\"45\" y=\"5\" width=\"22\" height=\"12\" rx=\"3\" stroke=\"#1C1611\" stroke-width=\"1.2\" fill=\"none\" opacity=\"0.9\"/>\n      <rect x=\"67\" y=\"8\" width=\"2.5\" height=\"6\" rx=\"1\" fill=\"#1C1611\" opacity=\"0.6\"/>\n      <rect x=\"46.5\" y=\"6.5\" width=\"16\" height=\"9\" rx=\"2\" fill=\"#1C1611\" opacity=\"0.9\"/>\n    </g>\n  </g>\n\n      <!-- Header -->\n      <text x=\"22\" y=\"56\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"22\" fill=\"#D4781A\">←</text>\n      <text x=\"195\" y=\"58\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"17\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#1C1611\">Reflect</text>\n\n      <!-- Day summary heading -->\n      <text x=\"22\" y=\"88\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"26\" font-weight=\"700\" fill=\"#1C1611\">Wednesday wrap-up</text>\n      <text x=\"22\" y=\"110\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"14\" font-style=\"italic\" fill=\"#A8937A\">April 1 · Energy peak day 🌅</text>\n\n      <!-- Score ring + day score -->\n      \n    <circle cx=\"195\" cy=\"196\" r=\"64\" stroke=\"#EDE4D0\" stroke-width=\"8\" fill=\"none\" opacity=\"0.3\"/>\n    <circle cx=\"195\" cy=\"196\" r=\"64\" stroke=\"url(#amberGrad)\" stroke-width=\"8\" fill=\"none\"\n      stroke-dasharray=\"325.7203263241898 76.40353333530373\"\n      stroke-dashoffset=\"100.53096491487338\"\n      stroke-linecap=\"round\"/>\n      <text x=\"195\" y=\"188\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"36\" font-weight=\"700\" text-anchor=\"middle\" fill=\"#1C1611\">81</text>\n      <text x=\"195\" y=\"208\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\" letter-spacing=\"1\">DAY SCORE</text>\n      <text x=\"195\" y=\"226\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" text-anchor=\"middle\" fill=\"#5A8A6A\">↑ 8 pts from yesterday</text>\n\n      <!-- Ritual completion bar -->\n      <text x=\"22\" y=\"274\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" letter-spacing=\"1.5\" fill=\"#A8937A\">RITUAL COMPLETION</text>\n      <rect x=\"22\" y=\"282\" width=\"346\" height=\"10\" rx=\"5\" fill=\"#EDE4D0\"/>\n      <rect x=\"22\" y=\"282\" width=\"207.6\" height=\"10\" rx=\"5\" fill=\"url(#amberGrad)\"/>\n      <text x=\"368\" y=\"292\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"10\" text-anchor=\"end\" fill=\"#D4781A\">3/5</text>\n\n      <!-- Highlights -->\n      <text x=\"22\" y=\"314\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" letter-spacing=\"1.5\" fill=\"#A8937A\">HIGHLIGHTS</text>\n      \n      \n        <rect x=\"16\" y=\"324\" width=\"358\" height=\"36\" rx=\"10\"\n          fill=\"rgba(90,138,106,0.07)\"\n          stroke=\"rgba(90,138,106,0.2)\" stroke-width=\"0.75\"/>\n        <text x=\"34\" y=\"346\" font-size=\"15\">☀</text>\n        <text x=\"56\" y=\"346\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#1C1611\">Sunlight streak: 12 days</text>\n        <text x=\"362\" y=\"346\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" fill=\"#5A8A6A\" text-anchor=\"end\">✓</text>\n        <rect x=\"16\" y=\"368\" width=\"358\" height=\"36\" rx=\"10\"\n          fill=\"rgba(90,138,106,0.07)\"\n          stroke=\"rgba(90,138,106,0.2)\" stroke-width=\"0.75\"/>\n        <text x=\"34\" y=\"390\" font-size=\"15\">🏃</text>\n        <text x=\"56\" y=\"390\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#1C1611\">Walk: 4.2km · 42 min</text>\n        <text x=\"362\" y=\"390\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" fill=\"#5A8A6A\" text-anchor=\"end\">✓</text>\n        <rect x=\"16\" y=\"412\" width=\"358\" height=\"36\" rx=\"10\"\n          fill=\"rgba(90,138,106,0.07)\"\n          stroke=\"rgba(90,138,106,0.2)\" stroke-width=\"0.75\"/>\n        <text x=\"34\" y=\"434\" font-size=\"15\">🧠</text>\n        <text x=\"56\" y=\"434\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#1C1611\">Deep work: 3h 20min</text>\n        <text x=\"362\" y=\"434\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" fill=\"#5A8A6A\" text-anchor=\"end\">✓</text>\n        <rect x=\"16\" y=\"456\" width=\"358\" height=\"36\" rx=\"10\"\n          fill=\"rgba(232,112,112,0.07)\"\n          stroke=\"rgba(232,112,112,0.2)\" stroke-width=\"0.75\"/>\n        <text x=\"34\" y=\"478\" font-size=\"15\">📓</text>\n        <text x=\"56\" y=\"478\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#1C1611\">Journaling missed</text>\n        <text x=\"362\" y=\"478\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" fill=\"#E87070\" text-anchor=\"end\">○</text>\n        <rect x=\"16\" y=\"500\" width=\"358\" height=\"36\" rx=\"10\"\n          fill=\"rgba(232,112,112,0.07)\"\n          stroke=\"rgba(232,112,112,0.2)\" stroke-width=\"0.75\"/>\n        <text x=\"34\" y=\"522\" font-size=\"15\">🚿</text>\n        <text x=\"56\" y=\"522\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12.5\" fill=\"#1C1611\">Cold shower skipped</text>\n        <text x=\"362\" y=\"522\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" fill=\"#E87070\" text-anchor=\"end\">○</text>\n\n      <!-- Journal prompt -->\n      <rect x=\"16\" y=\"552\" width=\"358\" height=\"80\" rx=\"18\" fill=\"url(#cardGrad)\" filter=\"url(#warmShadow)\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <text x=\"32\" y=\"576\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" letter-spacing=\"2\" fill=\"#D4781A\">✦ SOL PROMPT</text>\n      <text x=\"32\" y=\"596\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"14\" font-style=\"italic\" fill=\"#1C1611\">\"What gave you the most energy today,</text>\n      <text x=\"32\" y=\"614\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"14\" font-style=\"italic\" fill=\"#1C1611\">and how do you recreate it tomorrow?\"</text>\n\n      <!-- Tomorrow CTA -->\n      <rect x=\"16\" y=\"646\" width=\"358\" height=\"52\" rx=\"16\" fill=\"url(#amberGrad)\"/>\n      <text x=\"195\" y=\"677\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" font-weight=\"600\" text-anchor=\"middle\" fill=\"white\">Set tomorrow's intentions →</text>\n\n      \n  <g id=\"bottomnav\">\n    <rect x=\"0\" y=\"748\" width=\"390\" height=\"96\" fill=\"rgba(255,252,245,0.72)\" opacity=\"1\"/>\n    <path d=\"M0,748 h390\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n    \n        <g transform=\"translate(21,758)\">\n          <path d=\"M8,14 L8,6 L18,0 L28,6 L28,14 Z\" stroke=\"#A8937A\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\"/>\n               <rect x=\"13\" y=\"8\" width=\"10\" height=\"6\" rx=\"1\" stroke=\"#A8937A\" stroke-width=\"1.2\" fill=\"none\"/>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Today</text>\n          \n        </g>\n        <g transform=\"translate(99,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">☀</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Ritual</text>\n          \n        </g>\n        <g transform=\"translate(177,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">✦</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Insight</text>\n          \n        </g>\n        <g transform=\"translate(255,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">◷</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Schedule</text>\n          \n        </g>\n        <g transform=\"translate(333,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#D4781A\">◎</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#D4781A\">Reflect</text>\n          <circle cx=\"18\" cy=\"34\" r=\"2\" fill=\"#E8A020\"/>\n        </g>\n  </g>\n      <rect x=\"148\" y=\"824\" width=\"94\" height=\"4\" rx=\"2\" fill=\"#1C1611\" opacity=\"0.25\"/>\n    </g>\n  </svg>"
