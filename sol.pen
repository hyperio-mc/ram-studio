      "svg": "\n  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    \n  <defs>\n    <linearGradient id=\"bgGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#FDF8F0\"/>\n      <stop offset=\"60%\" stop-color=\"#FEF4E4\"/>\n      <stop offset=\"100%\" stop-color=\"#FBF0E2\"/>\n    </linearGradient>\n    <linearGradient id=\"amberGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#E8A020\"/>\n      <stop offset=\"100%\" stop-color=\"#D4781A\"/>\n    </linearGradient>\n    <linearGradient id=\"sageGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#5A8A6A\"/>\n      <stop offset=\"100%\" stop-color=\"#3D6B50\"/>\n    </linearGradient>\n    <linearGradient id=\"goldGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#F5C842\" stop-opacity=\"0.6\"/>\n      <stop offset=\"100%\" stop-color=\"#E8A020\" stop-opacity=\"0\"/>\n    </linearGradient>\n    <linearGradient id=\"cardGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"rgba(255,252,245,0.95)\"/>\n      <stop offset=\"100%\" stop-color=\"rgba(254,242,214,0.85)\"/>\n    </linearGradient>\n    <filter id=\"warmShadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"130%\">\n      <feDropShadow dx=\"0\" dy=\"4\" stdDeviation=\"12\" flood-color=\"rgba(139,110,70,0.12)\"/>\n    </filter>\n    <filter id=\"softGlow\">\n      <feGaussianBlur stdDeviation=\"18\" result=\"blur\"/>\n      <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\"/>\n    </filter>\n    <clipPath id=\"screenClip\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"40\"/>\n    </clipPath>\n  </defs>\n    <g clip-path=\"url(#screenClip)\">\n      <rect width=\"390\" height=\"844\" fill=\"url(#bgGrad)\"/>\n      <!-- Warm sunrise gradient at top -->\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"220\" fill=\"url(#goldGrad)\"/>\n      <circle cx=\"195\" cy=\"-20\" r=\"120\" fill=\"#F5C842\" opacity=\"0.18\"/>\n\n      \n  <g id=\"statusbar\">\n    <text x=\"20\" y=\"22\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"600\" fill=\"#1C1611\">9:41</text>\n    <g transform=\"translate(310,10)\">\n      <!-- Signal -->\n      <rect x=\"0\" y=\"7\" width=\"3\" height=\"5\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"5\" y=\"5\" width=\"3\" height=\"7\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"10\" y=\"3\" width=\"3\" height=\"9\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"15\" y=\"1\" width=\"3\" height=\"11\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- WiFi -->\n      <path d=\"M28,11 Q33,6 38,11\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <path d=\"M30,13.5 Q33,10 36,13.5\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <circle cx=\"33\" cy=\"16\" r=\"1.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- Battery -->\n      <rect x=\"45\" y=\"5\" width=\"22\" height=\"12\" rx=\"3\" stroke=\"#1C1611\" stroke-width=\"1.2\" fill=\"none\" opacity=\"0.9\"/>\n      <rect x=\"67\" y=\"8\" width=\"2.5\" height=\"6\" rx=\"1\" fill=\"#1C1611\" opacity=\"0.6\"/>\n      <rect x=\"46.5\" y=\"6.5\" width=\"16\" height=\"9\" rx=\"2\" fill=\"#1C1611\" opacity=\"0.9\"/>\n    </g>\n  </g>\n\n      <!-- Back + Title -->\n      <text x=\"22\" y=\"56\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"22\" fill=\"#D4781A\">←</text>\n      <text x=\"195\" y=\"58\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"17\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#1C1611\">Morning Ritual</text>\n\n      <!-- Streak card -->\n      <rect x=\"16\" y=\"68\" width=\"358\" height=\"100\" rx=\"20\" fill=\"url(#amberGrad)\"/>\n      <text x=\"30\" y=\"100\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"36\" font-weight=\"700\" fill=\"white\">🔥 12</text>\n      <text x=\"30\" y=\"122\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" fill=\"rgba(255,255,255,0.85)\">Day streak — longest ever!</text>\n      \n      <!-- Sparkline bars (streak history) -->\n      <rect x=\"94\" y=\"152\" width=\"18\" height=\"16\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"116\" y=\"144\" width=\"18\" height=\"24\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"138\" y=\"148\" width=\"18\" height=\"20\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"160\" y=\"136\" width=\"18\" height=\"32\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"182\" y=\"128\" width=\"18\" height=\"40\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"204\" y=\"132\" width=\"18\" height=\"36\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"226\" y=\"140\" width=\"18\" height=\"28\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"248\" y=\"134\" width=\"18\" height=\"34\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"270\" y=\"128\" width=\"18\" height=\"40\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"292\" y=\"128\" width=\"18\" height=\"40\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"314\" y=\"128\" width=\"18\" height=\"40\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"336\" y=\"128\" width=\"18\" height=\"40\" rx=\"4\" fill=\"rgba(255,255,255,0.35)\"/>\n      <text x=\"358\" y=\"176\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" text-anchor=\"end\" fill=\"rgba(255,255,255,0.6)\">12 days</text>\n\n      <!-- Step list (detailed) -->\n      <text x=\"22\" y=\"198\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" letter-spacing=\"1.5\" fill=\"#A8937A\">TODAY'S STEPS</text>\n\n      \n        <rect x=\"16\" y=\"212\" width=\"358\" height=\"84\" rx=\"18\" fill=\"rgba(90,138,106,0.07)\" filter=\"url(#warmShadow)\" stroke=\"rgba(90,138,106,0.2)\" stroke-width=\"0.75\"/>\n        \n        <!-- Icon circle -->\n        <circle cx=\"54\" cy=\"254\" r=\"22\" fill=\"rgba(90,138,106,0.15)\"/>\n        <text x=\"54\" y=\"260\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\">💧</text>\n        \n        <!-- Step connector line -->\n        <line x1=\"54\" y1=\"276\" x2=\"54\" y2=\"308\" stroke=\"#E8DCC8\" stroke-width=\"1.5\" stroke-dasharray=\"3,3\"/>\n        \n        <!-- Text -->\n        <text x=\"86\" y=\"242\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#1C1611\">Hydration</text>\n        <text x=\"86\" y=\"260\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11.5\" fill=\"#A8937A\">500ml room temp water</text>\n        \n        <!-- Time + energy -->\n        <text x=\"86\" y=\"278\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"10\" fill=\"#E8A020\" opacity=\"0.7\">6:30</text>\n        <text x=\"360\" y=\"260\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#5A8A6A\" text-anchor=\"end\">+4 pts</text>\n        \n        <!-- Checkbox -->\n        <circle cx=\"360\" cy=\"278\" r=\"8\" fill=\"#5A8A6A\"/><path d=\"M355,278 L359,282 L366,273\" stroke=\"white\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\"/>\n        <rect x=\"16\" y=\"308\" width=\"358\" height=\"84\" rx=\"18\" fill=\"rgba(90,138,106,0.07)\" filter=\"url(#warmShadow)\" stroke=\"rgba(90,138,106,0.2)\" stroke-width=\"0.75\"/>\n        \n        <!-- Icon circle -->\n        <circle cx=\"54\" cy=\"350\" r=\"22\" fill=\"rgba(90,138,106,0.15)\"/>\n        <text x=\"54\" y=\"356\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\">☀</text>\n        \n        <!-- Step connector line -->\n        <line x1=\"54\" y1=\"372\" x2=\"54\" y2=\"404\" stroke=\"#E8DCC8\" stroke-width=\"1.5\" stroke-dasharray=\"3,3\"/>\n        \n        <!-- Text -->\n        <text x=\"86\" y=\"338\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#1C1611\">Sunlight</text>\n        <text x=\"86\" y=\"356\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11.5\" fill=\"#A8937A\">10 min outdoor light</text>\n        \n        <!-- Time + energy -->\n        <text x=\"86\" y=\"374\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"10\" fill=\"#E8A020\" opacity=\"0.7\">6:45</text>\n        <text x=\"360\" y=\"356\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#5A8A6A\" text-anchor=\"end\">+6 pts</text>\n        \n        <!-- Checkbox -->\n        <circle cx=\"360\" cy=\"374\" r=\"8\" fill=\"#5A8A6A\"/><path d=\"M355,374 L359,378 L366,369\" stroke=\"white\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\"/>\n        <rect x=\"16\" y=\"404\" width=\"358\" height=\"84\" rx=\"18\" fill=\"rgba(90,138,106,0.07)\" filter=\"url(#warmShadow)\" stroke=\"rgba(90,138,106,0.2)\" stroke-width=\"0.75\"/>\n        \n        <!-- Icon circle -->\n        <circle cx=\"54\" cy=\"446\" r=\"22\" fill=\"rgba(90,138,106,0.15)\"/>\n        <text x=\"54\" y=\"452\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\">🏃</text>\n        \n        <!-- Step connector line -->\n        <line x1=\"54\" y1=\"468\" x2=\"54\" y2=\"500\" stroke=\"#E8DCC8\" stroke-width=\"1.5\" stroke-dasharray=\"3,3\"/>\n        \n        <!-- Text -->\n        <text x=\"86\" y=\"434\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#1C1611\">Movement</text>\n        <text x=\"86\" y=\"452\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11.5\" fill=\"#A8937A\">20 min brisk walk</text>\n        \n        <!-- Time + energy -->\n        <text x=\"86\" y=\"470\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"10\" fill=\"#E8A020\" opacity=\"0.7\">7:00</text>\n        <text x=\"360\" y=\"452\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#5A8A6A\" text-anchor=\"end\">+12 pts</text>\n        \n        <!-- Checkbox -->\n        <circle cx=\"360\" cy=\"470\" r=\"8\" fill=\"#5A8A6A\"/><path d=\"M355,470 L359,474 L366,465\" stroke=\"white\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\"/>\n        <rect x=\"16\" y=\"500\" width=\"358\" height=\"84\" rx=\"18\" fill=\"#FFFCF5\" filter=\"url(#warmShadow)\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n        \n        <!-- Icon circle -->\n        <circle cx=\"54\" cy=\"542\" r=\"22\" fill=\"#FEF2D6\"/>\n        <text x=\"54\" y=\"548\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\">🚿</text>\n        \n        <!-- Step connector line -->\n        <line x1=\"54\" y1=\"564\" x2=\"54\" y2=\"596\" stroke=\"#E8DCC8\" stroke-width=\"1.5\" stroke-dasharray=\"3,3\"/>\n        \n        <!-- Text -->\n        <text x=\"86\" y=\"530\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#1C1611\">Cold shower</text>\n        <text x=\"86\" y=\"548\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11.5\" fill=\"#A8937A\">2 min cold finish</text>\n        \n        <!-- Time + energy -->\n        <text x=\"86\" y=\"566\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"10\" fill=\"#E8A020\" opacity=\"0.7\">7:30</text>\n        <text x=\"360\" y=\"548\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#A8937A\" text-anchor=\"end\">+8 pts</text>\n        \n        <!-- Checkbox -->\n        <circle cx=\"360\" cy=\"566\" r=\"8\" stroke=\"#E8DCC8\" stroke-width=\"1.5\" fill=\"none\"/>\n        <rect x=\"16\" y=\"596\" width=\"358\" height=\"84\" rx=\"18\" fill=\"#FFFCF5\" filter=\"url(#warmShadow)\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n        \n        <!-- Icon circle -->\n        <circle cx=\"54\" cy=\"638\" r=\"22\" fill=\"#FEF2D6\"/>\n        <text x=\"54\" y=\"644\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\">📓</text>\n        \n        <!-- Step connector line -->\n        \n        \n        <!-- Text -->\n        <text x=\"86\" y=\"626\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"14\" font-weight=\"600\" fill=\"#1C1611\">Journaling</text>\n        <text x=\"86\" y=\"644\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11.5\" fill=\"#A8937A\">3 prompts · 5 min</text>\n        \n        <!-- Time + energy -->\n        <text x=\"86\" y=\"662\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"10\" fill=\"#E8A020\" opacity=\"0.7\">8:00</text>\n        <text x=\"360\" y=\"644\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"600\" fill=\"#A8937A\" text-anchor=\"end\">+5 pts</text>\n        \n        <!-- Checkbox -->\n        <circle cx=\"360\" cy=\"662\" r=\"8\" stroke=\"#E8DCC8\" stroke-width=\"1.5\" fill=\"none\"/>\n\n      \n  <g id=\"bottomnav\">\n    <rect x=\"0\" y=\"748\" width=\"390\" height=\"96\" fill=\"rgba(255,252,245,0.72)\" opacity=\"1\"/>\n    <path d=\"M0,748 h390\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n    \n        <g transform=\"translate(21,758)\">\n          <path d=\"M8,14 L8,6 L18,0 L28,6 L28,14 Z\" stroke=\"#A8937A\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\"/>\n               <rect x=\"13\" y=\"8\" width=\"10\" height=\"6\" rx=\"1\" stroke=\"#A8937A\" stroke-width=\"1.2\" fill=\"none\"/>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Today</text>\n          \n        </g>\n        <g transform=\"translate(99,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#D4781A\">☀</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#D4781A\">Ritual</text>\n          <circle cx=\"18\" cy=\"34\" r=\"2\" fill=\"#E8A020\"/>\n        </g>\n        <g transform=\"translate(177,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">✦</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Insight</text>\n          \n        </g>\n        <g transform=\"translate(255,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">◷</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Schedule</text>\n          \n        </g>\n        <g transform=\"translate(333,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" 