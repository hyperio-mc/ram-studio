      "width": 390,
      "height": 844,
      "svg": "\n  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    \n  <defs>\n    <linearGradient id=\"bgGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#FDF8F0\"/>\n      <stop offset=\"60%\" stop-color=\"#FEF4E4\"/>\n      <stop offset=\"100%\" stop-color=\"#FBF0E2\"/>\n    </linearGradient>\n    <linearGradient id=\"amberGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#E8A020\"/>\n      <stop offset=\"100%\" stop-color=\"#D4781A\"/>\n    </linearGradient>\n    <linearGradient id=\"sageGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#5A8A6A\"/>\n      <stop offset=\"100%\" stop-color=\"#3D6B50\"/>\n    </linearGradient>\n    <linearGradient id=\"goldGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#F5C842\" stop-opacity=\"0.6\"/>\n      <stop offset=\"100%\" stop-color=\"#E8A020\" stop-opacity=\"0\"/>\n    </linearGradient>\n    <linearGradient id=\"cardGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"rgba(255,252,245,0.95)\"/>\n      <stop offset=\"100%\" stop-color=\"rgba(254,242,214,0.85)\"/>\n    </linearGradient>\n    <filter id=\"warmShadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"130%\">\n      <feDropShadow dx=\"0\" dy=\"4\" stdDeviation=\"12\" flood-color=\"rgba(139,110,70,0.12)\"/>\n    </filter>\n    <filter id=\"softGlow\">\n      <feGaussianBlur stdDeviation=\"18\" result=\"blur\"/>\n      <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\"/>\n    </filter>\n    <clipPath id=\"screenClip\">\n      <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"40\"/>\n    </clipPath>\n  </defs>\n    <g clip-path=\"url(#screenClip)\">\n      <rect width=\"390\" height=\"844\" fill=\"url(#bgGrad)\"/>\n\n      \n  <g id=\"statusbar\">\n    <text x=\"20\" y=\"22\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"600\" fill=\"#1C1611\">9:41</text>\n    <g transform=\"translate(310,10)\">\n      <!-- Signal -->\n      <rect x=\"0\" y=\"7\" width=\"3\" height=\"5\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"5\" y=\"5\" width=\"3\" height=\"7\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"10\" y=\"3\" width=\"3\" height=\"9\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <rect x=\"15\" y=\"1\" width=\"3\" height=\"11\" rx=\"0.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- WiFi -->\n      <path d=\"M28,11 Q33,6 38,11\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <path d=\"M30,13.5 Q33,10 36,13.5\" stroke=\"#1C1611\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.9\"/>\n      <circle cx=\"33\" cy=\"16\" r=\"1.5\" fill=\"#1C1611\" opacity=\"0.9\"/>\n      <!-- Battery -->\n      <rect x=\"45\" y=\"5\" width=\"22\" height=\"12\" rx=\"3\" stroke=\"#1C1611\" stroke-width=\"1.2\" fill=\"none\" opacity=\"0.9\"/>\n      <rect x=\"67\" y=\"8\" width=\"2.5\" height=\"6\" rx=\"1\" fill=\"#1C1611\" opacity=\"0.6\"/>\n      <rect x=\"46.5\" y=\"6.5\" width=\"16\" height=\"9\" rx=\"2\" fill=\"#1C1611\" opacity=\"0.9\"/>\n    </g>\n  </g>\n\n      <!-- Header -->\n      <text x=\"22\" y=\"56\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"22\" fill=\"#D4781A\">←</text>\n      <text x=\"195\" y=\"58\" font-family=\"'Georgia', 'Times New Roman', serif\" font-size=\"17\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#1C1611\">Schedule</text>\n      <text x=\"368\" y=\"58\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"20\" fill=\"#A8937A\" text-anchor=\"end\">+</text>\n\n      <!-- Date strip -->\n      <rect x=\"16\" y=\"66\" width=\"358\" height=\"44\" rx=\"14\" fill=\"#FFFCF5\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      \n          \n          <text x=\"40\" y=\"82\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Mon</text>\n          <text x=\"40\" y=\"96\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\">1</text>\n        \n          \n          <text x=\"86\" y=\"82\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Tue</text>\n          <text x=\"86\" y=\"96\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\">2</text>\n        \n          <circle cx=\"132\" cy=\"88\" r=\"16\" fill=\"#E8A020\"/>\n          <text x=\"132\" y=\"84\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"13\" font-weight=\"600\" text-anchor=\"middle\" fill=\"white\">Wed</text>\n          \n        \n          \n          <text x=\"178\" y=\"82\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Thu</text>\n          <text x=\"178\" y=\"96\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\">4</text>\n        \n          \n          <text x=\"224\" y=\"82\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Fri</text>\n          <text x=\"224\" y=\"96\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\">5</text>\n        \n          \n          <text x=\"270\" y=\"82\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Sat</text>\n          <text x=\"270\" y=\"96\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\">6</text>\n        \n          \n          <text x=\"316\" y=\"82\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"11\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Sun</text>\n          <text x=\"316\" y=\"96\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" text-anchor=\"middle\" fill=\"#A8937A\">7</text>\n        \n\n      <!-- Energy band overlay legend -->\n      <text x=\"22\" y=\"128\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"10\" font-weight=\"600\" letter-spacing=\"1.5\" fill=\"#A8937A\">APR 1 · SOL OPTIMISED</text>\n      \n      <!-- Legend -->\n      \n        <circle cx=\"140\" cy=\"128\" r=\"4\" fill=\"#5A8A6A\"/>\n        <text x=\"148\" y=\"132\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9.5\" fill=\"#A8937A\">Focus</text>\n      \n        <circle cx=\"196\" cy=\"128\" r=\"4\" fill=\"#E8A020\"/>\n        <text x=\"204\" y=\"132\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9.5\" fill=\"#A8937A\">Ritual</text>\n      \n        <circle cx=\"252\" cy=\"128\" r=\"4\" fill=\"#8B6EBE\"/>\n        <text x=\"260\" y=\"132\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9.5\" fill=\"#A8937A\">Meeting</text>\n      \n        <circle cx=\"308\" cy=\"128\" r=\"4\" fill=\"#E87070\"/>\n        <text x=\"316\" y=\"132\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9.5\" fill=\"#A8937A\">Admin</text>\n      \n\n      <!-- Timeline -->\n      <line x1=\"72\" y1=\"210\" x2=\"72\" y2=\"678\" stroke=\"#EDE4D0\" stroke-width=\"0.75\" stroke-dasharray=\"3,4\"/>\n      \n      <rect x=\"80\" y=\"210\" width=\"294\" height=\"30\" rx=\"10\"\n        fill=\"rgba(232,160,32,0.15)\" stroke=\"#E8A020\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"224\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">6:30</text>\n      <line x1=\"72\" y1=\"211\" x2=\"72\" y2=\"239\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"224\" r=\"3\" fill=\"#E8A020\"/>\n      <text x=\"94\" y=\"224\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Morning Ritual</text>\n      \n    \n      <rect x=\"80\" y=\"246\" width=\"294\" height=\"54\" rx=\"10\"\n        fill=\"rgba(90,138,106,0.12)\" stroke=\"#5A8A6A\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"260\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">8:00</text>\n      <line x1=\"72\" y1=\"247\" x2=\"72\" y2=\"299\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"260\" r=\"3\" fill=\"#5A8A6A\"/>\n      <text x=\"94\" y=\"260\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Deep Work Block</text>\n      <text x=\"94\" y=\"274\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9.5\" fill=\"#5A8A6A\" opacity=\"0.8\">SOL peak focus window</text>\n    \n      <rect x=\"80\" y=\"306\" width=\"294\" height=\"30\" rx=\"10\"\n        fill=\"rgba(139,110,190,0.12)\" stroke=\"#8B6EBE\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"320\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">9:30</text>\n      <line x1=\"72\" y1=\"307\" x2=\"72\" y2=\"335\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"320\" r=\"3\" fill=\"#8B6EBE\"/>\n      <text x=\"94\" y=\"320\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Team Sync</text>\n      \n    \n      <rect x=\"80\" y=\"342\" width=\"294\" height=\"78\" rx=\"10\"\n        fill=\"rgba(90,138,106,0.12)\" stroke=\"#5A8A6A\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"356\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">10:00</text>\n      <line x1=\"72\" y1=\"343\" x2=\"72\" y2=\"419\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"356\" r=\"3\" fill=\"#5A8A6A\"/>\n      <text x=\"94\" y=\"356\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Deep Work Block</text>\n      <text x=\"94\" y=\"370\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9.5\" fill=\"#5A8A6A\" opacity=\"0.8\">Longest focus streak</text>\n    \n      <rect x=\"80\" y=\"426\" width=\"294\" height=\"30\" rx=\"10\"\n        fill=\"rgba(200,190,175,0.15)\" stroke=\"#E8DCC8\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"440\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">11:30</text>\n      <line x1=\"72\" y1=\"427\" x2=\"72\" y2=\"455\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"440\" r=\"3\" fill=\"#A8937A\"/>\n      <text x=\"94\" y=\"440\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Break + Walk</text>\n      \n    \n      <rect x=\"80\" y=\"462\" width=\"294\" height=\"30\" rx=\"10\"\n        fill=\"rgba(200,190,175,0.15)\" stroke=\"#E8DCC8\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"476\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">12:00</text>\n      <line x1=\"72\" y1=\"463\" x2=\"72\" y2=\"491\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"476\" r=\"3\" fill=\"#A8937A\"/>\n      <text x=\"94\" y=\"476\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Lunch</text>\n      \n    \n      <rect x=\"80\" y=\"498\" width=\"294\" height=\"42\" rx=\"10\"\n        fill=\"rgba(232,112,112,0.10)\" stroke=\"#E87070\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"512\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">13:00</text>\n      <line x1=\"72\" y1=\"499\" x2=\"72\" y2=\"539\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"512\" r=\"3\" fill=\"#E87070\"/>\n      <text x=\"94\" y=\"512\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Admin & Email</text>\n      \n    \n      <rect x=\"80\" y=\"546\" width=\"294\" height=\"54\" rx=\"10\"\n        fill=\"rgba(90,138,106,0.12)\" stroke=\"#5A8A6A\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"560\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">14:00</text>\n      <line x1=\"72\" y1=\"547\" x2=\"72\" y2=\"599\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"560\" r=\"3\" fill=\"#5A8A6A\"/>\n      <text x=\"94\" y=\"560\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Creative Work</text>\n      \n    \n      <rect x=\"80\" y=\"606\" width=\"294\" height=\"30\" rx=\"10\"\n        fill=\"rgba(232,112,112,0.10)\" stroke=\"#E87070\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"620\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">15:30</text>\n      <line x1=\"72\" y1=\"607\" x2=\"72\" y2=\"635\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"620\" r=\"3\" fill=\"#E87070\"/>\n      <text x=\"94\" y=\"620\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Review + Plan</text>\n      \n    \n      <rect x=\"80\" y=\"642\" width=\"294\" height=\"30\" rx=\"10\"\n        fill=\"rgba(200,190,175,0.15)\" stroke=\"#E8DCC8\" stroke-width=\"0.75\"/>\n      <text x=\"16\" y=\"656\" font-family=\"'JetBrains Mono', 'Fira Code', monospace\" font-size=\"9.5\" fill=\"#A8937A\">16:00</text>\n      <line x1=\"72\" y1=\"643\" x2=\"72\" y2=\"671\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n      <circle cx=\"75\" cy=\"656\" r=\"3\" fill=\"#A8937A\"/>\n      <text x=\"94\" y=\"656\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"12\" font-weight=\"500\" fill=\"#1C1611\">Free time</text>\n      \n    \n\n      \n  <g id=\"bottomnav\">\n    <rect x=\"0\" y=\"748\" width=\"390\" height=\"96\" fill=\"rgba(255,252,245,0.72)\" opacity=\"1\"/>\n    <path d=\"M0,748 h390\" stroke=\"#EDE4D0\" stroke-width=\"0.75\"/>\n    \n        <g transform=\"translate(21,758)\">\n          <path d=\"M8,14 L8,6 L18,0 L28,6 L28,14 Z\" stroke=\"#A8937A\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\"/>\n               <rect x=\"13\" y=\"8\" width=\"10\" height=\"6\" rx=\"1\" stroke=\"#A8937A\" stroke-width=\"1.2\" fill=\"none\"/>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Today</text>\n          \n        </g>\n        <g transform=\"translate(99,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">☀</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Ritual</text>\n          \n        </g>\n        <g transform=\"translate(177,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">✦</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Insight</text>\n          \n        </g>\n        <g transform=\"translate(255,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#D4781A\">◷</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"600\" text-anchor=\"middle\" fill=\"#D4781A\">Schedule</text>\n          <circle cx=\"18\" cy=\"34\" r=\"2\" fill=\"#E8A020\"/>\n        </g>\n        <g transform=\"translate(333,758)\">\n          <text x=\"18\" y=\"17\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"18\" text-anchor=\"middle\" fill=\"#A8937A\">◎</text>\n          <text x=\"18\" y=\"30\" font-family=\"'Inter', -apple-system, BlinkMacSystemFont, sans-serif\" font-size=\"9\" font-weight=\"400\" text-anchor=\"middle\" fill=\"#A8937A\">Reflect</text>\n          \n        </g>\n  </g>\n      <rect x=\"148\" y=\"824\" width=\"94\" height=\"4\" rx=\"2\" fill=\"#1C1611\" opacity=\"0.25\"/>\n    </g>\n  </svg>"
