          "opacity": 1,
          "stroke": "#252A1E",
          "strokeWidth": 1
        },
        {
          "type": "TEXT",
          "id": "n204",
          "x": 1395,
          "y": 338,
          "w": 212,
          "content": "That's the whole thing, isn't it. Slow is the point.",
          "fontSize": 12,
          "color": "#E4E0D6",
          "fontWeight": 400,
          "fontStyle": "normal",
          "fontFamily": "Inter",
          "textAlign": "left",
