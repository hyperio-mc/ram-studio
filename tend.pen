          "y": 238,
          "w": 240,
          "h": 70,
          "fill": "#C4904022",
          "cornerRadius": 14,
          "opacity": 1,
          "stroke": "#C4904040",
          "strokeWidth": 1
        },
        {
          "type": "TEXT",
          "id": "n201",
          "x": 1498,
          "y": 248,
          "w": 212,
          "content": "Yes. Before it gets too warm. I miss when things felt slower.",
          "fontSize": 12,
          "color": "#E4E0D6",
          "fontWeight": 400,
          "fontStyle": "normal",
          "fontFamily": "Inter",
          "textAlign": "left",
          "lineHeight": 1.6,
          "letterSpacing": 0,
          "opacity": 1
        },
        {
          "type": "TEXT",
