        {
          "type": "TEXT",
          "id": "n196",
          "x": 1425,
          "y": 117,
          "w": 255,
          "content": "Slow exchange — no read receipts",
          "fontSize": 9,
          "color": "rgba(228,224,214,0.38)",
          "fontWeight": 400,
          "fontStyle": "normal",
          "fontFamily": "Inter",
          "textAlign": "center",
          "lineHeight": 1.5,
          "letterSpacing": 0,
          "opacity": 1
        },
        {
          "type": "RECTANGLE",
          "id": "n197",
          "x": 1381,
          "y": 148,
          "w": 240,
          "h": 70,
          "fill": "#131510",
          "cornerRadius": 14,
          "opacity": 1,
          "stroke": "#252A1E",
          "strokeWidth": 1
        },
        {
          "type": "TEXT",
          "id": "n198",
          "x": 1395,
          "y": 158,
          "w": 212,
          "content": "Thinking about that walk we did last autumn. Should do it again.",
          "fontSize": 12,
          "color": "#E4E0D6",
          "fontWeight": 400,
          "fontStyle": "normal",
          "fontFamily": "Inter",
          "textAlign": "left",
          "lineHeight": 1.6,
          "letterSpacing": 0,
          "opacity": 1
        },
        {
          "type": "TEXT",
          "id": "n199",
          "x": 1395,
          "y": 203,
          "w": 212,
          "content": "Mar 24",
          "fontSize": 9,
          "color": "rgba(228,224,214,0.38)",
          "fontWeight": 400,
          "fontStyle": "normal",
          "fontFamily": "Inter",
          "textAlign": "left",
          "lineHeight": 1.5,
          "letterSpacing": 0,
          "opacity": 1
        },
        {
          "type": "RECTANGLE",
          "id": "n200",
