          "w": 212,
          "content": "Mar 24",
          "fontSize": 9,
          "color": "rgba(228,224,214,0.38)",
          "fontWeight": 400,
          "fontStyle": "normal",
          "fontFamily": "Inter",
          "textAlign": "right",
          "lineHeight": 1.5,
          "letterSpacing": 0,
          "opacity": 1
        },
        {
