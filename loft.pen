      "name": "Project Brief",
      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FAF7F2\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"52\" fill=\"#FFFFFF\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <line x1=\"0\" y1=\"52\" x2=\"390\" y2=\"52\" stroke=\"#E2DDD7\" stroke-width=\"1\" opacity=\"1\"/>\n    <text x=\"20\" y=\"33\" font-size=\"13\" fill=\"#C2714A\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">← Verdana Brand Identity</text>\n    <rect x=\"318\" y=\"16\" width=\"68\" height=\"20\" fill=\"#D4EAE6\" rx=\"10\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"326\" y=\"30\" font-size=\"10\" fill=\"#4A7C6F\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.3\" opacity=\"1\">On Track</text>\n    <rect x=\"0\" y=\"52\" width=\"390\" height=\"110\" fill=\"#C2714A\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"20\" y=\"83\" font-size=\"17\" fill=\"#FFFFFF\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Verdana Brand Identity</text>\n    <text x=\"20\" y=\"102\" font-size=\"12\" fill=\"rgba(255,225,215,0.8)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Verdana Inc. · Branding & Identity</text>\n    <text x=\"20\" y=\"121\" font-size=\"11\" fill=\"rgba(255,225,215,0.7)\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Due Mon Apr 14 · 3 days left</text>\n    <rect x=\"20\" y=\"134\" width=\"350\" height=\"6\" fill=\"rgba(255,255,255,0.25)\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"20\" y=\"134\" width=\"238.00000000000003\" height=\"6\" fill=\"#FFFFFF\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"370\" y=\"144\" font-size=\"10\" fill=\"rgba(255,225,215,0.9)\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">68%</text>\n    <rect x=\"0\" y=\"162\" width=\"390\" height=\"40\" fill=\"#FFFFFF\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <line x1=\"0\" y1=\"202\" x2=\"390\" y2=\"202\" stroke=\"#E2DDD7\" stroke-width=\"1\" opacity=\"1\"/>\n    <text x=\"20\" y=\"186\" font-size=\"12\" fill=\"#C2714A\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Brief</text>\n    <line x1=\"20\" y1=\"202\" x2=\"57.5\" y2=\"202\" stroke=\"#C2714A\" stroke-width=\"2\" opacity=\"1\"/>\n    <text x=\"79.5\" y=\"186\" font-size=\"12\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Assets</text>\n    <text x=\"146.5\" y=\"186\" font-size=\"12\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Timeline</text>\n    <text x=\"228.5\" y=\"186\" font-size=\"12\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Notes</text>\n    <rect x=\"16\" y=\"216\" width=\"358\" height=\"80\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"#E2DDD7\" stroke-width=\"1\"/>\n    <text x=\"26\" y=\"232\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">CLIENT CONTEXT</text>\n    <text x=\"26\" y=\"247\" font-size=\"11\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Verdana Inc. is a sustainable materials startup rebr</text>\n    <text x=\"26\" y=\"262\" font-size=\"11\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">anding after Series A. They need a full visual ident</text>\n    <text x=\"26\" y=\"277\" font-size=\"11\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">ity reflecting their commitment to circular design principles.</text>\n    <rect x=\"16\" y=\"308\" width=\"358\" height=\"136\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"#E2DDD7\" stroke-width=\"1\"/>\n    <text x=\"26\" y=\"324\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">DELIVERABLES</text>\n    <circle cx=\"30\" cy=\"336\" r=\"3\" fill=\"#C2714A\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"40\" y=\"340\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Primary + secondary logo suite</text>\n    <circle cx=\"30\" cy=\"360\" r=\"3\" fill=\"#C2714A\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"40\" y=\"364\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Brand guidelines (40pp PDF)</text>\n    <circle cx=\"30\" cy=\"384\" r=\"3\" fill=\"#C2714A\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"40\" y=\"388\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Business stationery pack</text>\n    <circle cx=\"30\" cy=\"408\" r=\"3\" fill=\"#C2714A\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"40\" y=\"412\" font-size=\"11\" fill=\"#1C1917\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Social media template set</text>\n    <rect x=\"16\" y=\"454\" width=\"358\" height=\"80\" fill=\"#FFFFFF\" rx=\"10\" opacity=\"1\" stroke=\"#E2DDD7\" stroke-width=\"1\"/>\n    <text x=\"26\" y=\"470\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"1\" opacity=\"1\">CREATIVE DIRECTION</text>\n    <text x=\"26\" y=\"485\" font-size=\"11\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Earthy, premium, minimal. Reference: Aesop meets Pat</text>\n    <text x=\"26\" y=\"500\" font-size=\"11\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">agonia. Avoid tech-company aesthetics. Serif headlin</text>\n    <text x=\"26\" y=\"515\" font-size=\"11\" fill=\"#57534E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">e type preferred.</text>\n    <rect x=\"0\" y=\"764\" width=\"390\" height=\"80\" fill=\"#FFFFFF\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <line x1=\"0\" y1=\"764\" x2=\"390\" y2=\"764\" stroke=\"#E2DDD7\" stroke-width=\"1\" opacity=\"1\"/>\n    <circle cx=\"39\" cy=\"792\" r=\"14\" fill=\"none\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"39\" y=\"799\" font-size=\"14\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">⌂</text>\n    <text x=\"39\" y=\"818\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.2\" opacity=\"1\">Home</text>\n    <circle cx=\"117\" cy=\"792\" r=\"14\" fill=\"#F0E0D6\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"117\" y=\"799\" font-size=\"14\" fill=\"#C2714A\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◫</text>\n    <text x=\"117\" y=\"818\" font-size=\"9\" fill=\"#C2714A\" font-weight=\"600\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.2\" opacity=\"1\">Projects</text>\n    <circle cx=\"195\" cy=\"804\" r=\"22\" fill=\"#C2714A\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"195\" y=\"811\" font-size=\"18\" fill=\"#FFFFFF\" font-weight=\"300\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">+</text>\n    <circle cx=\"273\" cy=\"792\" r=\"14\" fill=\"none\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"273\" y=\"799\" font-size=\"14\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">☰</text>\n    <text x=\"273\" y=\"818\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.2\" opacity=\"1\">Assets</text>\n    <circle cx=\"351\" cy=\"792\" r=\"14\" fill=\"none\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"351\" y=\"799\" font-size=\"14\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">◎</text>\n    <text x=\"351\" y=\"818\" font-size=\"9\" fill=\"#A8A29E\" font-weight=\"400\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0.2\" opacity=\"1\">Profile</text>\n  </svg>",
