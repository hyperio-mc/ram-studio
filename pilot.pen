text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\" letter-spacing=\"0.04em\">Role Description</text>\n    <rect x=\"16\" y=\"228\" width=\"358\" height=\"56\" rx=\"10\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n    <text x=\"30\" y=\"252\" font-size=\"13\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Monitor Hacker News for product mentions</text>\n    <text x=\"30\" y=\"270\" font-size=\"13\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">and summarise daily...</text>\n\n    <!-- Model select -->\n    <text x=\"20\" y=\"306\" font-size=\"11\" font-weight=\"600\" fill=\"#8C8580\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\" letter-spacing=\"0.04em\">Model</text>\n    \n        <rect x=\"16\" y=\"318\" width=\"173\" height=\"34\" rx=\"10\" fill=\"#EEF2FF\" stroke=\"#2D5BFF\" stroke-width=\"1.5\"/>\n        <text x=\"102.5\" y=\"340\" font-size=\"11\" font-weight=\"600\" fill=\"#2D5BFF\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">GPT-4o</text>\n      \n        <rect x=\"201\" y=\"318\" width=\"173\" height=\"34\" rx=\"10\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"287.5\" y=\"340\" font-size=\"11\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Claude 3.5 Sonnet</text>\n      \n        <rect x=\"16\" y=\"360\" width=\"173\" height=\"34\" rx=\"10\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"102.5\" y=\"382\" font-size=\"11\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Gemini 1.5 Pro</text>\n      \n        <rect x=\"201\" y=\"360\" width=\"173\" height=\"34\" rx=\"10\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"287.5\" y=\"382\" font-size=\"11\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Mistral Large</text>\n      \n\n    <!-- Tools -->\n    <text x=\"20\" y=\"410\" font-size=\"11\" font-weight=\"600\" fill=\"#8C8580\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\" letter-spacing=\"0.04em\">Tools & Permissions</text>\n    \n        <rect x=\"16\" y=\"422\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#EEF2FF\" stroke=\"#2D5BFF\" stroke-width=\"1.5\"/>\n        <text x=\"59.25\" y=\"442\" font-size=\"10\" font-weight=\"600\" fill=\"#2D5BFF\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Web Browse</text>\n      \n        <rect x=\"106.5\" y=\"422\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#EEF2FF\" stroke=\"#2D5BFF\" stroke-width=\"1.5\"/>\n        <text x=\"149.75\" y=\"442\" font-size=\"10\" font-weight=\"600\" fill=\"#2D5BFF\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Code Exec</text>\n      \n        <rect x=\"197\" y=\"422\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"240.25\" y=\"442\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Email</text>\n      \n        <rect x=\"287.5\" y=\"422\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"330.75\" y=\"442\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Postgres</text>\n      \n        <rect x=\"16\" y=\"462\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#EEF2FF\" stroke=\"#2D5BFF\" stroke-width=\"1.5\"/>\n        <text x=\"59.25\" y=\"482\" font-size=\"10\" font-weight=\"600\" fill=\"#2D5BFF\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">File I/O</text>\n      \n        <rect x=\"106.5\" y=\"462\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"149.75\" y=\"482\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Slack</text>\n      \n        <rect x=\"197\" y=\"462\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"240.25\" y=\"482\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">GitHub</text>\n      \n        <rect x=\"287.5\" y=\"462\" width=\"86.5\" height=\"30\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n        <text x=\"330.75\" y=\"482\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Stripe</text>\n      \n\n    <!-- Schedule -->\n    <text x=\"20\" y=\"512\" font-size=\"11\" font-weight=\"600\" fill=\"#8C8580\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\" letter-spacing=\"0.04em\">Schedule</text>\n    <rect x=\"16\" y=\"524\" width=\"358\" height=\"44\" rx=\"10\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n    <text x=\"30\" y=\"551\" font-size=\"14\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Every 2 hours</text>\n    <text x=\"362\" y=\"551\" font-size=\"14\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"end\" font-family=\"Inter, -apple-system, sans-serif\">▾</text>\n\n    <!-- Deploy button -->\n    <rect x=\"16\" y=\"586\" width=\"358\" height=\"52\" rx=\"26\" fill=\"#2D5BFF\"/>\n    <text x=\"195\" y=\"618\" font-size=\"16\" font-weight=\"700\" fill=\"#fff\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Deploy Phantom →</text>\n\n    <!-- Credit note -->\n    <text x=\"195\" y=\"652\" font-size=\"11\" font-weight