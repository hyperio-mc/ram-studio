          "content": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" rx=\"0\" fill=\"#F5F1EB\"/>\n\n    <text x=\"20\" y=\"22\" font-size=\"13\" font-weight=\"600\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">9:41</text>\n    <text x=\"370\" y=\"22\" font-size=\"11\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"end\" font-family=\"Inter, -apple-system, sans-serif\" opacity=\"0.5\">●●● 100%</text>\n\n    <text x=\"20\" y=\"58\" font-size=\"22\" font-weight=\"700\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Outcomes</text>\n    <text x=\"20\" y=\"76\" font-size=\"13\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">What your fleet accomplished</text>\n\n    <!-- Today's summary card -->\n    <rect x=\"16\" y=\"90\" width=\"358\" height=\"100\" rx=\"16\" fill=\"#2D5BFF\"/>\n    <text x=\"32\" y=\"116\" font-size=\"10\" font-weight=\"700\" fill=\"rgba(255,255,255,0.65)\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\" letter-spacing=\"0.08em\">TODAY</text>\n    <text x=\"32\" y=\"144\" font-size=\"36\" font-weight=\"800\" fill=\"#fff\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">847</text>\n    <text x=\"32\" y=\"164\" font-size=\"13\" font-weight=\"400\" fill=\"rgba(255,255,255,0.75)\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">tasks completed</text>\n\n    <!-- mini bar chart -->\n    <rect x=\"270\" y=\"141.04\" width=\"4.75\" height=\"24.96\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"277.75\" y=\"133.76\" width=\"4.75\" height=\"32.24\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"285.5\" y=\"129.07999999999998\" width=\"4.75\" height=\"36.92\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"293.25\" y=\"137.4\" width=\"4.75\" height=\"28.6\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"301\" y=\"124.4\" width=\"4.75\" height=\"41.6\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"308.75\" y=\"119.19999999999999\" width=\"4.75\" height=\"46.800000000000004\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"316.5\" y=\"121.80000000000001\" width=\"4.75\" height=\"44.199999999999996\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"324.25\" y=\"118.16\" width=\"4.75\" height=\"47.84\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"332\" y=\"120.24000000000001\" width=\"4.75\" height=\"45.76\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"339.75\" y=\"115.03999999999999\" width=\"4.75\" height=\"50.96\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"347.5\" y=\"116.6\" width=\"4.75\" height=\"49.4\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/><rect x=\"355.25\" y=\"114\" width=\"4.75\" height=\"52\" rx=\"2\" fill=\"rgba(255,255,255,0.35)\"/>\n    <text x=\"314\" y=\"178\" font-size=\"10\" font-weight=\"400\" fill=\"rgba(255,255,255,0.6)\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">vs 634 yesterday</text>\n\n    <!-- Category breakdown -->\n    <text x=\"20\" y=\"214\" font-size=\"10\" font-weight=\"700\" fill=\"#8C8580\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\" letter-spacing=\"0.07em\">BY CATEGORY</text>\n\n    \n      <rect x=\"16\" y=\"228\" width=\"358\" height=\"40\" rx=\"10\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <circle cx=\"34\" cy=\"248\" r=\"7\" fill=\"#2D5BFF\"/>\n      <text x=\"50\" y=\"252\" font-size=\"13\" font-weight=\"500\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Research</text>\n      <text x=\"370\" y=\"252\" font-size=\"13\" font-weight=\"600\" fill=\"#1A1714\" text-anchor=\"end\" font-family=\"Inter, -apple-system, sans-serif\">312</text>\n      \n    <rect x=\"50\" y=\"256\" width=\"310\" height=\"4\" rx=\"2\" fill=\"#E8E3DA\"/>\n    <rect x=\"50\" y=\"256\" width=\"114.7\" height=\"4\" rx=\"2\" fill=\"#2D5BFF\"/>\n  \n    \n      <rect x=\"16\" y=\"276\" width=\"358\" height=\"40\" rx=\"10\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <circle cx=\"34\" cy=\"296\" r=\"7\" fill=\"#7C3AED\"/>\n      <text x=\"50\" y=\"300\" font-size=\"13\" font-weight=\"500\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Code gen</text>\n      <text x=\"370\" y=\"300\" font-size=\"13\" font-weight=\"600\" fill=\"#1A1714\" text-anchor=\"end\" font-family=\"Inter, -apple-system, sans-serif\">228</text>\n      \n    <rect x=\"50\" y=\"304\" width=\"310\" height=\"4\" rx=\"2\" fill=\"#E8E3DA\"/>\n    <rect x=\"50\" y=\"304\" width=\"83.7\" height=\"4\" rx=\"2\" fill=\"#7C3AED\"/>\n  \n    \n      <rect x=\"16\" y=\"324\" width=\"358\" height=\"40\" rx=\"10\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <circle cx=\"34\" cy=\"344\" r=\"7\" fill=\"#1A9E6A\"/>\n      <text x=\"50\" y=\"348\" font-size=\"13\" font-weight=\"500\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Data sync</text>\n      <text x=\"370\" y=\"348\" font-size=\"13\" font-weight=\"600\" fill=\"#1A1714\" text-anchor=\"end\" font-family=\"Inter, -apple-system, sans-serif\">189</text>\n      \n    <rect x=\"50\" y=\"352\" width=\"310\" height=\"4\" rx=\"2\" fill=\"#E8E3DA\"/>\n    <rect x=\"50\" y=\"352\" width=\"68.2\" height=\"4\" rx=\"2\" fill=\"#1A9E6A\"/>\n  \n    \n      <rect x=\"16\" y=\"372\" width=\"358\" height=\"40\" rx=\"10\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <circle cx=\"34\" cy=\"392\" r=\"7\" fill=\"#F59E0B\"/>\n      <text x=\"50\" y=\"396\" font-size=\"13\" font-weight=\"500\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Outreach</text>\n      <text x=\"370\" y=\"396\" font-size=\"13\" font-weight=\"600\" fill=\"#1A1714\" text-anchor=\"end\" font-family=\"Inter, -apple-system, sans-serif\">84</text>\n      \n    <rect x=\"50\" y=\"400\" width=\"310\" height=\"4\" rx=\"2\" fill=\"#E8E3DA\"/>\n    <rect x=\"50\" y=\"400\" width=\"31\" height=\"4\" rx=\"2\" fill=\"#F59E0B\"/>\n  \n    \n      <rect x=\"16\" y=\"420\" width=\"358\" height=\"40\" rx=\"10\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <circle cx=\"34\" cy=\"440\" r=\"7\" fill=\"#8C8580\"/>\n      <text x=\"50\" y=\"444\" font-size=\"13\" font-weight=\"500\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Security</text>\n      <text x=\"370\" y=\"444\" font-size=\"13\" font-weight=\"600\" fill=\"#1A1714\" text-anchor=\"end\" font-family=\"Inter, -apple-system, sans-serif\">34</text>\n      \n    <rect x=\"50\" y=\"448\" width=\"310\" height=\"4\" rx=\"2\" fill=\"#E8E3DA\"/>\n    <rect x=\"50\" y=\"448\" width=\"12.4\" height=\"4\" rx=\"2\" fill=\"#8C8580\"/>\n  \n    \n\n    <!-- Notable outcomes -->\n    <text x=\"20\" y=\"474\" font-size=\"10\" font-weight=\"700\" fill=\"#8C8580\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\" letter-spacing=\"0.07em\">NOTABLE RESULTS</text>\n\n    \n      <rect x=\"16\" y=\"488\" width=\"358\" height=\"64\" rx=\"12\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <rect x=\"30\" y=\"504\" width=\"28\" height=\"28\" rx=\"8\" fill=\"#EEF2FF\"/>\n      <text x=\"44\" y=\"523\" font-size=\"14\" font-weight=\"400\" fill=\"#2D5BFF\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">↓</text>\n      <text x=\"70\" y=\"512\" font-size=\"12\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Scout found 6 competitor price changes — Notion raised by 20%</text>\n    \n      <rect x=\"16\" y=\"560\" width=\"358\" height=\"64\" rx=\"12\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <rect x=\"30\" y=\"576\" width=\"28\" height=\"28\" rx=\"8\" fill=\"#E8F7F1\"/>\n      <text x=\"44\" y=\"595\" font-size=\"14\" font-weight=\"400\" fill=\"#1A9E6A\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">✓</text>\n      <text x=\"70\" y=\"584\" font-size=\"12\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Forge generated 1,240 lines of tested TypeScript in 3.2 min</text>\n    \n      <rect x=\"16\" y=\"632\" width=\"358\" height=\"64\" rx=\"12\" fill=\"#FDFCFA\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n      <rect x=\"30\" y=\"648\" width=\"28\" height=\"28\" rx=\"8\" fill=\"#FEF3C7\"/>\n      <text x=\"44\" y=\"667\" font-size=\"14\" font-weight=\"400\" fill=\"#F59E0B\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">◈</text>\n      <text x=\"70\" y=\"656\" font-size=\"12\" font-weight=\"400\" fill=\"#1A1714\" text-anchor=\"start\" font-family=\"Inter, -apple-system, sans-serif\">Herald queued 42 personalised outreach emails, 78% open rate</text>\n    \n\n    <!-- Bottom nav -->\n    <rect x=\"0\" y=\"772\" width=\"390\" height=\"72\" rx=\"0\" fill=\"#FFFFFF\" stroke=\"#E8E3DA\" stroke-width=\"1\"/>\n    <text x=\"78\" y=\"804\" font-size=\"18\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">⌂</text>\n    <text x=\"78\" y=\"822\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Fleet</text>\n    <text x=\"156\" y=\"804\" font-size=\"18\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">≡</text>\n    <text x=\"156\" y=\"822\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Tasks</text>\n    <text x=\"234\" y=\"804\" font-size=\"18\" font-weight=\"400\" fill=\"#2D5BFF\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">◎</text>\n    <text x=\"234\" y=\"822\" font-size=\"10\" font-weight=\"600\" fill=\"#2D5BFF\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Outcomes</text>\n    <text x=\"312\" y=\"804\" font-size=\"18\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">⚙</text>\n    <text x=\"312\" y=\"822\" font-size=\"10\" font-weight=\"400\" fill=\"#8C8580\" text-anchor=\"middle\" font-family=\"Inter, -apple-system, sans-serif\">Settings</text>\n  </svg>"
