    {
      "id": "fn198",
      "type": "text",
      "x": 22,
      "y": 1978,
      "width": 327,
      "content": "Today I woke before my alarm — unusual. The light\ncoming through the curtain had that early-spring\nquality, soft and almost green.",
      "fontSize": 14,
      "fontFamily": "\"Inter\",\"Helvetica Neue\",sans-serif",
      "fontWeight": "400",
      "color": "#1E130A",
      "textAlign": "left",
      "lineHeight": 1.65,
      "letterSpacing": 0,
      "opacity": 0.88
    },
    {
      "id": "fn199",
      "type": "text",
      "x": 22,
      "y": 2070,
      "width": 327,
      "content": "I made tea without reaching for my phone first.\nThat felt important. Something to hold onto.",
      "fontSize": 14,
      "fontFamily": "\"Inter\",\"Helvetica Neue\",sans-serif",
      "fontWeight": "400",
      "color": "#1E130A",
      "textAlign": "left",
      "lineHeight": 1.65,
      "letterSpacing": 0,
      "opacity": 0.88
    },
    {
      "id": "fn200",
      "type": "text",
      "x": 22,
      "y": 2136,
      "width": 327,
      "content": "What do I want from today? Not achievement —\njust presence. To notice the small things that\nusually scroll past me.",
      "fontSize": 14,
      "fontFamily": "\"Inter\",\"Helvetica Neue\",sans-serif",
      "fontWeight": "400",
      "color": "#1E130A",
      "textAlign": "left",
      "lineHeight": 1.65,
      "letterSpacing": 0,
      "opacity": 0.88
    },
