      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FAF7F2\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"0\" y=\"0\" width=\"390\" height=\"44\" fill=\"#FAF7F2\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"20\" y=\"29\" font-size=\"13\" fill=\"#1C1916\" font-weight=\"500\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">9:41</text>\n  <text x=\"370\" y=\"29\" font-size=\"11\" fill=\"#1C1916\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">●●●</text>\n  <text x=\"20\" y=\"68\" font-size=\"12\" fill=\"#A89D93\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"2\" opacity=\"1\">Journal</text>\n  <line x1=\"20\" y1=\"75\" x2=\"370\" y2=\"75\" stroke=\"#E3DAD0\" stroke-width=\"1\" opacity=\"1\"/>\n  <text x=\"20\" y=\"106\" font-size=\"13\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Thursday</text>\n  <text x=\"20\" y=\"134\" font-size=\"42\" fill=\"#1C1916\" font-weight=\"700\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">10 April</text>\n  <text x=\"20\" y=\"156\" font-size=\"13\" fill=\"#C4703A\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Day 6 · Andalucia</text>\n  <line x1=\"20\" y1=\"168\" x2=\"370\" y2=\"168\" stroke=\"#E3DAD0\" stroke-width=\"1\" opacity=\"1\"/>\n  <rect x=\"20\" y=\"178\" width=\"80\" height=\"60\" fill=\"#C4985A\" rx=\"8\" opacity=\"0.4\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"60\" y=\"214\" font-size=\"16\" fill=\"#C4985A\" font-weight=\"400\" font-family=\"system-ui\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"0.8\">▣</text>\n  <rect x=\"108\" y=\"178\" width=\"80\" height=\"60\" fill=\"#8FA87B\" rx=\"8\" opacity=\"0.4\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"148\" y=\"214\" font-size=\"16\" fill=\"#8FA87B\" font-weight=\"400\" font-family=\"system-ui\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"0.8\">▣</text>\n  <rect x=\"196\" y=\"178\" width=\"80\" height=\"60\" fill=\"#7BA3B8\" rx=\"8\" opacity=\"0.4\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"236\" y=\"214\" font-size=\"16\" fill=\"#7BA3B8\" font-weight=\"400\" font-family=\"system-ui\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"0.8\">▣</text>\n  <rect x=\"284\" y=\"178\" width=\"80\" height=\"60\" fill=\"#D4956A\" rx=\"8\" opacity=\"0.4\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"324\" y=\"214\" font-size=\"16\" fill=\"#D4956A\" font-weight=\"400\" font-family=\"system-ui\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"0.8\">▣</text>\n  <text x=\"20\" y=\"256\" font-size=\"11\" fill=\"#A89D93\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">14 photos</text>\n  <text x=\"370\" y=\"256\" font-size=\"11\" fill=\"#C4703A\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">+ Add</text>\n  <text x=\"20\" y=\"282\" font-size=\"14\" fill=\"#1C1916\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Left Granada as the city woke up — the</text>\n  <text x=\"20\" y=\"302\" font-size=\"14\" fill=\"#1C1916\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">market vendors setting up in Bib-Rambla,</text>\n  <text x=\"20\" y=\"322\" font-size=\"14\" fill=\"#1C1916\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">the air still cool from the Sierra Nevada.</text>\n  <text x=\"20\" y=\"350\" font-size=\"14\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"0.8\">The path climbed fast out of the city — olive</text>\n  <text x=\"20\" y=\"370\" font-size=\"14\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"0.8\">groves and cork oak, the occasional ruined</text>\n  <text x=\"20\" y=\"390\" font-size=\"14\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"0.8\">cortijo. By noon I reached Cenes…</text>\n  <rect x=\"20\" y=\"410\" width=\"4\" height=\"64\" fill=\"#C4703A\" rx=\"2\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"34\" y=\"430\" font-size=\"13\" fill=\"#1C1916\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"0.9\">\"The Alhambra behind me, the olive groves</text>\n  <text x=\"34\" y=\"450\" font-size=\"13\" fill=\"#1C1916\" font-weight=\"600\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"0.9\">ahead. Walking is just thinking slowly.\"</text>\n  <text x=\"34\" y=\"472\" font-size=\"11\" fill=\"#A89D93\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">— Journal note, 9:40am</text>\n  <rect x=\"20\" y=\"490\" width=\"68\" height=\"24\" fill=\"#F4EFE7\" rx=\"12\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"54\" y=\"506\" font-size=\"10\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Granada</text>\n  <rect x=\"96\" y=\"490\" width=\"68\" height=\"24\" fill=\"#F4EFE7\" rx=\"12\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"130\" y=\"506\" font-size=\"10\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Hiking</text>\n  <rect x=\"172\" y=\"490\" width=\"68\" height=\"24\" fill=\"#F4EFE7\" rx=\"12\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"206\" y=\"506\" font-size=\"10\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Solitude</text>\n  <rect x=\"248\" y=\"490\" width=\"68\" height=\"24\" fill=\"#F4EFE7\" rx=\"12\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"282\" y=\"506\" font-size=\"10\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Sunrise</text>\n  <rect x=\"20\" y=\"525\" width=\"350\" height=\"48\" fill=\"#FFFFFF\" rx=\"12\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"554\" font-size=\"13\" fill=\"#1C1916\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Mood: Content ◕</text>\n  <text x=\"354\" y=\"554\" font-size=\"12\" fill=\"#6B6259\" font-weight=\"400\" font-family=\"system-ui, sans-serif\" text-anchor=\"end\" letter-spacing=\"0\" opacity=\"1\">☀ 24°C · Sunny</text>\n  <rect x=\"20\" y=\"585\" width=\"350\" height=\"48\" fill=\"#EDCFB8\" rx=\"12\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n  <text x=\"36\" y=\"614\" font-size=\"13\" fill=\"#C4703A\" font-weight=\"600\" font-family=\"system-ui, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">🎙 Voice note · 2:14</text>\n  <rect x=\"160\" y=\"606.1863996100227\" width=\"3\" height=\"5.627200779954582\" fill=\"#C4703A\" rx=\"1\" opacity=\"0.6\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"166\" y=\"603.7948616336602\" width=\"3\" height=\"10.410276732679721\" fill=\"#C4703A\" rx=\"1\" opacity=\"0.6\" stroke=\"none\" stroke-width=\"0\"/>\n  <rect x=\"172\" y=\"601.3541918853266\" width=\"3\