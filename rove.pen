        },
        {
          "type": "text",
          "x": 20,
          "y": 322,
          "content": "the air still cool from the Sierra Nevada.",
          "fontSize": 14,
          "fill": "#1C1916",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "textAnchor": "start",
          "letterSpacing": 0,
          "opacity": 1
        },
        {
          "type": "text",
          "x": 20,
          "y": 350,
          "content": "The path climbed fast out of the city — olive",
          "fontSize": 14,
          "fill": "#6B6259",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "textAnchor": "start",
          "letterSpacing": 0,
