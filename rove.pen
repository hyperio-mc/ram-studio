        },
        {
          "type": "text",
          "x": 20,
          "y": 370,
          "content": "groves and cork oak, the occasional ruined",
          "fontSize": 14,
          "fill": "#6B6259",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
