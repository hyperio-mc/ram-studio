        {
          "type": "text",
          "x": 20,
          "y": 282,
          "content": "Left Granada as the city woke up — the",
          "fontSize": 14,
          "fill": "#1C1916",
          "fontWeight": 400,
          "fontFamily": "Georgia, serif",
          "textAnchor": "start",
