    {
      "name": "Brief Detail",
      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\">\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FAF7EC\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"2\" y=\"2\" width=\"390\" height=\"110\" fill=\"#1A1510\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"0\" y=\"0\" width=\"390\" height=\"110\" fill=\"#F9EAA9\" rx=\"0\" opacity=\"1\" stroke=\"#1A1510\" stroke-width=\"2\"/>\n    <text x=\"20\" y=\"36\" font-size=\"15\" fill=\"#1A1510\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">← Nova Rebrand</text>\n    <text x=\"20\" y=\"72\" font-size=\"24\" fill=\"#1A1510\" font-weight=\"900\" font-family=\"Georgia, serif\" text-anchor=\"start\" letter-spacing=\"-0.01em\" opacity=\"1\">Nova Rebrand System</text>\n    <text x=\"20\" y=\"96\" font-size=\"14\" fill=\"#6B6050\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">Nova Studio · $4,200 fixed</text>\n    <rect x=\"0\" y=\"112\" width=\"390\" height=\"52\" fill=\"#FFFFFF\" rx=\"0\" opacity=\"1\" stroke=\"#1A1510\" stroke-width=\"1\"/>\n    <rect x=\"18\" y=\"126\" width=\"108\" height=\"26\" fill=\"#1A1510\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"16\" y=\"124\" width=\"108\" height=\"26\" fill=\"#C8DFC8\" rx=\"4\" opacity=\"1\" stroke=\"#1A1510\" stroke-width=\"1.5\"/>\n    <text x=\"70\" y=\"142\" font-size=\"12\" fill=\"#1A1510\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">IN PROGRESS</text>\n    <rect x=\"142\" y=\"133\" width=\"180\" height=\"14\" fill=\"#1A1510\" rx=\"4\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <rect x=\"140\" y=\"131\" width=\"180\" height=\"14\" fill=\"#FFFFFF\" rx=\"4\" opacity=\"1\" stroke=\"#1A1510\" stroke-width=\"1.5\"/>\n    <rect x=\"141\" y=\"132\" width=\"116\" height=\"12\" fill=\"#E84B3A\" rx=\"3\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"326\" y=\"131\" font-size=\"12\" fill=\"#6B6050\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0\" opacity=\"1\">65%</text>\n    <rect x=\"0\" y=\"164\" width=\"390\" height=\"40\" fill=\"#FAF7EC\" rx=\"0\" opacity=\"1\" stroke=\"#1A1510\" stroke-width=\"1\"/>\n    <rect x=\"14\" y=\"164\" width=\"80\" height=\"40\" fill=\"#E84B3A\" rx=\"0\" opacity=\"1\" stroke=\"none\" stroke-width=\"0\"/>\n    <text x=\"54\" y=\"190\" font-size=\"13\" fill=\"#FFFFFF\" font-weight=\"800\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Brief</text>\n    <text x=\"146\" y=\"190\" font-size=\"13\" fill=\"#6B6050\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Assets</text>\n    <text x=\"238\" y=\"190\" font-size=\"13\" fill=\"#6B6050\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Notes</text>\n    <text x=\"330\" y=\"190\" font-size=\"13\" fill=\"#6B6050\" font-weight=\"500\" font-family=\"Inter, sans-serif\" text-anchor=\"middle\" letter-spacing=\"0\" opacity=\"1\">Time</text>\n    <line x1=\"0\" y1=\"204\" x2=\"390\" y2=\"204\" stroke=\"#1A1510\" stroke-width=\"2\" opacity=\"1\"/>\n    <text x=\"20\" y=\"226\" font-size=\"11\" fill=\"#6B6050\" font-weight=\"700\" font-family=\"Inter, sans-serif\" text-anchor=\"start\" letter-spacing=\"0.1em\" opacity=\"1\">DELIVERABLES</text>\n    <line x1=\"20\" y1=\"232\" x2=\"370\" y2=\"232\" stroke=\"#1A1510\" stroke-width=\"1\" opacity=\"1\"/>\n    <rect x=\"20\" y=\"244\" width=\"20\" height=\"20\" fill=\"#E84B3A\" rx=\"3\" opacity=\"1\" stroke=\"#1A1510\" stroke-width=\"2\"/>\n    <text x=\"30\" y=\"259\" font-size=\"13\" fill=\"#FFFFFF\" font-weight=\"900\" font-fam