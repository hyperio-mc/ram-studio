      "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"390\" height=\"844\" viewBox=\"0 0 390 844\"><defs>\n    <filter id=\"shadow-sm\"><feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"2\" flood-opacity=\"0.06\"/></filter>\n    <filter id=\"shadow-md\"><feDropShadow dx=\"0\" dy=\"2\" stdDeviation=\"6\" flood-opacity=\"0.10\"/></filter>\n  </defs><rect x=\"0\" y=\"0\" width=\"390\" height=\"844\" fill=\"#FBF8F3\"/>\n<line x1=\"0\" y1=\"212\" x2=\"390\" y2=\"212\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"236\" x2=\"390\" y2=\"236\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"260\" x2=\"390\" y2=\"260\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"284\" x2=\"390\" y2=\"284\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"308\" x2=\"390\" y2=\"308\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"332\" x2=\"390\" y2=\"332\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"356\" x2=\"390\" y2=\"356\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"380\" x2=\"390\" y2=\"380\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"404\" x2=\"390\" y2=\"404\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"428\" x2=\"390\" y2=\"428\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"452\" x2=\"390\" y2=\"452\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"476\" x2=\"390\" y2=\"476\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"500\" x2=\"390\" y2=\"500\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"524\" x2=\"390\" y2=\"524\" stroke=\"#E4DDD0\" stroke-width=\"0.3\" opacity=\"0.25\"/>\n<line x1=\"0\" y1=\"548\" x2=\"390\" y2=\"548\" stroke=\"#E4D